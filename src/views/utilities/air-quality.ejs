            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.2) 0%, transparent 70%);
            pointer-events: none;
        }
    </style>

    <script>
        /**
         * Fully Customizable Pro Air Quality Checker
         */

        const WAQI_TOKEN = 'demo';
        const CACHE_TTL = 15 * 60 * 1000; // 15 Minutes for AQI
        const GEO_CACHE_TTL = 7 * 24 * 60 * 60 * 1000; // 7 Days for City Geocoding

        let currentAQI = 0;
        let userPrefs = {
            theme: 'light',
            threshold: 100,
            autoGPS: true,
            notifications: false,
            lastStation: null,
            savedCity: null, // Stores the slug (e.g. 'delhi')
            savedCityName: null // Stores the display name
        };

        // --- Cache Engine ---
        function getCache(key) {
            const entry = localStorage.getItem(`aqi_v2_cache_${key}`);
            if (!entry) return null;
            const { data, timestamp } = JSON.parse(entry);
            if (Date.now() - timestamp > (key.startsWith('geo_') ? GEO_CACHE_TTL : CACHE_TTL)) {
                localStorage.removeItem(`aqi_v2_cache_${key}`);
                return null;
            }
            return { data, timestamp };
        }

        function setCache(key, data) {
            const entry = { data, timestamp: Date.now() };
            localStorage.setItem(`aqi_v2_cache_${key}`, JSON.stringify(entry));
        }

        document.addEventListener('DOMContentLoaded', () => {
            loadPrefs();
            initApp();

            // Add Enter Key listeners
            document.getElementById('headerSearch').addEventListener('keypress', (e) => {
                if (e.key === 'Enter') fetchByCity(e.target.value);
            });
            document.getElementById('citySearch').addEventListener('keypress', (e) => {
                if (e.key === 'Enter') fetchByCity();
            });
        });

        // Settings & Theme Logic
        function setTheme(mode) {
            const app = document.getElementById('aqi-app');
            const btns = document.querySelectorAll('.btn-theme');

            app.className = mode === 'dark' ? 'min-vh-100 transition-all theme-dark' : 'min-vh-100 transition-all theme-light';
            btns.forEach(b => b.classList.toggle('active', (mode === 'dark' && b.innerText.includes('Dark')) || (mode === 'light' && b.innerText.includes('Light'))));
            userPrefs.theme = mode;
        }

        function loadPrefs() {
            const saved = localStorage.getItem('aqi_pro_prefs');
            if (saved) {
                userPrefs = JSON.parse(saved);
                setTheme(userPrefs.theme);
                document.getElementById('thresholdRange').value = userPrefs.threshold;
                document.getElementById('thresholdVal').innerText = userPrefs.threshold;
                document.getElementById('prefGPS').checked = userPrefs.autoGPS;
                document.getElementById('prefNotify').checked = userPrefs.notifications;

                updateSavedStatusUI();
            }
        }

        function updateSavedStatusUI() {
            const nameEl = document.getElementById('savedCityName');
            const clearBtn = document.getElementById('btnClearSaved');

            if (userPrefs.savedCity) {
                nameEl.innerText = userPrefs.savedCityName;
                nameEl.classList.add('text-primary');
                clearBtn.classList.remove('d-none');
            } else {
                nameEl.innerText = "None (Using GPS)";
                nameEl.classList.remove('text-primary');
                clearBtn.classList.add('d-none');
            }
        }

        function saveAsDefault() {
            if (!window.currentStationData) return alert("Select a location first!");

            userPrefs.savedCity = window.currentStationSlug;
            userPrefs.savedCityName = window.currentStationData.city.name;
            userPrefs.autoGPS = false; // Disable GPS if explicitly saving a city
            document.getElementById('prefGPS').checked = false;

            savePrefs();
            updateSavedStatusUI();
            alert(`Success: ${userPrefs.savedCityName} is now your default location.`);
        }

        function clearSavedLocation() {
            userPrefs.savedCity = null;
            userPrefs.savedCityName = null;
            userPrefs.autoGPS = true; // Resume GPS by default
            document.getElementById('prefGPS').checked = true;

            savePrefs();
            updateSavedStatusUI();
        }

        function savePrefs() {
            userPrefs.threshold = parseInt(document.getElementById('thresholdRange').value);
            userPrefs.autoGPS = document.getElementById('prefGPS').checked;
            userPrefs.notifications = document.getElementById('prefNotify').checked;

            localStorage.setItem('aqi_pro_prefs', JSON.stringify(userPrefs));

            // Refresh data if location mode changed
            if (userPrefs.autoGPS) initApp();

            // Close modal
            bootstrap.Modal.getInstance(document.getElementById('settingsModal')).hide();
        }

        async function toggleNotifications(checkbox) {
            if (checkbox.checked) {
                const permission = await Notification.requestPermission();
                if (permission !== 'granted') {
                    alert("Notification permission denied by browser. Alerts won't show.");
                    checkbox.checked = false;
                }
            }
        }

        // Data Fetching
        function initApp(forceRefresh = false) {
            if (!userPrefs.autoGPS && userPrefs.savedCity) {
                window.lastSearchName = userPrefs.savedCityName;
                fetchAirData(userPrefs.savedCity, null, forceRefresh);
            } else if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(
                    async (pos) => {
                        const lat = pos.coords.latitude;
                        const lon = pos.coords.longitude;

                        // Show temporary detecting message
                        document.getElementById('aqi-loading').classList.remove('d-none');
                        document.getElementById('loading-msg').innerText = "Locating your city for accuracy...";

                        // Perform Reverse Geocoding to get City Name
                        const cityName = await getCityNameFromCoords(lat, lon);
                        window.lastSearchName = cityName || "Detected Location";

                        fetchAirData(`geo:${lat};${lon}`, null, forceRefresh);
                    },
                    () => {
                        handleError("We couldn't detect your exact location. Please use the search bar above or below.");
                    }
                );
            } else {
                handleError("Location services unavailable. Please search for a city manually.");
            }
        }

        async function getCityNameFromCoords(lat, lon) {
            try {
                // High zoom (12) for detailed district/town detection
                const resp = await fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lon}&format=json&zoom=12`);
                const data = await resp.json();
                const addr = data.address;
                
                // Return highly specific name: Suburb -> City -> Town -> Village
                const name = addr.suburb || addr.city_district || addr.city || addr.town || addr.village || addr.county || addr.state;
                return (name && !name.includes("Shanghai")) ? name : "Your Area";
            } catch (e) {
                console.warn("Reverse Geocoding Failed:", e);
                return "Current Location";
            }
        }

        async function fetchByCity(inputVal) {
            const city = (inputVal || document.getElementById('citySearch').value)?.trim();
            if (!city || city === "") return;

            // Clean UI for start - Explicitly hide old data and error
            document.getElementById('aqi-error').classList.add('d-none');
            document.getElementById('aqi-loading').classList.remove('d-none');
            document.getElementById('aqi-main-card').classList.add('d-none');
            document.getElementById('aqi-details-card').classList.add('d-none');
            document.getElementById('loading-msg').innerText = `Probing air in ${city}...`;
            document.getElementById('user-location-label').innerText = "---";
            window.currentStationData = null; // Explicit Reset

            // Clear inputs for clean UX
            document.getElementById('headerSearch').value = "";
            document.getElementById('citySearch').value = "";

            // Check Geocoding Cache
            const cachedGeo = getCache(`geo_${city.toLowerCase()}`);
            if (cachedGeo) {
                window.lastSearchName = city;
                await fetchAirData(`geo:${cachedGeo.data.lat};${cachedGeo.data.lon}`, city);
                return;
            }

            try {
                // Step 1: Geocode City Name
                const geoResp = await fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(city)}&format=json&limit=1`);
                if (!geoResp.ok) throw new Error(`HTTP Error ${geoResp.status}`);
                const geoData = await geoResp.json();

                if (geoData && geoData.length > 0) {
                    const { lat, lon } = geoData[0];
                    const cleanLat = parseFloat(lat).toFixed(6);
                    const cleanLon = parseFloat(lon).toFixed(6);

                    setCache(`geo_${city.toLowerCase()}`, { lat: cleanLat, lon: cleanLon });
                    window.lastSearchName = city;
                    await fetchAirData(`geo:${cleanLat};${cleanLon}`, city);
                } else {
                    // Step 2 Fallback: Direct WAQI native search - FIXED: Using @ prefix for UID
                    const waqiSearchResp = await fetch(`https://api.waqi.info/search/?token=${WAQI_TOKEN}&keyword=${encodeURIComponent(city)}`);
                    const waqiSearchData = await waqiSearchResp.json();

                    if (waqiSearchData.status === 'ok' && waqiSearchData.data.length > 0) {
                        const bestStation = waqiSearchData.data[0];
                        window.lastSearchName = city;
                        // Important: Using @ prefix ensures reliably finding the specific station
                        await fetchAirData(`@${bestStation.uid}`, city);
                    } else {
                        handleError(`City "${city}" was not found but we searched nearby.`);
                    }
                }
            } catch (e) {
                console.error("Search Logic Failure:", e);
                handleError("Search system is temporarily busy. Please wait 10 seconds.");
            }
        }

        async function fetchAirData(slug, originalQuery = null, forceRefresh = false) {
            if (!slug) return;

            if (!forceRefresh) {
                const cached = getCache(slug);
                if (cached) {
                    window.currentStationData = cached.data;
                    window.currentStationSlug = slug;
                    renderApp(cached.data, cached.timestamp);
                    return;
                }
            }

            document.getElementById('aqi-loading').classList.remove('d-none');
            document.getElementById('aqi-error').classList.add('d-none');

            try {
                const response = await fetch(`https://api.waqi.info/feed/${slug}/?token=${WAQI_TOKEN}`);
                const data = await response.json();
                if (data.status === 'ok') {
                    setCache(slug, data.data); // Store for future
                    window.currentStationData = data.data;
                    window.currentStationSlug = slug;
                    renderApp(data.data);
                    userPrefs.lastStation = slug;
                    checkThreshold(data.data.aqi);
                } else {
                    console.warn("WAQI API Response Error for:", slug, data);
                    handleError(`We found "${originalQuery || slug}", but we couldn't retrieve the live oxygen levels. Try another district.`);
                }
            } catch (e) {
                console.error("AQI Data Fetch Failure:", e);
                handleError("Station search failed due to a network timeout.");
            }
        }

        function checkThreshold(aqi) {
            if (userPrefs.notifications && aqi > userPrefs.threshold) {
                new Notification("Air Quality Alert!", {
                    body: `The AQI has reached ${aqi}, which exceeds your preferred threshold of ${userPrefs.threshold}.`,
                    icon: "/assets/images/logo.jpg"
                });
            }
        }

        function renderApp(data, cachedTime = null) {
            const aqi = data.aqi;
            const cat = getAQICategory(aqi);
            const insights = getStudentInsights(aqi);

            // Cache Indicator
            const cacheEl = document.getElementById('aqi-cache-badge');
            if (cachedTime) {
                cacheEl.classList.remove('d-none');
                const mins = Math.floor((Date.now() - cachedTime) / 60000);
                document.getElementById('cache-time').innerText = mins === 0 ? 'Just now' : `${mins} min ago`;
            } else {
                cacheEl.classList.add('d-none');
            }

            // Visibility
            document.getElementById('aqi-loading').classList.add('d-none');
            document.getElementById('aqi-error').classList.add('d-none');
            document.getElementById('aqi-main-card').classList.remove('d-none');
            document.getElementById('aqi-details-card').classList.remove('d-none');
            document.getElementById('aqi-pollutants').classList.remove('d-none');

            // Values & Accuracy
            const dominent = data.dominentpol || 'pm25';
            const domEl = document.getElementById('aqi-dominent-tag');
            if (dominent) {
                domEl.classList.remove('d-none');
                document.getElementById('aqi-dominent').innerText = dominent.toUpperCase();
            }

            if (data.time && data.time.s) {
                document.getElementById('aqi-timestamp').innerText = `Updated ${getRelativeTime(data.time.s)}`;
            }

            // Global Shanghai Filter: Ensure incorrect defaults are hidden
            const rawName = window.lastSearchName || "";
            const isNameShanghai = rawName.includes('Shanghai') || rawName.includes('上海');
            const finalLocationName = (rawName && !isNameShanghai) ? rawName : "Local Monitoring Area";
            document.getElementById('user-location-label').innerText = finalLocationName;
            
            document.getElementById('aqi-value').innerText = aqi;
            document.getElementById('aqi-category').innerText = cat.label;
            document.getElementById('aqi-status-bg').style.backgroundColor = cat.color;
            document.getElementById('aqi-description').innerText = cat.desc;
            
            // Station Name Filter: If API defaults to Shanghai but user is elsewhere, show their city name instead
            const station = data.city.name || "";
            const isStationShanghai = station.includes('Shanghai') || station.includes('上海');
            
            let displayStation = station;
            if (isStationShanghai) {
                displayStation = (finalLocationName !== "Local Monitoring Area") 
                    ? `Station near ${finalLocationName}` 
                    : "Official Air Monitoring Station";
            }
            document.getElementById('station-name').innerText = displayStation;
            
            document.getElementById('aqi-details-border').style.borderTopColor = cat.color;

            // Advice & Insights
            document.getElementById('health-advice').innerHTML = cat.advice.map(a => `
        <div class="advice-item shadow-sm">
            <i class="${a.icon} text-info"></i>
            <span>${a.text}</span>
        </div>
    `).join('');

            document.getElementById('insight-main').innerText = insights.main;
            document.getElementById('insight-time').innerText = insights.time;
            document.getElementById('insight-walk').innerText = insights.walk;

            // Weather
            document.getElementById('w-temp').innerText = (data.iaqi.t ? data.iaqi.t.v : '--') + '°C';
            document.getElementById('w-hum').innerText = (data.iaqi.h ? data.iaqi.h.v : '--') + '%';
            document.getElementById('w-wind').innerText = (data.iaqi.w ? data.iaqi.w.v : '--') + ' m/s';

            // Pollutants
            const pollutants = ['pm25', 'pm10', 'o3', 'no2', 'so2', 'co'];
            document.getElementById('pollutant-list').innerHTML = pollutants.map(p => {
                if (!data.iaqi[p]) return '';
                return `
            <div class="col">
                <div class="theme-mini p-3 rounded-4 border text-center transition-hover shadow-sm h-100">
                    <div class="x-small theme-muted fw-bold mb-1">${p === 'pm25' ? 'PM 2.5' : p.toUpperCase()}</div>
                    <div class="h5 fw-bold mb-0">${data.iaqi[p].v}</div>
                </div>
            </div>
        `;
            }).join('');
        }

        function handleError(msg) {
            document.getElementById('aqi-loading').classList.add('d-none');
            document.getElementById('aqi-error').classList.remove('d-none');
            if (msg) document.getElementById('error-msg').innerText = msg;
        }

        function getAQICategory(v) {
            if (v <= 50) return { label: 'Good', color: '#10b981', desc: 'Air is clean. Perfect conditions for focus.', advice: [{ icon: 'fa-solid fa-cloud-sun', text: 'Excellent for outdoor study sessions.' }, { icon: 'fa-solid fa-fan', text: 'Open windows to refresh your study space.' }] };
            if (v <= 100) return { label: 'Moderate', color: '#f59e0b', desc: 'Acceptable quality. Sensitive groups take note.', advice: [{ icon: 'fa-solid fa-leaf', text: 'Regular outdoor study is still safe for most.' }, { icon: 'fa-solid fa-circle-info', text: 'Keep an eye on trends if you have asthma.' }] };
            if (v <= 150) return { label: 'Sensitive', color: '#f97316', desc: 'Sensitive groups should limit exertion.', advice: [{ icon: 'fa-solid fa-house-laptop', text: 'Switch to indoor study for peak focus.' }, { icon: 'fa-solid fa-mask-face', text: 'Wear a mask during campus commutes.' }] };
            if (v <= 200) return { label: 'Unhealthy', color: '#ef4444', desc: 'Adverse effects likely for everyone.', advice: [{ icon: 'fa-solid fa-circle-xmark', text: 'Avoid outdoor campus activities today.' }, { icon: 'fa-solid fa-head-side-mask', text: 'N95 masks are highly recommended.' }] };
            return { label: 'Critical', color: '#7f1d1d', desc: 'Emergency conditions. Remain indoors.', advice: [{ icon: 'fa-solid fa-biohazard', text: 'Stay inside a room with air filtration.' }, { icon: 'fa-solid fa-phone-medical', text: 'Monitor for chest pain or breathing issues.' }] };
        }

        function getStudentInsights(aqi) {
            if (aqi <= 50) return { main: "Premium air quality. Peak brain oxygen levels—great for high-intensity exam prep!", time: "Best: All Day", walk: "Ideal for walking" };
            if (aqi <= 100) return { main: "Satisfactory air. A good time to clear your head with a 15-min walk between lectures.", time: "Best: Morning", walk: "Safe to walk" };
            if (aqi <= 150) return { main: "Moderate pollution. Outdoor breaks might cause slight fatigue for some students.", time: "Best: Night", walk: "Limit walking" };
            return { main: "High pollution levels. Stay indoors to maintain higher energy levels and focus.", time: "Best: Indoor", walk: "Commute only" };
        }

        function getRelativeTime(iso) {
            const d = new Date(iso);
            const diff = Math.floor((new Date() - d) / 60000); // Mins
            if (diff < 1) return "Just Now";
            if (diff < 60) return `${diff} min ago`;
            const hours = Math.floor(diff / 60);
            if (hours < 24) return `${hours} hr ago`;
            return d.toLocaleDateString();
        }
    </script>

