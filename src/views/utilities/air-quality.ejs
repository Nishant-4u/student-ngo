<%- include('../partials/header') %>

    <main id="aqi-app" class="min-vh-100 transition-all theme-light" style="padding-top: 100px !important;">
        <div class="container py-5">
            <div class="row justify-content-center">
                <div class="col-lg-10">

                    <div class="d-flex justify-content-between align-items-center mb-5">
                        <div>
                            <h1 class="display-5 fw-bold mb-0 theme-text">
                                <i class="fa-solid fa-wind me-2 text-info"></i> Air Quality Pro
                            </h1>
                            <p class="theme-muted small mb-0 mt-1">Customizable monitoring for students & commuters.</p>
                        </div>
                        <div class="d-flex btn-group input-group-sm">
                            <div
                                class="input-group input-group-sm max-w-300 me-2 d-none d-md-flex shadow-sm rounded-pill overflow-hidden border">
                                <input type="text" id="headerSearch" class="form-control border-0 px-3"
                                    placeholder="Quick Search City...">
                                <button class="btn btn-info text-white px-3"
                                    onclick="fetchByCity(document.getElementById('headerSearch').value)"><i
                                        class="fa-solid fa-magnifying-glass"></i></button>
                            </div>
                            <button class="btn btn-outline-info rounded-pill px-4 fw-bold shadow-sm"
                                data-bs-toggle="modal" data-bs-target="#settingsModal">
                                <i class="fa-solid fa-gears me-2"></i> Settings
                            </button>
                        </div>
                    </div>

                    <div id="aqi-dashboard" class="row g-4 align-items-stretch">
                        <!-- Loading -->
                        <div id="aqi-loading" class="col-12 text-center py-5 d-none">
                            <div class="spinner-border text-info mb-3" role="status"></div>
                            <p class="fw-bold text-muted" id="loading-msg">Analyzing your local atmosphere...</p>
                        </div>

                        <!-- Error / Empty State -->
                        <div id="aqi-error" class="col-12 text-center py-5">
                            <div class="p-5 theme-card shadow-sm rounded-4 border">
                                <i class="fa-solid fa-location-dot fa-4x text-info opacity-50 mb-3"></i>
                                <h4 class="fw-bold theme-text">Choose a Location to Begin</h4>
                                <p class="theme-muted" id="error-msg">Search for your current city to see real-time
                                    student health alerts.</p>
                                <div
                                    class="input-group mb-3 max-w-400 mx-auto mt-4 shadow rounded-pill overflow-hidden border">
                                    <input type="text" id="citySearch" class="form-control border-0 px-4"
                                        placeholder="Enter City Name...">
                                    <button class="btn btn-info text-white fw-bold px-4"
                                        onclick="fetchByCity()">Search</button>
                                </div>
                            </div>
                        </div>

                        <!-- Main Gauge Card -->
                        <div id="aqi-main-card" class="col-md-5 d-none">
                            <div id="aqi-status-bg"
                                class="h-100 rounded-4 p-5 text-white d-flex flex-column align-items-center justify-content-center text-center shadow-lg position-relative overflow-hidden">
                                <div class="aqi-label small fw-bold text-uppercase mb-2 opacity-75">Current AQI Index
                                </div>
                                <div class="d-flex align-items-center justify-content-center gap-2 mb-1">
                                    <div id="user-location-label" class="h4 fw-bold mb-0 opacity-90">---</div>
                                    <button class="btn btn-sm btn-link text-white opacity-75 p-0"
                                        onclick="initApp(true)" title="Force Refresh Data"><i
                                            class="fa-solid fa-rotate"></i></button>
                                    <button class="btn btn-sm btn-link text-white opacity-75 p-0"
                                        onclick="document.getElementById('aqi-error').classList.toggle('d-none'); document.getElementById('citySearch').focus();"
                                        title="Search Manually"><i class="fa-solid fa-magnifying-glass"></i></button>
                                </div>
                                <div id="aqi-cache-badge" class="x-small fw-bold text-uppercase mb-2 d-none"
                                    style="background: rgba(255,255,255,0.15); padding: 4px 10px; border-radius: 100px;">
                                    <i class="fa-solid fa-database me-1"></i> Cached: <span id="cache-time">--</span>
                                </div>
                                <div id="aqi-value" class="display-1 fw-bold mb-0">--</div>
                                <div id="aqi-category" class="h3 fw-bold mb-1">...</div>
                                <div id="aqi-dominent-tag"
                                    class="small fw-bold text-uppercase opacity-75 mb-3 bg-white bg-opacity-10 px-3 py-1 rounded-pill d-none">
                                    Main Pollutant: <span id="aqi-dominent">--</span>
                                </div>
                                <div id="aqi-description" class="small opacity-90 px-lg-3">--</div>
                                <div id="aqi-timestamp" class="x-small fw-bold text-uppercase mt-2 opacity-50">Just
                                    updated</div>
                                
                                <div class="mt-4 pt-3 border-top border-white border-opacity-25 w-100 fs-6 fw-bold">
                                    <span id="station-name">---</span>
                                </div>
                            </div>
                        </div>

                        <!-- Details & Personalized Student Insights -->
                        <div id="aqi-details-card" class="col-md-7 d-none">
                            <div id="aqi-details-border"
                                class="theme-card h-100 rounded-4 p-4 border-top border-5 shadow-sm d-flex flex-column transition-all"
                                style="border-top-color: #cbd5e1;">

                                <!-- Interactive Tab Section -->
                                <ul class="nav nav-pills mb-4 gap-2 bg-light p-1 rounded-pill d-inline-flex"
                                    id="aqi-tabs" role="tablist">
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link active rounded-pill px-4 small fw-bold"
                                            data-bs-toggle="pill" data-bs-target="#tab-health">Health Tips</button>
                                    </li>
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link rounded-pill px-4 small fw-bold" data-bs-toggle="pill"
                                            data-bs-target="#tab-student">Student Insights</button>
                                    </li>
                                </ul>

                                <div class="tab-content flex-grow-1" id="aqi-tabsContent">
                                    <!-- Standard Health Advice -->
                                    <div class="tab-pane fade show active" id="tab-health" role="tabpanel">
                                        <div id="health-advice" class="d-flex flex-column gap-3 mb-4"></div>
                                    </div>

                                    <!-- Student Personalized Insights -->
                                    <div class="tab-pane fade" id="tab-student" role="tabpanel">
                                        <div id="student-insights" class="row g-3">
                                            <div class="col-12 mb-3 px-2">
                                                <h6 class="fw-bold mb-3 d-flex align-items-center"><i
                                                        class="fa-solid fa-graduation-cap text-primary me-2"></i>
                                                    Personalized Productivity Hacks</h6>
                                                <div
                                                    class="p-3 bg-primary bg-opacity-5 border-start border-primary border-4 rounded-end">
                                                    <p id="insight-main" class="small mb-0 fw-medium">Calculating the
                                                        best study environment for you...</p>
                                                </div>
                                            </div>
                                            <div class="col-6">
                                                <div
                                                    class="theme-mini p-3 rounded-4 border transition-hover text-center shadow-sm">
                                                    <div class="small theme-muted mb-1 fw-bold text-uppercase">Study
                                                        Time</div>
                                                    <div id="insight-time" class="fw-bold text-primary">Best: --</div>
                                                </div>
                                            </div>
                                            <div class="col-6">
                                                <div
                                                    class="theme-mini p-3 rounded-4 border transition-hover text-center shadow-sm">
                                                    <div class="small theme-muted mb-1 fw-bold text-uppercase">Outdoor
                                                        Break</div>
                                                    <div id="insight-walk" class="fw-bold text-success">Good: --</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Mini Weather -->
                                <div class="mt-auto pt-4 border-top">
                                    <div class="row text-center g-3">
                                        <div class="col-4">
                                            <div class="theme-mini rounded-3 p-2 border shadow-xs transition-hover">
                                                <div class="x-small theme-muted fw-bold">TEMP</div>
                                                <div class="fw-bold" id="w-temp">--</div>
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <div class="theme-mini rounded-3 p-2 border shadow-xs transition-hover">
                                                <div class="x-small theme-muted fw-bold">HUMIDITY</div>
                                                <div class="fw-bold" id="w-hum">--</div>
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <div class="theme-mini rounded-3 p-2 border shadow-xs transition-hover">
                                                <div class="x-small theme-muted fw-bold">WIND</div>
                                                <div class="fw-bold" id="w-wind">--</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Pollutants Grid -->
                        <div id="aqi-pollutants" class="col-12 d-none mt-4">
                            <div class="theme-card border rounded-4 p-4 shadow-sm">
                                <h6 class="fw-bold mb-4 opacity-75"><i class="fa-solid fa-microchip me-2"></i> Real-time
                                    Sensor Breakdown</h6>
                                <div class="row row-cols-2 row-cols-md-3 row-cols-lg-6 g-3" id="pollutant-list"></div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- Settings Modal -->
        <div class="modal fade" id="settingsModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 rounded-4 shadow-lg overflow-hidden">
                    <div class="modal-header bg-info text-white py-3 px-4">
                        <h5 class="modal-title fw-bold">Customization & Alerts</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-4">

                        <div class="mb-4">
                            <label class="fw-bold small text-muted text-uppercase mb-2 d-block text-info">Station
                                Customization</label>
                            <div id="savedLocationStatus"
                                class="p-3 bg-light rounded-4 border d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="x-small text-muted fw-bold">SAVED LOCATION</div>
                                    <div id="savedCityName" class="small fw-bold">None (Using GPS)</div>
                                </div>
                                <button class="btn btn-link text-danger btn-sm p-0 d-none" id="btnClearSaved"
                                    onclick="clearSavedLocation()"><i class="fa-solid fa-trash-can"></i></button>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="fw-bold small text-muted text-uppercase mb-2 d-block">App Appearance</label>
                            <div class="btn-group w-100 shadow-sm rounded-pill overflow-hidden p-1 bg-light border">
                                <button type="button"
                                    class="btn btn-sm btn-white btn-theme border-0 rounded-pill active"
                                    onclick="setTheme('light')">Light Mode</button>
                                <button type="button" class="btn btn-sm btn-white btn-theme border-0 rounded-pill"
                                    onclick="setTheme('dark')">Dark Mode</button>
                            </div>
                        </div>

                        <hr class="my-4 opacity-10">

                        <div class="mb-4">
                            <label class="fw-bold small text-muted text-uppercase mb-2 d-block">Default Alert
                                Threshold</label>
                            <p class="x-small text-muted mb-3">Receive a browser notification if AQI exceeds this level.
                            </p>
                            <div class="d-flex align-items-center gap-3">
                                <input type="range" class="form-range flex-grow-1" id="thresholdRange" min="50"
                                    max="300" step="10" value="100"
                                    oninput="document.getElementById('thresholdVal').innerText = this.value">
                                <span id="thresholdVal" class="badge bg-info fw-bold py-2 px-3 fs-6">100</span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="fw-bold small text-muted text-uppercase mb-2 d-block">Station Sync</label>
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" id="prefGPS" checked>
                                <label class="form-check-label small" for="prefGPS">Auto-detect location
                                    (GPS/IP)</label>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="prefNotify"
                                    onchange="toggleNotifications(this)">
                                <label class="form-check-label small" for="prefNotify">Enable Air Alerts
                                    (Notifications)</label>
                            </div>
                        </div>

                    </div>
                    <div class="modal-footer bg-light border-0 py-3">
                        <button type="button" class="btn btn-info w-100 rounded-pill fw-bold" onclick="savePrefs()">Save
                            & Apply Changes</button>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <style>
        /* CSS Variable System for Themes */
