<%- include('../partials/header') %>

<section class="py-5 text-white text-center" style="background: linear-gradient(135deg, #0ea5e9 0%, #6366f1 100%); padding-top: 100px !important;">
  <div class="container py-5 mt-4">
    <h1 class="display-4 fw-bold mb-3"><i class="fa-solid fa-screwdriver-wrench me-3"></i> Essential Student Utilities: Writing & Environment Tools</h1>
    <p class="lead fw-light mb-0" style="max-width: 640px; margin: 0 auto;">
      A collection of professional digital tools for your assignments, environment, and daily productivity.
    </p>
  </div>
</section>

<main class="container py-5">
  <div class="row g-4">

    <!-- Air Quality Checker -->
    <div class="col-md-6 col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 h-100 p-3 text-center transition-hover">
        <div class="card-body">
          <div class="feature-icon-circle bg-info bg-opacity-10 text-info mb-3 mx-auto">
            <i class="fa-solid fa-wind fa-2x"></i>
          </div>
          <h4 class="fw-bold">Air Quality Tracker</h4>
          <p class="text-muted small">Real-time local AQI data with student-focused health advice.</p>
          <div class="mt-3">
             <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 small mb-3">Live Updates</span>
          </div>
          <a href="/air-quality" class="btn btn-outline-info rounded-pill w-100 fw-bold">Check Local Air</a>
        </div>
      </div>
    </div>

    <!-- Grammar & Spell Checker -->
    <div class="col-md-6 col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 h-100 p-3 text-center transition-hover">
        <div class="card-body">
          <div class="feature-icon-circle bg-primary bg-opacity-10 text-primary mb-3 mx-auto">
            <i class="fa-solid fa-spell-check fa-2x"></i>
          </div>
          <h4 class="fw-bold">Smart Grammar</h4>
          <p class="text-muted small">Advanced AI-powered writing assistant with click-to-fix suggestions.</p>
          <div class="mt-3">
             <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 small mb-3">Real-time Highlights</span>
          </div>
          <a href="/grammar-checker" class="btn btn-outline-primary rounded-pill w-100 fw-bold">Analyze Writing</a>
        </div>
      </div>
    </div>

    <!-- Word Counter -->
    <div class="col-md-6 col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 h-100 p-3 text-center transition-hover">
        <div class="card-body">
          <div class="feature-icon-circle bg-success bg-opacity-10 text-success mb-3 mx-auto">
            <i class="fa-solid fa-hashtag fa-2x"></i>
          </div>
          <h4 class="fw-bold">Word Counter</h4>
          <p class="text-muted small">Deep statistics on character counts, reading time, and clarity.</p>
          <div class="mt-3">
             <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 small mb-3">Essay Mode</span>
          </div>
          <a href="/word-counter" class="btn btn-outline-success rounded-pill w-100 fw-bold">Open Counter</a>
        </div>
      </div>
    </div>

    <!-- Weather Forecast -->
    <div class="col-md-6 col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 h-100 p-3 text-center transition-hover opacity-75">
        <div class="card-body">
          <div class="feature-icon-circle bg-warning bg-opacity-10 text-warning mb-3 mx-auto">
            <i class="fa-solid fa-cloud-sun fa-2x"></i>
          </div>
          <h4 class="fw-bold">Weather Station</h4>
          <p class="text-muted small">Plan your study day with local temperature and storm alerts.</p>
          <a href="/weather" class="btn btn-outline-warning rounded-pill w-100 fw-bold">View Forecast</a>
        </div>
      </div>
    </div>

    <!-- Digital Compass -->
    <div class="col-md-6 col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 h-100 p-3 text-center transition-hover opacity-75">
        <div class="card-body">
          <div class="feature-icon-circle bg-danger bg-opacity-10 text-danger mb-3 mx-auto">
            <i class="fa-solid fa-compass fa-2x"></i>
          </div>
          <h4 class="fw-bold">Digital Compass</h4>
          <p class="text-muted small">Find your orientation on the go with our browser-based compass.</p>
          <a href="/compass" class="btn btn-outline-danger rounded-pill w-100 fw-bold">Open Compass</a>
        </div>
      </div>
    </div>

  </div>

  <div class="text-center mt-5">
      <a href="/" class="btn btn-link text-muted fw-bold text-decoration-none"><i class="fa-solid fa-arrow-left me-2"></i> Back to Home</a>
  </div>
</main>

<style>
.transition-hover { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); cursor: pointer; }
.transition-hover:hover { transform: translateY(-10px); box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1) !important; }

.feature-icon-circle {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
}
</style>

<%- include('../partials/footer') %>
