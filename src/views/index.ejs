      <script>
        document.addEventListener("DOMContentLoaded", function () {
          const noteBtns = document.querySelectorAll('.notes-buy-btn');
          const noteNameDisplay = document.getElementById('selectedNoteName');
          const noteNameInput = document.getElementById('noteNameInput');
          const notesDownloadLink = document.getElementById('notesDownloadLink');

          const stepForm = document.getElementById('notesStepForm');
          const stepPayment = document.getElementById('notesStepPayment');
          const stepInstruction = document.getElementById('notesStepInstruction');
          const stepConfirmation = document.getElementById('notesStepConfirmation');

          const notesPurchaseForm = document.getElementById('notesPurchaseForm');
          const btnConfirmed = document.getElementById('btnConfirmed');
          const btnInstructionNext = document.getElementById('btnInstructionNext');

          // Map of products to their Google Drive Links
          const noteDriveLinks = {
            'UPSC Exam Notes': 'https://drive.google.com/drive/folders/1Dc8zyUB1Oma7kco0vsDdfnHvpQptYtXt?usp=sharing',
            'GATE Exam Notes': 'https://drive.google.com/drive/folders/1MzlifurAtKR7xOur9jP_SiUh4puUCFGT?usp=drive_link',
            'NEET Exam Notes': 'https://drive.google.com/drive/folders/1kTo058ZLX32J4kG6nVBJB8HFdyKfJJUc?usp=drive_link'
          };

          noteBtns.forEach(btn => {
            btn.addEventListener('click', function () {
              const noteProduct = this.getAttribute('data-note');
              noteNameDisplay.textContent = noteProduct;
              if (noteNameInput) noteNameInput.value = noteProduct;

              // Pre-set the download link
              if (notesDownloadLink) {
                notesDownloadLink.href = noteDriveLinks[noteProduct] || 'https://drive.google.com/drive/folders/GENERAL_NOTES_LINK';
              }

              // Reset steps
              stepForm.classList.remove('d-none');
              stepPayment.classList.add('d-none');
              stepInstruction.classList.add('d-none');
              stepConfirmation.classList.add('d-none');
              notesPurchaseForm.reset();
            });
          });

          notesPurchaseForm.addEventListener('submit', async function (e) {
            e.preventDefault();

            const submitBtn = notesPurchaseForm.querySelector('button[type="submit"]');
            const fullScreenLoader = document.getElementById('full-screen-loader');

            // Disable button and show loader
            if (submitBtn) submitBtn.disabled = true;
            if (fullScreenLoader) fullScreenLoader.classList.remove('d-none');

            // Send Email Data
            try {
              const formData = new FormData(notesPurchaseForm);
              const payload = Object.fromEntries(formData.entries());
              payload.formName = notesPurchaseForm.dataset.formName;

              await fetch('/send-email', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
              });
            } catch (error) {
              console.error('Notes email error:', error);
            } finally {
              // Hide loader and transition to payment step
              if (fullScreenLoader) fullScreenLoader.classList.add('d-none');
              stepForm.classList.add('d-none');
              stepPayment.classList.remove('d-none');
              if (submitBtn) submitBtn.disabled = false;
            }
          });

          btnConfirmed.addEventListener('click', function () {
            stepPayment.classList.add('d-none');
            stepInstruction.classList.remove('d-none');
          });

          btnInstructionNext.addEventListener('click', function () {
            stepInstruction.classList.add('d-none');
            stepConfirmation.classList.remove('d-none');
          });
        });
      </script>

