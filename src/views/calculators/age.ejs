<%- include('../partials/header') %>

<main class="container py-5 my-0">
  <div class="row pt-5 justify-content-center">
    <div class="col-lg-6">
      <div class="bg-white p-4 p-md-5 rounded-4 shadow-lg border-0 text-center">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb justify-content-center mb-4">
            <li class="breadcrumb-item"><a href="/calculators">Calculators</a></li>
            <li class="breadcrumb-item active" aria-current="page">Age</li>
          </ol>
        </nav>

        <ul class="nav nav-pills nav-fill bg-light p-1 rounded-3 mb-5 mt-2">
          <li class="nav-item"><a class="nav-link text-dark fw-bold" href="/calculator">Scientific Calculator</a></li>
          <li class="nav-item"><a class="nav-link text-dark fw-bold" href="/calculators/cgpa">CGPA</a></li>
          <li class="nav-item"><a class="nav-link text-dark fw-bold" href="/calculators/percentage">Percentage</a></li>
          <li class="nav-item"><a class="nav-link active fw-bold" href="/calculators/age">Age</a></li>
        </ul>

        <h1 class="display-5 fw-bold mb-3 text-danger"><i class="fa-solid fa-cake-candles me-2"></i> Age Calculator</h1>
        <p class="text-muted mb-5">Calculate your exact age in years, months, and days.</p>

        <div class="mb-4 text-start">
            <label class="form-label fw-bold">Date of Birth</label>
            <input type="date" id="dobInput" class="form-control form-control-lg border-2">
        </div>
        
        <div class="mb-5 text-start">
            <label class="form-label fw-bold">Calculate Age At</label>
            <input type="date" id="targetDate" class="form-control form-control-lg border-2">
        </div>
        
        <button class="btn btn-danger btn-lg w-100 fw-bold premium-btn-primary shadow-sm" onclick="calculateAge()">Calculate Age</button>

        <div id="ageResultBox" class="mt-5 d-none">
            <h2 class="fw-bold mb-4">You are:</h2>
            <div class="row g-2 justify-content-center" id="ageDetails">
                <!-- Injected via JS -->
            </div>
        </div>

      </div>
    </div>
  </div>
</main>

<script>
// Set default target date to today
document.getElementById('targetDate').valueAsDate = new Date();

function calculateAge() {
    const dobValue = document.getElementById('dobInput').value;
    const targetValue = document.getElementById('targetDate').value;
    
    if(!dobValue || !targetValue) {
        alert("Please enter both dates.");
        return;
    }
    
    const dob = new Date(dobValue);
    const target = new Date(targetValue);
    
    if(dob > target) {
        alert("Date of Birth cannot be after the Target Date.");
        return;
    }

    let years = target.getFullYear() - dob.getFullYear();
    let months = target.getMonth() - dob.getMonth();
    let days = target.getDate() - dob.getDate();

    if (days < 0) {
        months--;
        // Get number of days in the previous month of target date
        let tempDate = new Date(target.getFullYear(), target.getMonth(), 0);
        days += tempDate.getDate();
    }

    if (months < 0) {
        years--;
        months += 12;
    }

    const box = document.getElementById('ageResultBox');
    const details = document.getElementById('ageDetails');
    
    details.innerHTML = `
        <div class="col-4">
            <div class="bg-light border border-danger border-opacity-25 rounded-4 p-3 text-center">
                <h1 class="fw-bold text-danger mb-0">${years}</h1>
                <small class="text-muted fw-bold">Years</small>
            </div>
        </div>
        <div class="col-4">
            <div class="bg-light border border-danger border-opacity-25 rounded-4 p-3 text-center">
                <h1 class="fw-bold text-danger mb-0">${months}</h1>
                <small class="text-muted fw-bold">Months</small>
            </div>
        </div>
        <div class="col-4">
            <div class="bg-light border border-danger border-opacity-25 rounded-4 p-3 text-center">
                <h1 class="fw-bold text-danger mb-0">${days}</h1>
                <small class="text-muted fw-bold">Days</small>
            </div>
        </div>
    `;
    
    box.classList.remove('d-none');
}
</script>

<%- include('../partials/footer') %>
