  function initMusic() {
    const musicCategory = document.getElementById('music-category');
    const musicSelect = document.getElementById('music-select');
    const musicPlayer = document.getElementById('focus-music-player');
    const musicIframe = document.getElementById('music-iframe');
    const categoryDescription = document.getElementById('music-category-description');
    if (!musicSelect || !musicPlayer || !musicCategory || !categoryDescription) return;

    const populateTracks = () => {
      const selectedCategory = musicCategory.value;
      const filtered = musicTracks.filter(track => track.category === selectedCategory);
      musicSelect.innerHTML = '';
      filtered.forEach(track => {
        const option = document.createElement('option');
        option.value = track.src;
        option.dataset.video = track.video || '';
        option.dataset.description = track.description || '';
        option.textContent = track.label;
        musicSelect.appendChild(option);
      });
      if (filtered.length) {
        const firstTrack = filtered[0];
        musicSelect.value = firstTrack.src;
        musicPlayer.src = firstTrack.src;
        musicIframe.src = firstTrack.video || musicIframe.src;
        categoryDescription.textContent = firstTrack.description || 'Pick a mood and play a track to match your study focus.';
      }
    };

    musicCategory.addEventListener('change', populateTracks);
    musicSelect.addEventListener('change', () => {
      const selectedOption = musicSelect.selectedOptions[0];
      if (!selectedOption) return;
      musicPlayer.src = selectedOption.value;
      musicIframe.src = selectedOption.dataset.video || musicIframe.src;
      categoryDescription.textContent = selectedOption.dataset.description || categoryDescription.textContent;
      musicPlayer.play().catch(() => { });
    });

    populateTracks();
  }

  function showDistractionConfirmation() {
    return new Promise(resolve => {
      if (!distractionOverlay || !distractionContinue || !distractionStay) {
        resolve(false);
        return;
      }

      distractionOverlay.classList.remove('d-none');

      const cleanup = () => {
        distractionOverlay.classList.add('d-none');
        distractionContinue.removeEventListener('click', onContinue);
        distractionStay.removeEventListener('click', onStay);
      };

      const onContinue = () => {
        cleanup();
        resolve(true);
      };

      const onStay = () => {
        cleanup();
        resolve(false);
      };

      distractionContinue.addEventListener('click', onContinue);
      distractionStay.addEventListener('click', onStay);
    });
  }

  function playRedirect(link, isBlank) {
    if (isBlank) {
      window.open(link, '_blank', 'noopener');
    } else {
      window.location.href = link;
    }
  }

  function isDistractingLink(url) {
    const distractingSites = ['youtube.com', 'youtu.be', 'instagram.com', 'facebook.com', 'tiktok.com', 'twitter.com', 'x.com', 'reddit.com', 'twitch.tv', 'netflix.com'];
    return distractingSites.some(site => url.hostname.toLowerCase().includes(site));
  }

  function bindInteractions() {
    const timerStart = document.getElementById('timer-start');
    const timerPause = document.getElementById('timer-pause');
    const timerReset = document.getElementById('timer-reset');
    const timerStudyMode = document.getElementById('timer-study-mode');
    const timerBreakMode = document.getElementById('timer-break-mode');
    const reminderSet = document.getElementById('reminder-set');
    const taskAdd = document.getElementById('task-add');
    const taskTitle = document.getElementById('task-title');
    const taskList = document.getElementById('task-list');
    const flashcardAdd = document.getElementById('flashcard-add');
    const flashcardFront = document.getElementById('flashcard-front');
    const flashcardBack = document.getElementById('flashcard-back');
    const cardsContainer = document.getElementById('flashcards-container');

    timerStart?.addEventListener('click', () => {
      startPomodoro();
      recordActivity();
    });
    timerPause?.addEventListener('click', pausePomodoro);
    timerReset?.addEventListener('click', resetPomodoro);
    timerStudyMode?.addEventListener('click', () => setPomodoroMode('study'));
    timerBreakMode?.addEventListener('click', () => setPomodoroMode('break'));
    timerFullscreenButton?.addEventListener('click', toggleTimerFullscreen);

    const syncStudyDuration = () => {
      if (!studyDurationInput || !studyDurationRange) return;
      const value = Math.max(1, Math.min(120, Number(studyDurationInput.value) || 25));
      studyDurationInput.value = value;
      studyDurationRange.value = value;
      updateTimerSettings();
    };

    const syncBreakDuration = () => {
      if (!breakDurationInput || !breakDurationRange) return;
      const value = Math.max(1, Math.min(60, Number(breakDurationInput.value) || 5));
      breakDurationInput.value = value;
      breakDurationRange.value = value;
      updateTimerSettings();
    };

    studyDurationInput?.addEventListener('input', syncStudyDuration);
    studyDurationRange?.addEventListener('input', () => {
      if (studyDurationInput) studyDurationInput.value = studyDurationRange.value;
      updateTimerSettings();
    });
    breakDurationInput?.addEventListener('input', syncBreakDuration);
    breakDurationRange?.addEventListener('input', () => {
      if (breakDurationInput) breakDurationInput.value = breakDurationRange.value;
      updateTimerSettings();
    });

    focusModeToggle?.addEventListener('click', () => setFocusModeSetting(!focusModeSetting));

    reminderSet?.addEventListener('click', async () => {
      const timeInput = document.getElementById('reminder-time');
      if (!timeInput || !timeInput.value) {
        showWindow({ title: 'Pick a Time', message: 'Please choose a time for your study reminder.', type: 'warning' });
        return;
      }
      const [hours, minutes] = timeInput.value.split(':').map(Number);
      const target = new Date();
      target.setHours(hours, minutes, 0, 0);
      if (target <= new Date()) {
        target.setDate(target.getDate() + 1);
      }
      const delay = target.getTime() - Date.now();
      showWindow({
        title: '⏰ Reminder Set',
        message: `Your study reminder is set for ${target.toLocaleTimeString()}. We'll notify you!`,
        type: 'success'
      });
      setTimeout(() => {
        showWindow({ title: '⏰ Study Time!', message: 'It\'s time to start your scheduled study session. Let\'s go!', type: 'alert' });
      }, delay);
    });

    taskAdd?.addEventListener('click', () => {
      if (!taskTitle || !taskTitle.value.trim()) return;
      tasks.push({ title: taskTitle.value.trim(), completed: false });
      taskTitle.value = '';
      saveTasks();
      renderTasks();
      recordActivity();
    });

    taskList?.addEventListener('click', event => {
      const target = event.target;
      const index = target.dataset.index;
      if (typeof index === 'undefined') return;
      const idx = Number(index);
      if (target.classList.contains('task-delete')) {
        tasks.splice(idx, 1);
        saveTasks();
        renderTasks();
      }
      if (target.classList.contains('task-toggle')) {
        tasks[idx].completed = !tasks[idx].completed;
        saveTasks();
        renderTasks();
        recordActivity();
      }
    });

    flashcardAdd?.addEventListener('click', () => {
      if (!flashcardFront || !flashcardBack || !flashcardFront.value.trim() || !flashcardBack.value.trim()) return;
      flashcards.push({ front: flashcardFront.value.trim(), back: flashcardBack.value.trim() });
      flashcardFront.value = '';
      flashcardBack.value = '';
      saveFlashcards();
      renderFlashcards();
      recordActivity();
    });

    document.querySelectorAll('.game-mode-btn').forEach(button => {
      button.addEventListener('click', () => {
        const mode = button.id.replace('game-mode-', '');
        currentGameMode = mode;
        switchGameMode(mode);
      });
    });

    document.getElementById('quiz-options')?.addEventListener('click', event => {
      const button = event.target.closest('button[data-option-index]');
      if (!button) return;
      handleQuizAnswer(Number(button.dataset.optionIndex));
    });

    document.getElementById('quiz-restart-btn')?.addEventListener('click', initQuizGame);
    const reactionBtn = document.getElementById('reaction-start-btn');
    reactionBtn?.addEventListener('click', () => {
      if (reactionStart === null && reactionTimeout) {
        const status = document.getElementById('reaction-status');
        if (status) status.textContent = 'Too early! Wait for the green signal.';
        return;
      }
      if (!reactionStart) {
        initReactionGame();
        return;
      }
      const reactionResult = document.getElementById('reaction-result');
      const reactionStatus = document.getElementById('reaction-status');
      const elapsed = Date.now() - reactionStart;
      if (reactionResult) reactionResult.textContent = `Reaction time: ${elapsed} ms`;
      if (reactionStatus) reactionStatus.textContent = 'Great reflex! Try again to improve.';
      reactionStart = null;
      if (reactionTimeout) {
        clearTimeout(reactionTimeout);
        reactionTimeout = null;
      }
      reactionBtn.textContent = 'Start Reaction Test';
    });
    document.getElementById('focus-start-btn')?.addEventListener('click', initFocusChallenge);
    document.getElementById('focus-duration')?.addEventListener('change', resetFocusChallenge);

    cardsContainer?.addEventListener('click', event => {
      const target = event.target;
      const index = target.dataset.index;
      if (typeof index === 'undefined') return;
      const idx = Number(index);
      if (target.classList.contains('flashcard-delete')) {
        flashcards.splice(idx, 1);
        saveFlashcards();
        renderFlashcards();
      }
      if (target.classList.contains('flashcard-flip')) {
        const cardNode = target.closest('.flashcard-item');
        const backText = cardNode.querySelector('.flashcard-back');
        if (backText) backText.classList.toggle('flashcard-hidden');
        recordActivity();
      }
    });

    streakActivityButton?.addEventListener('click', () => {
      recordActivity();
      showWindow({ title: 'Activity Recorded', message: 'Study activity recorded. Keep your streak going!', type: 'success' });
    });

    const logMinutesButton = document.getElementById('log-minutes-btn');
    logMinutesButton?.addEventListener('click', async () => {
      const input = await showWindow({
        title: 'Log Minutes',
        message: 'Enter minutes of study to log for today:',
        type: 'prompt',
        defaultValue: '30',
        placeholder: 'e.g. 30, 60'
      });
      const minutes = Number(input);
      if (!minutes || minutes <= 0) return;
      addStudyMinutes(minutes);
      updateStreakPage();
      showWindow({ title: 'Minutes Logged', message: `Logged ${minutes} minutes for today. Keep the streak alive!`, type: 'success' });
    });

    featureCards.forEach(card => card.addEventListener('click', recordActivity));

    document.addEventListener('click', async event => {
      const link = event.target.closest('a[href]');
      if (!link) return;
      const href = link.getAttribute('href');
      if (link.dataset.loginProtected && !isLoggedIn()) {
        event.preventDefault();
        await showWindow({
          title: 'Registration Required',
          message: `${loginProtectedMessage} Please complete Register Now first.`,
          type: 'warning'
        });
        triggerRegisterFlow();
        return;
      }

      if (!href || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) {
        return;
      }

      try {
        const targetUrl = new URL(link.href, window.location.href);
        if (targetUrl.origin !== window.location.origin && isDistractingLink(targetUrl) && focusModeActive) {
          event.preventDefault();
          const proceed = await showDistractionConfirmation();
          if (proceed) {
            playRedirect(link.href, link.target === '_blank');
          }
          return;
        }
        if (targetUrl.origin !== window.location.origin && !focusModeActive && isDistractingLink(targetUrl)) {
          // allow navigation to distracting sites when focus mode is disabled
          return;
        }
      } catch (err) {
        // ignore invalid URLs
      }
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    updateTimerSettings();
    updateTimerDisplay();
    initDigitalClock();
    showQuote();
    loadTasks();
    loadFlashcards();
    refreshStreak();
    setupAuthPanels();
    setupGamePage();
    initMusic();
    updateFocusModeUI();
    bindInteractions();

    const heroRegisterForm = document.getElementById('hero-register-form');
    heroRegisterForm?.addEventListener('submit', () => {
      if (heroRegisterForm.checkValidity()) {
        markUserRegistered();
      }
    });

    const params = new URLSearchParams(window.location.search);
    if (params.get('openRegister') === '1' && !isLoggedIn()) {
      triggerRegisterFlow();
      params.delete('openRegister');
      const cleanQuery = params.toString();
      const cleanUrl = `${window.location.pathname}${cleanQuery ? '?' + cleanQuery : ''}${window.location.hash || ''}`;
      window.history.replaceState({}, '', cleanUrl);
    }
  });
</script>
