<!-- Firebase Integration for Global Forms -->
<script type="module">
  // Import the functions you need from the SDKs you need
  import { initializeApp } from "https://www.gstatic.com/firebasejs/12.12.0/firebase-app.js";
  import { getFirestore, collection, addDoc, serverTimestamp } from "https://www.gstatic.com/firebasejs/12.12.0/firebase-firestore.js";

  // Your web app's Firebase configuration
  const firebaseConfig = {
    apiKey: "AIzaSyCvJRS3UusvUrVCd2JSicBGL-uRD82GpNM",
    authDomain: "am-study-7ea87.firebaseapp.com",
    projectId: "am-study-7ea87",
    storageBucket: "am-study-7ea87.firebasestorage.app",
    messagingSenderId: "270924691236",
    appId: "1:270924691236:web:7ada12dcf50c290d0925b1"
  };

  let app, db;
  try {
    // Initialize Firebase
    app = initializeApp(firebaseConfig);
    db = getFirestore(app);
  } catch (error) {
    console.error("Error initializing Firebase:", error);
  }

  document.addEventListener("DOMContentLoaded", () => {
    // Intercept all forms on the site to route them through Firebase
    const forms = document.querySelectorAll("form");

    forms.forEach(form => {
      form.addEventListener("submit", async (e) => {
        // Prevent normal backend POST or page reload
        e.preventDefault();

        const submitBtn = form.querySelector('button[type="submit"]') || form.querySelector('.bannerFormBtn');
        const originalBtnText = submitBtn ? submitBtn.innerHTML : 'Submit';

        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Processing...';
        }

        // Remove old Firebase alert if it exists
        const oldAlert = form.querySelector('.firebase-alert');
        if (oldAlert) oldAlert.remove();

        // Prepare document data
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        data.submittedAt = new Date().toISOString();
        data.formName = form.getAttribute('data-form-name') || form.id || 'unidentified_form';

        try {
          if (!db) {
            throw new Error("Firebase is not configured yet. The site owner is currently upgrading this feature!");
          }

          // Use the formName to decide the collection, or default to site_submissions
          let collectionName = "site_submissions";
          if (data.formName.toLowerCase().includes('purchase') || data.formName.toLowerCase().includes('order')) {
            collectionName = "store_orders";
          } else if (data.formName.toLowerCase().includes('contact') || data.formName.toLowerCase().includes('enquiry')) {
            collectionName = "contact_messages";
          }

          // Add to firestore
          data.timestamp = serverTimestamp();
          await addDoc(collection(db, collectionName), data);

          // Success message injection
          const alertDiv = document.createElement('div');
          alertDiv.className = 'alert alert-success mt-3 mb-0 firebase-alert d-flex align-items-center shadow-sm';
          alertDiv.style.borderRadius = '1rem';
          alertDiv.style.fontSize = '0.9rem';
          alertDiv.innerHTML = '<i class="fa-solid fa-circle-check fs-5 me-2 text-success"></i> <div><strong>Success!</strong> Your request has been securely submitted.</div>';
          form.appendChild(alertDiv);

          form.reset();

          // Auto remove success message after 6 seconds
          setTimeout(() => {
            if (alertDiv) alertDiv.remove();
          }, 6000);

        } catch (error) {
          console.error("Firebase write error: ", error);
          // Error message injection
          const alertDiv = document.createElement('div');
          alertDiv.className = 'alert alert-danger mt-3 mb-0 firebase-alert d-flex align-items-center shadow-sm';
          alertDiv.style.borderRadius = '1rem';
          alertDiv.style.fontSize = '0.9rem';
          alertDiv.innerHTML = '<i class="fa-solid fa-triangle-exclamation fs-5 me-2 text-danger"></i> <div><strong>Oops!</strong> ' + error.message + '</div>';
          form.appendChild(alertDiv);
        } finally {
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalBtnText;
          }
        }
      });
    });
  });
</script>

