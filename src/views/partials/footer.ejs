  <!-- Store Cart Logic -->
  <script>
    async function updateFloatingCart() {
      const container = document.getElementById('storeCartContainer');
      const badge = document.getElementById('floatingCartCount');
      if (!container || !badge) return;
      
      // Only show on store pages
      const isStorePage = window.location.pathname.includes('/store');
      
      try {
        const res = await fetch(`<%= process.env.NEXT_PUBLIC_API_URL %>/api/store/cart`, { credentials: 'include' });
        const data = await res.json();
        if (data.success && data.itemCount > 0) {
          badge.textContent = data.itemCount;
          badge.style.display = 'flex';
          container.style.display = 'block'; // Always show if items exist
        } else {
          badge.style.display = 'none';
          // Hide only if not on a store page AND cart is empty
          if (!isStorePage) container.style.display = 'none';
          else container.style.display = 'block'; 
        }
      } catch (err) {
        console.error('Failed to sync cart', err);
      }
    }

    document.addEventListener('DOMContentLoaded', updateFloatingCart);
    window.addEventListener('cartUpdated', updateFloatingCart);
    
    // Also periodically check for cart updates if not triggered by event
    setInterval(updateFloatingCart, 10000); 
  </script>
</body>

