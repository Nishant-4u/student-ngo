        options: ['Continuous work with no rest', 'Balanced study and breaks', 'No planning at all', 'Studying only when bored'],
        answer: 1
      }
    ];
    let currentGameMode = 'memory';
    let currentQuizIndex = 0;
    let quizScore = 0;
    let reactionTimeout = null;
    let reactionStart = null;
    let focusTimer = null;
    let focusRemaining = 0;
    let focusActive = false;

    let pomodoroMode = 'study';
    let studyDurationSeconds = 25 * 60;
    let breakDurationSeconds = 5 * 60;
    let pomodoroSeconds = studyDurationSeconds;
    let pomodoroInterval = null;
    let focusModeSetting = localStorage.getItem('focusModeSetting') === 'true';
    let focusModeActive = false;
    let pendingRedirect = null;
    let tasks = JSON.parse(localStorage.getItem(tasksKey) || '[]');
    let flashcards = JSON.parse(localStorage.getItem(flashcardsKey) || '[]');
    let studySessionStart = null;
    let lastPendingMinuteCount = 0;

    const timerMinutes = document.getElementById('timer-minutes');
    const timerSeconds = document.getElementById('timer-seconds');
    const timerModeLabel = document.getElementById('timer-mode-label');
    const timerCurrentMode = document.getElementById('timer-current-mode');
    const timerProgressRing = document.getElementById('timer-progress-ring');
    const timerSessionMessage = document.getElementById('timer-session-message');
    const timerFullscreenButton = document.getElementById('timer-fullscreen');
    const timerCard = document.querySelector('.timer-card');
    const timerStart = document.getElementById('timer-start');
    const timerPause = document.getElementById('timer-pause');
    const timerReset = document.getElementById('timer-reset');
    const studyDurationInput = document.getElementById('study-duration-input');
    const breakDurationInput = document.getElementById('break-duration-input');
    const studyDurationRange = document.getElementById('study-duration-range');
    const breakDurationRange = document.getElementById('break-duration-range');
    let isTimerFullscreen = false;

    function formatTwoDigits(value) {
      return String(value).padStart(2, '0');
    }

    function updateTimerDisplay() {
      const minutes = Math.floor(pomodoroSeconds / 60);
      const seconds = pomodoroSeconds % 60;
      if (timerMinutes) timerMinutes.textContent = formatTwoDigits(minutes);
      if (timerSeconds) timerSeconds.textContent = formatTwoDigits(seconds);
      updateProgressRing();
    }

    function updateProgressRing() {
      if (!timerProgressRing) return;
      const total = pomodoroMode === 'break' ? breakDurationSeconds : studyDurationSeconds;
      const elapsed = Math.max(0, total - pomodoroSeconds);
      const progressAngle = total > 0 ? Math.min(360, (elapsed / total) * 360) : 0;
      timerProgressRing.style.background = `conic-gradient(#4f46e5 ${progressAngle}deg, #e9ecef ${progressAngle}deg)`;
    }

    function updateTimerSessionMessage() {
      if (!timerSessionMessage) return;
      if (pomodoroInterval) {
        timerSessionMessage.textContent = `Focus session in progress — ${timerModeLabel.textContent}`;
      } else if (pomodoroMode === 'break') {
        timerSessionMessage.textContent = 'Paused: break time ready when you are.';
      } else {
        timerSessionMessage.textContent = 'Ready to start your study session.';
      }
    }

    function updateTimerControls() {
      const isRunning = !!pomodoroInterval;
      if (timerStart) timerStart.disabled = isRunning;
      if (timerPause) timerPause.disabled = !isRunning;
      if (timerReset) timerReset.disabled = false;
      if (timerFullscreenButton) timerFullscreenButton.disabled = false;
      updateTimerSessionMessage();
    }

    function toggleTimerFullscreen() {
      if (!timerCard || !timerFullscreenButton) return;
      if (!document.fullscreenElement) {
        timerCard.requestFullscreen?.().catch(() => {});
      } else {
        document.exitFullscreen?.().catch(() => {});
      }
    }

    document.addEventListener('fullscreenchange', () => {
      isTimerFullscreen = !!document.fullscreenElement;
      if (timerFullscreenButton) {
        timerFullscreenButton.textContent = isTimerFullscreen ? 'Exit Full Screen' : 'Full Screen';
      }
      if (timerCard) timerCard.classList.toggle('fullscreen-card', isTimerFullscreen);
      document.body.classList.toggle('fullscreen-active', isTimerFullscreen);
    });

    function updateTimerSettings() {
      const studyMinutes = Number(studyDurationInput?.value) || 25;
      const breakMinutes = Number(breakDurationInput?.value) || 5;
      studyDurationSeconds = Math.max(60, Math.min(7200, studyMinutes * 60));
      breakDurationSeconds = Math.max(60, Math.min(3600, breakMinutes * 60));
      if (studyDurationInput) studyDurationInput.value = Math.round(studyDurationSeconds / 60);
      if (breakDurationInput) breakDurationInput.value = Math.round(breakDurationSeconds / 60);
      if (studyDurationRange) studyDurationRange.value = Math.round(studyDurationSeconds / 60);
      if (breakDurationRange) breakDurationRange.value = Math.round(breakDurationSeconds / 60);
      if (!pomodoroInterval) {
        pomodoroSeconds = pomodoroMode === 'break' ? breakDurationSeconds : studyDurationSeconds;
        updateTimerDisplay();
      }
    }

    function updateDigitalClock() {
      const clockElement = document.getElementById('digital-clock');
      const dateElement = document.getElementById('clock-date');
      if (!clockElement) return;
      const now = new Date();
      const hours = formatTwoDigits(now.getHours());
      const minutes = formatTwoDigits(now.getMinutes());
      const seconds = formatTwoDigits(now.getSeconds());
      clockElement.textContent = `${hours}:${minutes}:${seconds}`;
      if (dateElement) {
        dateElement.textContent = now.toLocaleDateString(undefined, {
          weekday: 'long',
          year: 'numeric',
          month: 'long',
          day: 'numeric'
        });
      }
    }

    function initDigitalClock() {
      const clockElement = document.getElementById('digital-clock');
      if (!clockElement) return;
      updateDigitalClock();
      setInterval(updateDigitalClock, 1000);
    }

    function updateFocusModeUI() {
      if (focusModeToggle) {
        focusModeToggle.textContent = focusModeSetting ? 'Focus Mode ON' : 'Focus Mode OFF';
        focusModeToggle.className = focusModeSetting ? 'btn btn-sm btn-success' : 'btn btn-sm btn-outline-info';
      }
      if (focusModeStatus) {
        focusModeStatus.textContent = focusModeActive ? 'Focus Mode active' : focusModeSetting ? 'Focus Mode ready' : 'Focus Mode OFF';
        focusModeStatus.className = focusModeActive ? 'badge bg-success' : focusModeSetting ? 'badge bg-warning' : 'badge bg-secondary';
      }
    }

    function setFocusModeSetting(enabled) {
      focusModeSetting = enabled;
      localStorage.setItem('focusModeSetting', String(enabled));
      updateBlockerState();
    }

    function updateBlockerState() {
      focusModeActive = focusModeSetting && !!pomodoroInterval;
      updateFocusModeUI();
    }

    function setPomodoroMode(mode) {
      pomodoroMode = mode;
      pomodoroSeconds = mode === 'break' ? breakDurationSeconds : studyDurationSeconds;
      timerModeLabel.textContent = mode === 'break' ? 'Break' : 'Study';
      timerModeLabel.className = mode === 'break' ? 'badge bg-warning' : 'badge bg-primary';
      if (timerCurrentMode) {
        timerCurrentMode.textContent = mode === 'break' ? 'Break period' : 'Study period';
      }
      updateTimerDisplay();
      updateTimerControls();
      updateBlockerState();
    }

    function startPomodoro() {
      if (pomodoroInterval) return;
      if (pomodoroMode === 'study') {
        studySessionStart = Date.now();
      } else {
        studySessionStart = null;
      }
      pomodoroInterval = setInterval(() => {
        if (pomodoroSeconds > 0) {
          pomodoroSeconds -= 1;
          updateTimerDisplay();
          const pendingMinutes = getPendingStudyMinutes();
          if (pendingMinutes !== lastPendingMinuteCount) {
            lastPendingMinuteCount = pendingMinutes;
            updateStreakPage();
          }
        } else {
          saveStudySessionTime(true);
          clearInterval(pomodoroInterval);
          pomodoroInterval = null;
          lastPendingMinuteCount = 0;
          updateBlockerState();
          updateTimerControls();
          // Play sound alert if enabled
          if (typeof window.timerAlertSound === 'function') {
            try { window.timerAlertSound(); } catch(e) {}
          }
          alert('Session complete! Time to switch your focus. Your study game is now unlocked.');
        }
      }, 1000);
      updateBlockerState();
      updateTimerControls();
    }

    function pausePomodoro() {
      if (pomodoroInterval) {
        saveStudySessionTime();
        clearInterval(pomodoroInterval);
        pomodoroInterval = null;
      }
      updateBlockerState();
      updateTimerControls();
    }

    function resetPomodoro() {
      pausePomodoro();
      pomodoroSeconds = pomodoroMode === 'break' ? breakDurationSeconds : studyDurationSeconds;
      updateTimerDisplay();
      updateBlockerState();
    }

    function showQuote() {
      const quote = quotes[Math.floor(Math.random() * quotes.length)];
      const quoteText = document.getElementById('quote-text');
      const quoteAuthor = document.getElementById('quote-author');
      if (quoteText) quoteText.textContent = quote.text;
      if (quoteAuthor) quoteAuthor.textContent = quote.author;
    }

    function loadTasks() {
      tasks = JSON.parse(localStorage.getItem(tasksKey) || '[]');
      renderTasks();
    }

    function saveTasks() {
      localStorage.setItem(tasksKey, JSON.stringify(tasks));
    }

    function renderTasks() {
      const taskList = document.getElementById('task-list');
      if (!taskList) return;

      const countBadge = document.getElementById('task-count');
      if (countBadge) countBadge.textContent = tasks.filter(t => !t.completed).length;

      if (tasks.length === 0) {
        taskList.innerHTML = '<li class="list-group-item text-center py-4 text-muted fst-italic border-0">No active tasks. Time to relax!</li>';
        return;
      }

      taskList.innerHTML = tasks.map((task, index) => `
        <li class="list-group-item d-flex justify-content-between align-items-center py-3 border-0 rounded-3 mb-2 task-item ${task.completed ? 'completed bg-light' : ''}">
          <div class="d-flex align-items-center gap-3">
            <span class="task-text fw-semibold ${task.completed ? 'text-decoration-line-through text-muted' : 'text-dark'}">${task.title}</span>
          </div>
          <div class="d-flex gap-2">
            <button data-index="${index}" class="btn btn-sm btn-outline-success border-0 task-toggle" title="${task.completed ? 'Undo' : 'Complete'}">
              <i class="fa-solid ${task.completed ? 'fa-rotate-left' : 'fa-check'}"></i>
            </button>
            <button data-index="${index}" class="btn btn-sm btn-outline-danger border-0 task-delete" title="Delete">
              <i class="fa-solid fa-trash-can"></i>
            </button>
          </div>
        </li>
      `).join('');
    }

    function loadFlashcards() {
      flashcards = JSON.parse(localStorage.getItem(flashcardsKey) || '[]');
      renderFlashcards();
    }

    function saveFlashcards() {
      localStorage.setItem(flashcardsKey, JSON.stringify(flashcards));
    }

    function renderFlashcards() {
      const cardsContainer = document.getElementById('flashcards-container');
      if (!cardsContainer) return;
      cardsContainer.innerHTML = flashcards.map((card, index) => `
        <div class="flashcard-item" data-index="${index}">
          <div class="flashcard-side flex-grow-1">
            <div class="fw-semibold">${card.front}</div>
            <div class="text-muted mt-2 flashcard-back flashcard-hidden">${card.back}</div>
          </div>
          <div class="flashcard-actions">
            <button data-index="${index}" class="btn btn-sm btn-outline-primary flashcard-flip">Flip</button>
            <button data-index="${index}" class="btn btn-sm btn-outline-danger flashcard-delete">Delete</button>
          </div>
        </div>
      `).join('');
    }

    function getISODate(date = new Date()) {
      const localDate = new Date(date.getTime() - date.getTimezoneOffset() * 60000);
      return localDate.toISOString().slice(0, 10);
    }

    function getStudyTimeLog() {
      return JSON.parse(localStorage.getItem(studyTimeLogKey) || '{}');
    }

    function saveStudyTimeLog(log) {
      localStorage.setItem(studyTimeLogKey, JSON.stringify(log));
    }

    function getStudyMinutes(date = new Date()) {
      const log = getStudyTimeLog();
      return Number(log[getISODate(date)] || 0);
    }

    function addStudyMinutes(minutes) {
      if (!minutes || minutes < 1) return 0;
      const dateKey = getISODate();
      const log = getStudyTimeLog();
      log[dateKey] = (Number(log[dateKey] || 0) + Math.round(minutes));
      saveStudyTimeLog(log);
      return log[dateKey];
    }

    function getWeeklyStudyMinutes() {
      let total = 0;
      for (let i = 0; i < 7; i += 1) {
        const date = new Date();
        date.setDate(date.getDate() - i);
        total += getStudyMinutes(date);
      }
      return total;
    }

    function getPendingStudyMinutes() {
      if (!studySessionStart || pomodoroMode !== 'study') return 0;
      return Math.max(0, Math.floor((Date.now() - studySessionStart) / 60000));
    }

    function getLevelText(streak) {
      if (streak >= 10) return 'Focus Master';
      if (streak >= 4) return 'Consistent';
      if (streak >= 1) return 'Beginner';
      return 'New Challenger';
    }

    function getMotivationText(streak) {
      if (streak >= 7) return 'You’re ahead of most people 💯';
      if (streak >= 3) return 'You’re building a habit 🔥';
      if (streak === 2) return 'Keep the momentum going!';
      if (streak === 1) return 'Great start!';
      return 'Every day is a new chance to grow.';
    }

    function getSampleLeaderboard() {
      return [
        { name: 'Priya', streak: 8, minutes: 320 },
        { name: 'Arjun', streak: 6, minutes: 280 },
        { name: 'Sneha', streak: 5, minutes: 240 },
        { name: 'Rohan', streak: 4, minutes: 190 },
        { name: 'Ayesha', streak: 2, minutes: 130 }
      ];
    }

    function getLeaderboardData() {
      const stored = JSON.parse(localStorage.getItem(leaderboardDataKey) || 'null');
      return Array.isArray(stored) && stored.length ? stored : getSampleLeaderboard();
    }

    function saveLeaderboardData(entries) {
      localStorage.setItem(leaderboardDataKey, JSON.stringify(entries));
    }

    function buildLeaderboard(userStats) {
      const entries = getLeaderboardData().filter(entry => entry.name !== 'You');
      const combined = [...entries, { name: 'You', streak: userStats.streak, minutes: userStats.minutes, isYou: true }];
      combined.sort((a, b) => {
        if (b.streak !== a.streak) return b.streak - a.streak;
        return b.minutes - a.minutes;
      });
      return combined.map((entry, index) => ({
        rank: index + 1,
        name: entry.name,
        streak: entry.streak,
        minutes: entry.minutes,
        isYou: !!entry.isYou
      }));
    }

    function renderLeaderboard(userStats) {
      const leaderboardList = document.getElementById('leaderboard-list');
      const leaderRank = document.getElementById('leader-rank');
      if (!leaderboardList || !leaderRank) return;

      const entries = buildLeaderboard(userStats);
      leaderboardList.innerHTML = entries.slice(0, 5).map(entry => `
        <li class="leaderboard-list-item ${entry.isYou ? 'leaderboard-you' : ''}">
          <div class="d-flex align-items-center justify-content-between gap-3">
            <div class="d-flex align-items-center gap-3">
              <div class="leaderboard-rank">#${entry.rank}</div>
              <div>
                <div class="fw-semibold">${entry.name}${entry.isYou ? ' (You)' : ''}</div>
                <div class="text-muted">${entry.streak} day streak • ${entry.minutes} min today</div>
              </div>
            </div>
            <span class="badge ${entry.isYou ? 'bg-success' : 'bg-warning text-dark'}">${entry.isYou ? 'Your pace' : 'Top'}</span>
          </div>
        </li>
      `).join('');

      const userRank = entries.find(entry => entry.isYou)?.rank || entries.length;
      leaderRank.textContent = `#${userRank}`;
    }

    function getStreakWarningText(lastDate) {
      const today = getISODate();
      const yesterday = getISODate(new Date(Date.now() - 86400000));
      if (!lastDate) return 'Start today to build your streak.';
      if (lastDate === today) return 'You’re on track today!';
      if (lastDate === yesterday) return 'Don’t break your streak! Come back today 😢';
      return 'A fresh streak begins now. Let’s get back on track.';
    }

    function updateStreakPage() {
      const streakPage = document.getElementById('streak-page');
      if (!streakPage) return;

      const storedCount = Number(localStorage.getItem(streakKey) || 0);
      const lastDate = localStorage.getItem(streakDateKey);
      const todayMinutes = getStudyMinutes();
      const weeklyMinutes = getWeeklyStudyMinutes();
      const pendingMinutes = getPendingStudyMinutes();
      const displayTodayMinutes = todayMinutes + pendingMinutes;
      const displayWeeklyMinutes = weeklyMinutes + pendingMinutes;
      const levelText = getLevelText(storedCount);
      const motivation = getMotivationText(storedCount);
      const warningText = getStreakWarningText(lastDate);
      const goalCompletion = Math.min(100, Math.round((displayTodayMinutes / dailyGoalMinutes) * 100));

      const streakCountElement = document.getElementById('streak-count');
      const streakMessageElement = document.getElementById('streak-message');
      const streakLevel = document.getElementById('streak-level');
      const todayStudyTime = document.getElementById('today-study-time');
      const weeklyStudyTime = document.getElementById('weekly-study-time');
      const goalCompleted = document.getElementById('goal-completed');
      const goalProgressFill = document.getElementById('goal-progress-fill');
      const weeklyProgressFill = document.getElementById('weekly-progress-fill');
      const leaderStreak = document.getElementById('leader-streak');
      const leaderTodayMinutes = document.getElementById('leader-today-minutes');
      const weeklyStudyLog = document.getElementById('weekly-study-log');
      const motivationText = document.getElementById('motivation-text');
      const streakWarning = document.getElementById('streak-warning');

      if (streakCountElement) streakCountElement.textContent = storedCount;
      if (streakMessageElement) streakMessageElement.textContent = storedCount > 0 ? `${storedCount} Day Streak — ${motivation}` : 'Your streak starts today!';
      if (streakLevel) streakLevel.textContent = levelText;
      if (todayStudyTime) todayStudyTime.textContent = `${displayTodayMinutes} min${pendingMinutes ? ` (+${pendingMinutes} live)` : ''}`;
      if (weeklyStudyTime) weeklyStudyTime.textContent = `${displayWeeklyMinutes} min`;
      if (goalCompleted) goalCompleted.textContent = `${(displayTodayMinutes / 60).toFixed(1)} hrs`;
      if (goalProgressFill) {
        goalProgressFill.style.width = `${goalCompletion}%`;
        goalProgressFill.textContent = `${goalCompletion}%`;
      }
      if (weeklyProgressFill) {
        weeklyProgressFill.style.width = `${Math.min(100, Math.round((displayWeeklyMinutes / (dailyGoalMinutes * 7)) * 100))}%`;
      }
      if (leaderStreak) leaderStreak.textContent = storedCount;
      if (leaderTodayMinutes) leaderTodayMinutes.textContent = `${displayTodayMinutes} min`;
      if (motivationText) motivationText.textContent = motivation;
      if (streakWarning) streakWarning.textContent = warningText;
      renderWeeklyStudyLog(pendingMinutes);
      renderLeaderboard({ streak: storedCount, minutes: displayTodayMinutes });
    }

    function renderWeeklyStudyLog(pendingMinutes = 0) {
      const weeklyStudyLog = document.getElementById('weekly-study-log');
      if (!weeklyStudyLog) return;
      const entries = [];
      const today = new Date();
      for (let i = 6; i >= 0; i -= 1) {
        const date = new Date(today);
        date.setDate(today.getDate() - i);
        const label = i === 0 ? 'Today' : date.toLocaleDateString(undefined, { weekday: 'short' });
        const minutes = getStudyMinutes(date) + (i === 0 ? pendingMinutes : 0);
        entries.push(`
          <li class="weekly-log-item d-flex align-items-center justify-content-between mb-3">
            <div>
              <div class="fw-semibold">${label}</div>
              <div class="text-muted small">${date.toLocaleDateString(undefined, { month: 'short', day: 'numeric' })}</div>
            </div>
            <span class="badge ${minutes >= 60 ? 'bg-warning text-dark' : 'bg-secondary text-white'}">${minutes} min</span>
          </li>
        `);
      }
      weeklyStudyLog.innerHTML = entries.join('');
    }

    function saveStudySessionTime(completed = false) {
      if (!studySessionStart || pomodoroMode !== 'study') {
        studySessionStart = null;
        return;
      }
      const elapsedSeconds = Math.floor((Date.now() - studySessionStart) / 1000);
      const minutes = Math.max(1, Math.round(elapsedSeconds / 60));
      addStudyMinutes(minutes);
      studySessionStart = null;
      updateStreakPage();
      if (completed) {
        localStorage.setItem(gameUnlockKey, 'true');
        if (document.getElementById('game-lock-message')) {
          setupGamePage();
        }
      }
    }

    function isGameUnlocked() {
      return localStorage.getItem(gameUnlockKey) === 'true';
    }

    function switchGameMode(mode) {
      resetReactionGame();
      resetFocusChallenge();
      currentGameMode = mode;
      document.querySelectorAll('.game-mode-btn').forEach(button => {
        button.classList.toggle('active', button.id === `game-mode-${mode}`);
      });
      document.querySelectorAll('.game-content').forEach(section => {
        section.classList.toggle('d-none', section.id !== `game-${mode}`);
      });
      if (mode === 'memory') initGameBoard();
      if (mode === 'quiz') initQuizGame();
      if (mode === 'reaction') resetReactionGame();
      if (mode === 'focus') resetFocusChallenge();
    }

    function renderQuizQuestion() {
      const questionEl = document.getElementById('quiz-question');
      const optionsEl = document.getElementById('quiz-options');
      const scoreEl = document.getElementById('quiz-score');
      if (!questionEl || !optionsEl || !scoreEl) return;

      const current = quizQuestions[currentQuizIndex];
      questionEl.textContent = current.question;
      optionsEl.innerHTML = current.options.map((option, index) => `
        <button type="button" class="btn btn-outline-secondary quiz-option-btn" data-option-index="${index}">${option}</button>
      `).join('');
      scoreEl.textContent = `Score: ${quizScore} / ${quizQuestions.length}`;
    }

    function initQuizGame() {
      currentQuizIndex = 0;
      quizScore = 0;
      renderQuizQuestion();
      const quizStatus = document.getElementById('game-status');
      if (quizStatus) quizStatus.textContent = 'Answer each question to earn a fun completion score.';
    }

    function handleQuizAnswer(selectedIndex) {
      const quizStatus = document.getElementById('game-status');
      if (currentQuizIndex >= quizQuestions.length) {
        if (quizStatus) quizStatus.textContent = `Quiz complete! Your final score is ${quizScore} / ${quizQuestions.length}.`;
        return;
      }
      const question = quizQuestions[currentQuizIndex];
      if (selectedIndex === question.answer) {
        quizScore += 1;
        if (quizStatus) quizStatus.textContent = 'Nice! That one was correct.';
      } else if (quizStatus) {
        quizStatus.textContent = 'Good try — keep going and learn from each question.';
      }
      currentQuizIndex += 1;
      if (currentQuizIndex >= quizQuestions.length) {
        if (quizStatus) quizStatus.textContent = `Quiz complete! Your final score is ${quizScore} / ${quizQuestions.length}.`;
      } else {
        renderQuizQuestion();
      }
    }

    function initReactionGame() {
      const reactionStatus = document.getElementById('reaction-status');
      const reactionResult = document.getElementById('reaction-result');
      const reactionButton = document.getElementById('reaction-start-btn');
      if (!reactionStatus || !reactionResult || !reactionButton) return;
      reactionResult.textContent = '';
      reactionStatus.textContent = 'Get ready... the button will turn green soon.';
      reactionButton.textContent = 'Wait for green';
      if (reactionTimeout) clearTimeout(reactionTimeout);
      reactionStart = null;
      const wait = 1500 + Math.random() * 2500;
      reactionTimeout = setTimeout(() => {
        if (!reactionStatus || !reactionButton) return;
        reactionStatus.textContent = 'Click now!';
        reactionButton.textContent = 'Click!';
        reactionStart = Date.now();
      }, wait);
    }

    function resetReactionGame() {
      const reactionStatus = document.getElementById('reaction-status');
      const reactionResult = document.getElementById('reaction-result');
      const reactionButton = document.getElementById('reaction-start-btn');
      if (reactionTimeout) clearTimeout(reactionTimeout);
      reactionStart = null;
      if (reactionButton) reactionButton.textContent = 'Start Reaction Test';
      if (reactionStatus) reactionStatus.textContent = 'Press start and wait for the green signal.';
      if (reactionResult) reactionResult.textContent = '';
    }

    function initFocusChallenge() {
      const focusStatus = document.getElementById('focus-challenge-status');
      const focusTimerEl = document.getElementById('focus-challenge-timer');
      const durationSelect = document.getElementById('focus-duration');
      if (!focusStatus || !focusTimerEl || !durationSelect) return;
      if (focusTimer) clearInterval(focusTimer);
      focusActive = true;
      focusRemaining = Number(durationSelect.value) || 120;
      const updateTimer = () => {
        const minutes = Math.floor(focusRemaining / 60);
        const seconds = focusRemaining % 60;
        focusTimerEl.textContent = `${formatTwoDigits(minutes)}:${formatTwoDigits(seconds)}`;
        if (focusRemaining <= 0) {
          clearInterval(focusTimer);
          focusActive = false;
          focusStatus.textContent = 'Great work! You completed the focus challenge.';
          return;
        }
        focusRemaining -= 1;
      };
      updateTimer();
      focusStatus.textContent = 'Stay on this page and keep your attention here.';
      focusTimer = setInterval(updateTimer, 1000);
      window.addEventListener('blur', () => {
        if (!focusActive) return;
        clearInterval(focusTimer);
        focusActive = false;
        focusStatus.textContent = 'Focus broken — try again after a full study session.';
      }, { once: true });
    }

    function resetFocusChallenge() {
      const focusStatus = document.getElementById('focus-challenge-status');
      const focusTimerEl = document.getElementById('focus-challenge-timer');
      if (focusTimer) clearInterval(focusTimer);
      focusActive = false;
      focusRemaining = Number(document.getElementById('focus-duration')?.value || 120);
      if (focusTimerEl) focusTimerEl.textContent = `${formatTwoDigits(Math.floor(focusRemaining / 60))}:${formatTwoDigits(focusRemaining % 60)}`;
      if (focusStatus) focusStatus.textContent = 'Press start to begin the Focus Trial.';
    }

    function initGameBoard() {
      const grid = document.getElementById('memory-grid');
      const gameStatus = document.getElementById('game-status');
      if (!grid || !gameStatus) return;

      const icons = ['🧠', '📚', '✨', '🚀'];
      const deck = [...icons, ...icons].sort(() => Math.random() - 0.5);
      let firstCard = null;
      let secondCard = null;
      let lockBoard = false;
      let matches = 0;

      function resetTurn() {
        firstCard = null;
        secondCard = null;
        lockBoard = false;
      }

      function checkForMatch() {
        if (!firstCard || !secondCard) return;
        const match = firstCard.dataset.symbol === secondCard.dataset.symbol;
        if (match) {
          firstCard.classList.add('matched');
          secondCard.classList.add('matched');
          matches += 1;
          gameStatus.textContent = matches === icons.length
            ? 'You matched all pairs! Great focus and well done.'
            : `Nice! ${matches} of ${icons.length} pairs matched.`;
          resetTurn();
        } else {
          lockBoard = true;
          setTimeout(() => {
            [firstCard, secondCard].forEach(card => {
              card.classList.remove('flipped');
              card.querySelector('.card-front')?.classList.remove('d-none');
              card.querySelector('.card-back')?.classList.add('card-hidden');
            });
            resetTurn();
          }, 900);
        }
      }

      grid.innerHTML = deck.map(symbol => `
        <button type="button" class="memory-card" data-symbol="${symbol}">
          <span class="card-front">?</span>
          <span class="card-back card-hidden">${symbol}</span>
        </button>
      `).join('');

      grid.querySelectorAll('.memory-card').forEach(card => {
        card.addEventListener('click', () => {
          if (lockBoard || card.classList.contains('flipped') || card.classList.contains('matched')) return;
          card.classList.add('flipped');
          card.querySelector('.card-front')?.classList.add('d-none');
          card.querySelector('.card-back')?.classList.remove('card-hidden');
          if (!firstCard) {
            firstCard = card;
            return;
          }
          secondCard = card;
          checkForMatch();
        });
      });

      const restartBtn = document.getElementById('restart-game-btn');
      if (restartBtn && !restartBtn.dataset.gameListener) {
        restartBtn.dataset.gameListener = 'true';
        restartBtn.addEventListener('click', initGameBoard);
      }
      gameStatus.textContent = 'Tap two cards to reveal a match.';
    }

    function setupGamePage() {
      const unlocked = isGameUnlocked();
      const gameLocked = document.getElementById('game-locked');
      const gameUnlockedPanel = document.getElementById('game-unlocked');
      const gameUnlockStatus = document.getElementById('game-unlock-status');
      const gameLockMessage = document.getElementById('game-lock-message');
      const gameUnlockHint = document.getElementById('game-unlock-hint');
      if (gameUnlockStatus) {
        gameUnlockStatus.textContent = unlocked ? 'Game unlocked — choose your reward' : 'Unlock the game with focus';
        gameUnlockStatus.className = unlocked ? 'badge bg-success py-2 px-3 fs-6' : 'badge bg-warning py-2 px-3 fs-6';
      }
      if (gameLockMessage) {
        gameLockMessage.textContent = unlocked
          ? 'Study game unlocked! Choose a mini-game and enjoy your reward challenge.'
          : 'Complete a study session to unlock the game.';
      }
      if (gameUnlockHint) {
        gameUnlockHint.textContent = unlocked
          ? 'Great job! The Study Game is unlocked — choose a game below.'
          : 'Complete a study session to unlock the Study Game reward.';
      }
      if (gameLocked) {
        gameLocked.classList.toggle('d-none', unlocked);
      }
      if (gameUnlockedPanel) {
        gameUnlockedPanel.classList.toggle('d-none', !unlocked);
      }
      if (unlocked) {
        switchGameMode(currentGameMode);
      }
    }

    function refreshStreak() {
      const storedCount = Number(localStorage.getItem(streakKey) || 0);
      if (streakCount) streakCount.textContent = storedCount;
      if (streakMessage) streakMessage.textContent = storedCount > 0 ? getMotivationText(storedCount) : 'Your streak starts today!';
      updateStreakPage();
    }

    function recordActivity() {
      const today = getISODate();
      const yesterday = getISODate(new Date(Date.now() - 86400000));
      const lastDate = localStorage.getItem(streakDateKey);
      let count = Number(localStorage.getItem(streakKey) || 0);
      if (lastDate !== today) {
        count = lastDate === yesterday ? count + 1 : 1;
        localStorage.setItem(streakKey, count);
        localStorage.setItem(streakDateKey, today);
      }
      refreshStreak();
    }

