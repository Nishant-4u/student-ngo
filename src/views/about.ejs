<%- include('partials/header') %>

<section class="py-5 bg-primary text-white text-center pb-5" style="background: linear-gradient(135deg, #4f46e5 0%, #3b82f6 100%); padding-top: 100px !important;">
    <div class="container py-5 mt-5">
        <h1 class="display-3 fw-bold mb-3">About 2AM Study</h1>
        <p class="lead fw-light mb-0" style="max-width: 700px; margin: 0 auto;">Your ultimate companion for late-night focus and academic success.</p>
    </div>
</section>

<main class="container py-5 my-3" style="margin-top: -60px !important;">
  <div class="row justify-content-center">
    <div class="col-lg-10 bg-white p-5 rounded-4 shadow-lg">
      <div class="row align-items-center g-5">
        <div class="col-md-6 order-md-2">
            <img src="/assets/images/logo.jpg" alt="2AM Study Logo" class="img-fluid rounded-4 shadow-sm" style="max-height: 400px; object-fit: cover; width: 100%;">
        </div>
        <div class="col-md-6 order-md-1">
            <h2 class="fw-bold mb-4 text-dark">Our Mission</h2>
            <p class="text-muted lh-lg">
                At <strong>2AM Study</strong>, we believe that every student has the potential to achieve greatness. The late hours of the night often represent the quietest, most focused moments of a student's life. Our mission is to transform those challenging study sessions into highly productive, engaging, and successful experiences.
            </p>
            <p class="text-muted lh-lg mb-0">
                Created with love for students everywhere, our platform provides a comprehensive suite of completely free tools—from Pomodoro timers and flashcards, to scientific calculators and ambient focus music.
            </p>
        </div>
      </div>

      <hr class="my-5 opacity-25">

      <div class="text-center mb-5">
          <h2 class="fw-bold text-dark">Why Choose Us?</h2>
          <p class="text-muted">We provide everything you need in one place.</p>
      </div>

      <div class="row g-4 text-center">
          <div class="col-md-4">
              <div class="p-4 bg-light rounded-4 h-100">
                  <div class="text-primary fs-1 mb-3"><i class="fa-solid fa-bolt"></i></div>
                  <h4 class="fw-bold">Fast & Free</h4>
                  <p class="text-muted small mb-0">All our tools are highly optimized for speed and cost absolutely nothing.</p>
              </div>
          </div>
          <div class="col-md-4">
              <div class="p-4 bg-light rounded-4 h-100">
                  <div class="text-primary fs-1 mb-3"><i class="fa-solid fa-box-open"></i></div>
                  <h4 class="fw-bold">All-in-One</h4>
                  <p class="text-muted small mb-0">PDF tools, calculators, timers, and music—all in a single platform.</p>
              </div>
          </div>
          <div class="col-md-4">
              <div class="p-4 bg-light rounded-4 h-100">
                  <div class="text-primary fs-1 mb-3"><i class="fa-solid fa-shield-halved"></i></div>
                  <h4 class="fw-bold">Privacy First</h4>
                  <p class="text-muted small mb-0">Your files and study habits are your own business. We respect your data.</p>
              </div>
          </div>
      </div>

    </div>
  </div>
</main>

<%- include('partials/footer') %>
