<script>
  document.addEventListener('DOMContentLoaded', function () {
    const searchInput = document.getElementById('blogSearchInput');
    const sortSelect = document.getElementById('blogSortSelect');
    const resultCount = document.getElementById('blogResultCount');
    const noResults = document.getElementById('blogNoResults');
    const cards = Array.from(document.querySelectorAll('.blog-card-col'));

    const cardMeta = cards.map((card, index) => {
      const title = (card.querySelector('.card-title')?.textContent || '').trim();
      const desc = (card.querySelector('.card-text')?.textContent || '').trim();
      const category = (card.querySelector('.badge')?.textContent || '').trim();
      return { card, index, title, desc, category };
    });

    function applyBlogFilters() {
      const query = (searchInput?.value || '').toLowerCase().trim();
      const sortMode = sortSelect?.value || 'default';

      let visible = cardMeta.filter(item => {
        const text = `${item.title} ${item.desc} ${item.category}`.toLowerCase();
        const matched = !query || text.includes(query);
        item.card.style.display = matched ? '' : 'none';
        return matched;
      });

      if (sortMode === 'title-asc') visible.sort((a, b) => a.title.localeCompare(b.title));
      if (sortMode === 'title-desc') visible.sort((a, b) => b.title.localeCompare(a.title));
      if (sortMode === 'category-asc') visible.sort((a, b) => a.category.localeCompare(b.category));
      if (sortMode === 'default') visible.sort((a, b) => a.index - b.index);

      visible.forEach(item => {
        item.card.parentNode.appendChild(item.card);
      });

      if (resultCount) {
        resultCount.textContent = `${visible.length} article${visible.length !== 1 ? 's' : ''} found`;
      }
      if (noResults) {
        noResults.style.display = visible.length ? 'none' : 'block';
      }
    }

    searchInput?.addEventListener('input', applyBlogFilters);
    sortSelect?.addEventListener('change', applyBlogFilters);
    applyBlogFilters();
  });
</script>

