<%- include('partials/header') %>
<section class="container-fluid py-5 bg-light">
  <div class="container">
    <div class="bg-white shadow-lg rounded p-4">
      <h1>Flashcards</h1>
      <p class="mb-4">Create, flip, and remove flashcards while storing them locally for review later.</p>
      <div class="tool-panel p-4">
        <div class="row g-2 mb-3">
          <div class="col-sm-6"><input id="flashcard-front" class="form-control" type="text" placeholder="Question / front"></div>
          <div class="col-sm-6"><input id="flashcard-back" class="form-control" type="text" placeholder="Answer / back"></div>
        </div>
        <button id="flashcard-add" class="btn btn-outline-primary btn-sm mb-3">Add Card</button>
        <div id="flashcards-container" class="flashcards-list"></div>
        <p class="tool-note">Add custom study cards, flip to reveal answers, and delete cards when you’re done.</p>
      </div>
      <a href="/" class="btn btn-link mt-4">← Back to Home</a>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
