<%- include('partials/header') %>
<section class="container-fluid py-5 bg-light">
  <div class="container">
    <div class="bg-white shadow-lg rounded p-4">
      <h1>Digital Clock</h1>
      <p class="mb-4">View the current local time with a live digital clock updated every second.</p>
      <div class="tool-panel p-4 text-center">
        <div class="digital-clock py-4 fs-1" id="digital-clock">00:00:00</div>
        <div id="clock-date" class="clock-date text-muted fs-5">Loading date...</div>
        <p class="tool-note">This clock runs in real time and keeps you anchored during study sessions.</p>
      </div>
      <a href="/" class="btn btn-link mt-4">← Back to Home</a>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
