<%- include('partials/header') %>
<section class="container-fluid py-5 bg-light">
  <div class="container">
    <div class="bg-white shadow-lg rounded p-4">
      <h1>Motivational Quotes</h1>
      <p class="mb-4">Refresh your motivation with a random quote every time you open this page.</p>
      <div class="tool-panel p-4">
        <blockquote class="blockquote fs-5 mb-3">
          <p id="quote-text">Loading inspiring quote...</p>
          <footer class="blockquote-footer" id="quote-author"></footer>
        </blockquote>
        <button id="new-quote" class="btn btn-outline-primary btn-sm">New Quote</button>
        <p class="tool-note mt-3">Boost your study spark with thoughtful words of encouragement.</p>
      </div>
      <a href="/" class="btn btn-link mt-4">← Back to Home</a>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
