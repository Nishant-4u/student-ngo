<%- include('partials/header') %>

<style>
/* Review & Pay - Advanced Flipkart Style Formatting */
:root {
  --rp-bg: #f1f3f6;
  --rp-card: #ffffff;
  --rp-border: #e0e0e0;
  --rp-accent: #2874f0;
  --rp-accent-hover: #1a5dc8;
  --rp-orange: #fb641b; 
  --rp-orange-hover: #ff7531;
  --rp-green: #388e3c;
  --rp-text: #212121;
  --rp-text-muted: #878787;
}

body {
  background-color: var(--rp-bg);
  color: var(--rp-text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.rp-main {
  padding-top: 100px;
  padding-bottom: 60px;
  min-height: 100vh;
}

/* Steps Framework */
.rp-step-box {
  background: var(--rp-card);
  border: 1px solid var(--rp-border);
  border-radius: 8px;
  margin-bottom: 1.5rem;
  overflow: hidden;
}
.rp-step-header {
  background: var(--rp-accent);
  padding: 1rem 1.5rem;
  border-bottom: 1px solid var(--rp-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.rp-step-header-left {
  display: flex; align-items: center; gap: 1rem;
}
.rp-step-num {
  width: 24px;
  height: 24px;
  background: #fff;
  color: var(--rp-accent);
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.85rem;
  font-weight: 700;
}
.rp-step-title {
  font-weight: 700;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  font-size: 0.95rem;
  margin: 0;
}
.rp-step-btn {
  background: transparent; color: #fff;
  border: 1px solid rgba(255,255,255,0.5); border-radius: 6px;
  padding: 0.4rem 1rem; font-size: 0.8rem; font-weight: 700;
  text-transform: uppercase; transition: 0.2s; text-decoration: none;
}
.rp-step-btn:hover { background: rgba(255,255,255,0.1); border-color: #fff; color: #fff; }

.rp-step-body { padding: 1.5rem; }

/* Contact Specifics */
.rp-contact-name { font-weight: 700; font-size: 1.1rem; margin-bottom: 0.2rem; color: #fff; }
.rp-contact-line { font-size: 0.95rem; color: rgba(255,255,255,0.8); margin-bottom: 0.2rem; }

/* Item Specifics */
.rp-item-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 1rem 0;
  border-bottom: 1px solid var(--rp-border);
}
.rp-item-row:last-child { border-bottom: none; padding-bottom: 0; }
.rp-item-left { display: flex; align-items: center; gap: 1rem; }
.rp-item-img {
  width: 60px; height: 60px; border-radius: 8px; object-fit: cover; border: 1px solid var(--rp-border);
}
.rp-item-details { display: flex; flex-direction: column; }
.rp-item-name { font-weight: 600; font-size: 0.95rem; color: var(--rp-text); }
.rp-item-qty { font-size: 0.85rem; color: var(--rp-text-muted); }
.rp-item-price { font-weight: 800; font-size: 1.1rem; color: var(--rp-text); }

/* Price Details Specifics */
.rp-price-box {
  background: var(--rp-card);
  border: 1px solid var(--rp-border);
  border-radius: 8px;
}
.rp-price-header {
  padding: 1rem 1.5rem;
  border-bottom: 1px solid var(--rp-border);
  font-weight: 700;
  color: var(--rp-text-muted);
  text-transform: uppercase;
  font-size: 0.95rem;
  letter-spacing: 0.5px;
}
.rp-price-body { padding: 1.5rem; }
.rp-price-row {
  display: flex; justify-content: space-between; margin-bottom: 1.1rem; font-size: 0.95rem;
}
.rp-price-final {
  display: flex; justify-content: space-between; align-items: center;
  padding: 1.2rem 0; margin: 0.5rem 0;
  border-top: 1px dashed var(--rp-border);
  border-bottom: 1px dashed var(--rp-border);
}
.rp-price-final span { font-weight: 700; font-size: 1.1rem; }
.rp-price-final strong { font-weight: 800; font-size: 1.4rem; color: var(--rp-text); }

.rp-saved-text { color: var(--rp-green); font-weight: 700; font-size: 0.95rem; padding-top: 0.5rem; display: block; }

.rp-checkout-btn-wrap {
  background: var(--rp-card);
  padding: 1rem 1.5rem;
  border-top: 1px solid var(--rp-border);
}
.btn-rp-pay {
  background: var(--rp-orange); color: #fff; border: none; width: 100%; padding: 1.1rem; border-radius: 6px; font-weight: 800; font-size: 1.1rem; text-transform: uppercase; box-shadow: 0 4px 6px rgba(251, 100, 27, 0.2); transition: 0.2s; display: flex; justify-content: center; align-items: center; gap: 0.5rem;
  border: 1px solid rgba(255,255,255,0.1);
}
.btn-rp-pay:hover { 
  background: var(--rp-orange-hover); 
  box-shadow: 0 0 20px rgba(251, 100, 27, 0.4); 
  transform: translateY(-1px); 
}

/* Trust Line */
.rp-trust-box {
  display: flex; justify-content: center; gap: 2rem; margin-top: 1.5rem; padding: 1rem;
  color: var(--rp-text-muted); font-size: 0.85rem; font-weight: 600;
}
.rp-trust-item { display: flex; align-items: center; gap: 0.5rem; }

/* ========================
   MOBILE - Review & Pay Page
   ======================== */
@media (max-width: 768px) {
  html, body { overflow-x: hidden !important; width: 100%; }
  body { background-color: #f1f3f6 !important; }
  .site-footer, .help-bot-container { display: none !important; }

  .rp-main {
    padding-top: 80px;
    padding-bottom: 130px;
    padding-left: 0 !important;
    padding-right: 0 !important;
  }

  /* Strip Bootstrap container gutters */
  .rp-main > .container {
    padding-left: 0 !important;
    padding-right: 0 !important;
    max-width: 100% !important;
  }

  /* Step boxes: edge-to-edge white cards */
  .rp-step-box, .rp-price-box, .rp-trust-box {
    border-radius: 0 !important;
    border-left: none !important;
    border-right: none !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
    margin-bottom: 8px !important;
  }

  /* Make the right-column static on mobile */
  .rp-sticky-parent { position: static !important; }
  .rp-checkout-btn-wrap { display: none !important; }

  /* Step header & body sizing */
  .rp-step-title { font-size: 0.8rem; }
  .rp-step-btn { font-size: 0.7rem; padding: 0.3rem 0.7rem; }
  .rp-step-body { padding: 1rem; }

  /* Item row: compact on phone */
  .rp-item-left { gap: 10px; }
  .rp-item-img { width: 48px; height: 48px; }
  .rp-item-name { font-size: 0.85rem; }
  .rp-item-price { font-size: 0.95rem; }

  /* Fixed sticky Pay button at bottom */
  .mobile-checkout-bar {
    display: flex !important;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background: var(--rp-card);
    border-top: 1px solid var(--rp-border);
    box-shadow: 0 -4px 20px rgba(0,0,0,0.5);
    padding: 12px 16px;
    padding-bottom: calc(12px + env(safe-area-inset-bottom, 0));
    align-items: center;
    gap: 14px;
  }
  .mobile-checkout-bar .mob-price-col {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .mobile-checkout-bar .mob-price-label {
    font-size: 0.7rem;
    color: var(--rp-text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .mobile-checkout-bar .mob-price-value {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--rp-text);
    line-height: 1.1;
  }
  .mobile-checkout-bar .mob-cta {
    flex: 1;
    padding: 15px;
    background: var(--rp-orange);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    white-space: nowrap;
    transition: 0.2s;
  }
  .mobile-checkout-bar .mob-cta:disabled { opacity: 0.7; cursor: not-allowed; }
}

/* Always hide the mobile bar on desktop */
@media (min-width: 769px) {
  .mobile-checkout-bar { display: none !important; }
}

</style>

<main class="container rp-main">
  <div class="row justify-content-center">
    
    <div class="col-12 mb-4 d-flex justify-content-between align-items-center flex-wrap gap-2 px-3 px-md-0">
      <h1 class="fs-3 fw-bold mb-0">Review & Pay</h1>
    </div>

    <!-- Empty State -->
    <div id="paymentEmpty" class="col-12 text-center py-5 d-none">
      <div class="mb-4">
        <i class="fa-solid fa-cart-arrow-down text-muted" style="font-size:3rem; opacity:0.5;"></i>
      </div>
      <h3 class="fw-bold mb-3">No items in your active order</h3>
      <p class="text-muted mb-4">You have securely exited the payment process.</p>
      <a href="/store" class="btn btn-outline-light px-5 py-2 fw-semibold rounded-pill">Return to Store</a>
    </div>

    <div class="col-12 row g-4" id="paymentContent">
      
      <!-- LEFT COL: Review Assets -->
      <div class="col-lg-8">
        
        <!-- 1. Address Block -->
        <div class="rp-step-box">
          <div class="rp-step-header">
            <div class="rp-step-header-left">
              <div class="rp-step-num"><i class="fa-solid fa-check" style="font-size:0.6rem;"></i></div>
              <h2 class="rp-step-title">Delivery Address</h2>
            </div>
            <a href="/store/order-summary" class="rp-step-btn">Change Address ❗</a>
          </div>
          <div class="rp-step-body" id="payAddressBox">
            <!-- Intercepted by JS -->
          </div>
        </div>

        <!-- 2. Items Block -->
        <div class="rp-step-box">
          <div class="rp-step-header">
            <div class="rp-step-header-left">
              <div class="rp-step-num"><i class="fa-solid fa-check" style="font-size:0.6rem;"></i></div>
              <h2 class="rp-step-title">Order Summary (<span id="rpItemCount">0</span> Items)</h2>
            </div>
            <a href="/store/cart" class="rp-step-btn">Edit Cart ❗</a>
          </div>
          <div class="rp-step-body" id="payItemsBox" style="padding-top: 0.5rem;">
            <!-- Intercepted by JS -->
          </div>
        </div>

        <!-- Trust Badge (Flipkart Style) -->
        <div style="display: flex; align-items: center; gap: 16px; padding: 16px 0; margin-bottom: 24px;">
          <i class="fa-solid fa-shield-halved" style="font-size: 2.2rem; color: #878787;"></i>
          <span style="font-size: 0.95rem; font-weight: 500; line-height: 1.4; color: var(--rp-text-muted);">Safe and Secure Payments. Easy returns.<br>100% Authentic products.</span>
        </div>

      </div>

      <!-- RIGHT COL: Price Execution -->
      <div class="col-lg-4">
        <div class="rp-sticky-parent" style="position: sticky; top: 100px; padding-bottom: 20px;">
          <div class="rp-price-box">
            <div class="rp-price-header">Price Details</div>
            
            <div class="rp-price-body">
              <div class="rp-price-row">
                <span>Price (<span id="rpItemCountBadge">0</span> items)</span>
                <span id="rpBasePrice">₹0</span>
              </div>
              <div class="rp-price-row">
                <span>Discount</span>
                <span id="rpDiscount" class="text-success">- ₹0</span>
              </div>
              <div class="rp-price-row" id="rpCouponRow" style="display:none;">
                <span>Coupon Discount</span>
                <span id="rpCouponDisc" class="text-success">- ₹0</span>
              </div>
              <div class="rp-price-row">
                <span>Platform Fee</span>
                <span>₹1</span>
              </div>
              <div class="rp-price-row border-bottom pb-3 mb-2" style="border-color:var(--rp-border)!important;">
                <span>Delivery Charges</span>
                <span id="rpDelivery">₹0</span>
              </div>

              <div class="rp-price-final">
                <span>Total Amount</span>
                <strong id="rpFinalTotal">₹0</strong>
              </div>

              <div class="rp-saved-text" id="rpSavedBlock">🎉 You saved ₹0 on this order</div>
            </div>

            <div class="rp-checkout-btn-wrap">
              <button id="payNowBtn" class="btn-rp-pay">
                Proceed to Pay &nbsp;<i class="fa-solid fa-angle-right"></i>
              </button>
            </div>
          </div>


        </div>
      </div>

    </div>
  </div>
</main>

<!-- Mobile Fixed Checkout Bar (Phone only) -->
<div class="mobile-checkout-bar" id="mobileCheckoutBar">
  <div class="mob-price-col">
    <span class="mob-price-label">Total Amount</span>
    <span class="mob-price-value" id="mobBarTotal">₹0</span>
  </div>
  <button class="mob-cta" id="payNowBtnMobile">
    Proceed to Pay &nbsp;<i class="fa-solid fa-angle-right"></i>
  </button>
</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
  (async function () {
    const RAZORPAY_KEY_ID = '<%= razorpayKeyId || "" %>';
    const empty = document.getElementById('paymentEmpty');
    const content = document.getElementById('paymentContent');

    // Load all checkout state from server session
    let checkoutData;
    try {
      const res = await fetch(`/api/store/checkout`, { credentials: 'include' });
      checkoutData = await res.json();
    } catch(e) {
      empty.classList.remove('d-none');
      content.classList.add('d-none');
      return;
    }

    const cart = checkoutData.cart || [];
    const checkoutCustomer = checkoutData.customer || null;
    const appliedCoupon = checkoutData.coupon || null;

    // Guard: empty cart
    if (!cart.length) {
      empty.classList.remove('d-none');
      content.classList.add('d-none');
      return;
    }

    // Guard: no address saved yet
    if (!checkoutCustomer) {
      window.location.href = '/store/order-summary';
      return;
    }

    // Render Delivery Address
    const delStartDate = new Date();
    delStartDate.setDate(delStartDate.getDate() + 3);
    const delEndDate = new Date();
    delEndDate.setDate(delEndDate.getDate() + 5);
    const dateOptions = { month: 'short', day: 'numeric' };
    
    document.getElementById('payAddressBox').innerHTML = `
      <div class="d-flex align-items-center flex-wrap gap-2 mb-2">
        <span style="font-weight: 700; font-size: 1.1rem; color: var(--rp-text);">${checkoutCustomer.name}</span>
        <span class="badge bg-secondary text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.5px;">Home</span>
        <span style="font-weight: 700; font-size: 1.05rem; color: var(--rp-text); margin-left: 0.5rem;">${checkoutCustomer.phone}</span>
      </div>
      <div style="font-size: 0.95rem; color: var(--rp-text); line-height: 1.5; margin-bottom: 0.5rem; max-width: 500px;">
        ${checkoutCustomer.address}, ${checkoutCustomer.city}
        <span style="font-weight: 600;">- ${checkoutCustomer.pincode}</span>
      </div>
      <div style="font-size: 0.85rem; color: var(--rp-text-muted); display: flex; align-items: center; gap: 0.4rem;">
        <i class="fa-regular fa-envelope"></i> ${checkoutCustomer.email}
      </div>
      <div style="font-size: 0.9rem; color: var(--rp-green); font-weight: 700; margin-top: 1rem; padding-top: 0.8rem; border-top: 1px dashed var(--rp-border);">
        <i class="fa-solid fa-truck me-1"></i> Delivery by ${delStartDate.toLocaleDateString('en-US', dateOptions)} – ${delEndDate.toLocaleDateString('en-US', dateOptions)}
      </div>
    `;

    // Render Items
    const totalItemsQuantity = cart.reduce((sum, item) => sum + parseInt(item.qty || 1), 0);
    document.getElementById('rpItemCount').textContent = totalItemsQuantity;
    document.getElementById('rpItemCountBadge').textContent = totalItemsQuantity;
    document.getElementById('payItemsBox').innerHTML = cart.map((i, idx) => {
      const imgUrl = i.image || '/assets/images/store/placeholder.jpg';
      return `
      <div class="rp-item-row">
        <div class="rp-item-left">
          <img src="${imgUrl}" class="rp-item-img" onerror="this.onerror=null; this.src='/assets/images/store/placeholder.jpg';">
          <div class="rp-item-details">
            <span class="rp-item-name">${i.name}</span>
            <span class="rp-item-qty">Qty: ${i.qty}</span>
          </div>
        </div>
        <div class="rp-item-price">₹${i.price * i.qty}</div>
      </div>`;
    }).join('');

    // === DISPLAY ONLY: All values are server-computed ===
    // The frontend does zero arithmetic — it only renders what the server sends.
    const s = checkoutData.summary;

    document.getElementById('rpBasePrice').textContent = `₹${s.mrpSubtotal}`;
    document.getElementById('rpDiscount').textContent = `- ₹${s.baseStoreDiscount}`;
    if (s.couponDiscount > 0) {
      document.getElementById('rpCouponRow').style.display = 'flex';
      document.getElementById('rpCouponDisc').textContent = `- ₹${s.couponDiscount}`;
    }
    const delEl = document.getElementById('rpDelivery');
    const delEl2 = document.getElementById('rpDelivery2');
    if (s.delivery === 0) {
      const freeDeliveryHTML = `<span style="text-decoration: line-through; color: var(--rp-text-muted); font-size: 0.85rem; margin-right: 6px; opacity: 0.7;">₹50</span> <span style="color: #388e3c; font-weight: 700;">FREE</span>`;
      delEl.innerHTML = freeDeliveryHTML;
      if (delEl2) delEl2.innerHTML = freeDeliveryHTML;
    } else {
      delEl.textContent = `₹${s.delivery}`;
      if (delEl2) delEl2.textContent = `₹${s.delivery}`;
    }
    
    document.getElementById('rpFinalTotal').textContent = `₹${s.finalTotal}`;
    const rpFinalTotal2 = document.getElementById('rpFinalTotal2');
    if (rpFinalTotal2) rpFinalTotal2.textContent = `₹${s.finalTotal}`;

    const mobBarTotalEl = document.getElementById('mobBarTotal');
    if (mobBarTotalEl) mobBarTotalEl.textContent = `₹${s.finalTotal}`;
    
    const taxHtml = '<div style="font-size:0.8rem; color: var(--rp-text-muted); text-align:right; margin-top:2px; font-weight:500; opacity: 0.8;">Inclusive of all taxes</div>';
    document.getElementById('rpFinalTotal').insertAdjacentHTML('afterend', taxHtml);
    if (rpFinalTotal2) rpFinalTotal2.insertAdjacentHTML('afterend', taxHtml);

    document.getElementById('payNowBtn').innerHTML = `Proceed to Pay &nbsp;<i class="fa-solid fa-angle-right"></i>`;
    document.getElementById('rpSavedBlock').textContent = `🎉 You saved ₹${s.totalSaved} on this order`;
    const rpSavedBlock2 = document.getElementById('rpSavedBlock2');
    if (rpSavedBlock2) rpSavedBlock2.textContent = `🎉 You saved ₹${s.totalSaved} on this order`;

    // Inline sync
    const rpItemCountBadge2 = document.getElementById('rpItemCountBadge2');
    if (rpItemCountBadge2) rpItemCountBadge2.textContent = totalItemsQuantity;
    const rpBasePrice2 = document.getElementById('rpBasePrice2');
    if (rpBasePrice2) rpBasePrice2.textContent = `₹${s.mrpSubtotal}`;
    const rpDiscount2 = document.getElementById('rpDiscount2');
    if (rpDiscount2) rpDiscount2.textContent = `- ₹${s.baseStoreDiscount}`;
    if (s.couponDiscount > 0) {
      document.getElementById('rpCouponRow2').style.display = 'flex';
      const rpCouponDisc2 = document.getElementById('rpCouponDisc2');
      if (rpCouponDisc2) rpCouponDisc2.textContent = `- ₹${s.couponDiscount}`;
    }

    // Pay Button Config
    async function startPaymentFlow(btn) {
      if (!btn) return;
      if (!RAZORPAY_KEY_ID) return alert('Razorpay server key not found in environment.');
      
      const originalHTML = btn.innerHTML;
      btn.innerHTML = `<i class="fa-solid fa-circle-notch fa-spin me-2"></i> Loading...`;
      btn.disabled = true;
      document.querySelectorAll('.mob-cta, .btn-rp-pay').forEach(b => b.disabled = true);

      try {
        // No amount sent — server reads from session and computes securely
        const res = await fetch(`/api/store/create-order`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({}),
          credentials: 'include'
        });
        const order = await res.json();
        if (!res.ok) throw new Error(order.error || 'Unable to create order with server.');

        // Use the server's confirmed total for display in Razorpay modal
        const confirmedTotal = order.serverSummary ? order.serverSummary.finalTotal : s.finalTotal;

        const rzp = new Razorpay({
          key: RAZORPAY_KEY_ID,
          amount: order.amount,       // Already in paise from server
          currency: order.currency,
          name: '2 AM Study',
          description: 'Secure Checkout',
          order_id: order.id,
          prefill: { name: checkoutCustomer.name, email: checkoutCustomer.email, contact: checkoutCustomer.phone },
          theme: { color: '#6366f1' },
          handler: async function (response) {
            document.body.insertAdjacentHTML('beforeend', `
              <div style="position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(11,18,32,0.9);z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;">
                <div class="spinner-border text-primary" style="width: 3rem; height: 3rem; margin-bottom:1rem;" role="status"></div>
                <h4 class="text-white fw-bold">Verifying Payment...</h4>
              </div>
            `);

            const verifyRes = await fetch(`/api/store/verify-payment`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(response),
              credentials: 'include'
            });
            const verifyData = await verifyRes.json();
            if (!verifyRes.ok || !verifyData.verified) {
              alert(verifyData.error || 'Payment verification failed.');
              window.location.reload();
              return;
            }

            // Save minimal last-order to localStorage ONLY for the post-payment review feature
            localStorage.setItem('2am_last_order', JSON.stringify({
              paymentId: response.razorpay_payment_id,
              orderId: response.razorpay_order_id,
              items: [...cart],
              address: checkoutCustomer,
              total: confirmedTotal,
              coupon: appliedCoupon?.code || '',
              platformFee: s.platformFee
            }));

            // Clear all checkout state from server session
            await fetch(`/api/store/checkout/clear`, { method: 'POST', credentials: 'include' });

            window.location.href = `/store/payment-success?payment_id=${encodeURIComponent(response.razorpay_payment_id)}&order_id=${encodeURIComponent(response.razorpay_order_id)}`;
          }
        });
        
        rzp.on('payment.failed', function () {
          btn.innerHTML = `Proceed to Pay ₹${confirmedTotal}`;
          btn.disabled = false;
        });

        rzp.open();
      } catch (e) {
        alert(e.message || 'Payment engine failure. Please try again.');
        btn.innerHTML = `Proceed to Pay &nbsp;<i class="fa-solid fa-angle-right"></i>`;
        document.querySelectorAll('.mob-cta, .btn-rp-pay').forEach(b => b.disabled = false);
      }
    }

    // Attach to Desktop Button
    const payBtn = document.getElementById('payNowBtn');
    if (payBtn) payBtn.addEventListener('click', () => startPaymentFlow(payBtn));

    // Attach to Mobile Button
    const payBtnMobile = document.getElementById('payNowBtnMobile');
    if (payBtnMobile) payBtnMobile.addEventListener('click', () => startPaymentFlow(payBtnMobile));

  })();
</script>

