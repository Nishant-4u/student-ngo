<%- include('partials/header') %>
<section class="container-fluid py-5 bg-light">
  <div class="container">
    <div class="bg-white shadow-lg rounded p-4">
      <h1>Reminder System</h1>
      <p class="mb-4">Set a time and receive an on-screen reminder to start your next study session.</p>
      <div class="tool-panel p-4">
        <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
          <input id="reminder-time" type="time" class="form-control" style="max-width:220px;">
          <button id="reminder-set" class="btn btn-warning">Set Reminder</button>
        </div>
        <p class="tool-note">Set your reminder and keep a consistent study schedule.</p>
      </div>
      <a href="/" class="btn btn-link mt-4">← Back to Home</a>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
