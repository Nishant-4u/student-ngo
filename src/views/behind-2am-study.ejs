<%- include('partials/header') %>

    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
            --glass-bg: rgba(255, 255, 255, 0.7);
            --glass-border: rgba(255, 255, 255, 0.3);
        }

        /* ── HERO BANNER ─────────────────────────────────── */
        .hero-section {
            background: linear-gradient(135deg,
                    #0f0c29 0%,
                    #302b63 35%,
                    #24243e 65%,
                    #4a00e0 100%);
            position: relative;
            overflow: hidden;
            padding: 160px 0 100px;
            color: white;
            min-height: 85vh;
            display: flex;
            align-items: center;
        }

        /* Animated radial mesh overlay */
        .hero-section::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 20% 50%, rgba(99, 102, 241, 0.35) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 20%, rgba(168, 85, 247, 0.25) 0%, transparent 45%),
                radial-gradient(ellipse at 50% 90%, rgba(59, 130, 246, 0.2) 0%, transparent 40%);
            z-index: 1;
        }

        /* Floating blob 1 */
        .hero-blob-1 {
            position: absolute;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(139, 92, 246, 0.3) 0%, transparent 70%);
            top: -100px;
            right: -100px;
            z-index: 1;
            animation: blobDrift 8s ease-in-out infinite alternate;
        }

        /* Floating blob 2 */
        .hero-blob-2 {
            position: absolute;
            width: 350px;
            height: 350px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.25) 0%, transparent 70%);
            bottom: -80px;
            left: -60px;
            z-index: 1;
            animation: blobDrift 10s ease-in-out 1s infinite alternate-reverse;
        }

        /* Grid dot pattern */
        .hero-grid {
            position: absolute;
            inset: 0;
            background-image: radial-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px);
            background-size: 32px 32px;
            z-index: 1;
        }

        @keyframes blobDrift {
            from {
                transform: translate(0, 0) scale(1);
            }

            to {
                transform: translate(40px, 30px) scale(1.1);
            }
        }

        .hero-content {
            position: relative;
            z-index: 2;
            width: 100%;
        }

        /* Badge pill */
        .hero-est-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: rgba(255, 255, 255, 0.12);
            border: 1px solid rgba(255, 255, 255, 0.25);
            backdrop-filter: blur(8px);
            color: white;
            padding: 0.45rem 1.2rem;
            border-radius: 999px;
            font-size: 0.8rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            margin-bottom: 1.5rem;
        }

        .hero-est-badge .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #a78bfa;
            animation: pulseDot 2s ease-in-out infinite;
        }

        @keyframes pulseDot {

            0%,
            100% {
                opacity: 1;
                transform: scale(1);
            }

            50% {
                opacity: 0.5;
                transform: scale(0.7);
            }
        }

        /* Main title */
        .hero-title {
            font-size: clamp(2.5rem, 6vw, 5rem);
            font-weight: 900;
            letter-spacing: -0.03em;
            line-height: 1.05;
            background: linear-gradient(135deg, #ffffff 0%, #c4b5fd 50%, #93c5fd 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 1.25rem;
        }

        .hero-tagline {
            font-size: clamp(1rem, 2vw, 1.3rem);
            opacity: 0.8;
            max-width: 620px;
            margin: 0 auto 2rem;
            line-height: 1.7;
            font-weight: 400;
        }

        /* CTA buttons in hero */
        .hero-cta-group {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
            margin-bottom: 3.5rem;
        }

        .hero-btn-primary {
            background: white;
            color: #4f46e5;
            border: none;
            padding: 0.85rem 2rem;
            border-radius: 999px;
            font-weight: 700;
            font-size: 0.95rem;
            text-decoration: none;
            transition: all 0.3s ease;
            box-shadow: 0 8px 24px rgba(255, 255, 255, 0.2);
        }

        .hero-btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 14px 32px rgba(255, 255, 255, 0.3);
            color: #4338ca;
        }

        .hero-btn-outline {
            background: rgba(255, 255, 255, 0.1);
            color: white;
            border: 1px solid rgba(255, 255, 255, 0.3);
            padding: 0.85rem 2rem;
            border-radius: 999px;
            font-weight: 600;
            font-size: 0.95rem;
            text-decoration: none;
            backdrop-filter: blur(6px);
            transition: all 0.3s ease;
        }

        .hero-btn-outline:hover {
            background: rgba(255, 255, 255, 0.2);
            color: white;
            transform: translateY(-3px);
        }

        /* Hero highlighted badge */
        .hero-free-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.6rem;
            background: linear-gradient(135deg, rgba(16, 185, 129, 0.15) 0%, rgba(52, 211, 153, 0.1) 100%);
            border: 1px solid rgba(52, 211, 153, 0.4);
            color: #6ee7b7;
            padding: 0.65rem 1.8rem;
            border-radius: 999px;
            font-size: 0.95rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            position: relative;
            overflow: hidden;
            animation: badgeFadeIn 0.8s ease 0.3s both;
            box-shadow: 0 0 20px rgba(52, 211, 153, 0.15),
                        inset 0 0 20px rgba(52, 211, 153, 0.05);
        }

        .hero-free-badge::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -75%;
            width: 50%;
            height: 200%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
            transform: skewX(-25deg);
            animation: shimmer 3s ease-in-out infinite;
        }

        .hero-free-badge i {
            font-size: 1rem;
            filter: drop-shadow(0 0 4px rgba(52, 211, 153, 0.5));
        }

        @keyframes badgeFadeIn {
            from { opacity: 0; transform: scale(0.9); }
            to   { opacity: 1; transform: scale(1); }
        }

        @keyframes shimmer {
            0%   { left: -75%; }
            100% { left: 125%; }
        }



        /* ── GLASS CARDS ──────────────────────────────────── */
        .glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.1);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .glass-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 48px 0 rgba(31, 38, 135, 0.15);
        }

        .stat-number {
            font-size: 2.5rem;
            font-weight: 800;
            background: var(--primary-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .story-img {
            border-radius: 30px;
            box-shadow: 20px 20px 60px #bebebe, -20px -20px 60px #ffffff;
        }

        .icon-box {
            width: 60px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 16px;
            background: var(--primary-gradient);
            color: white;
            font-size: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .section-title {
            font-weight: 800;
            letter-spacing: -0.02em;
            margin-bottom: 1.5rem;
        }

        @media (max-width: 576px) {
            .hero-free-badge {
                font-size: 0.82rem;
                padding: 0.5rem 1.4rem;
            }
        }
    </style>

    <div class="hero-section">
