<%- include('partials/header') %>

<style>
  :root {
    --primary-glow: #6366f1;
    --accent-glow: #f43f5e;
  }
  
  .store-page {
    background-color: #0f172a;
    background-image: 
      radial-gradient(at 0% 0%, rgba(99, 102, 241, 0.15) 0px, transparent 50%),
      radial-gradient(at 100% 100%, rgba(244, 63, 94, 0.1) 0px, transparent 50%),
      radial-gradient(at 50% 50%, rgba(15, 23, 42, 1) 0px, transparent 100%);
    min-height: 100vh;
    padding-top: 120px;
    padding-bottom: 100px;
    color: #f8fafc;
    font-family: 'Inter', sans-serif;
    position: relative;
    overflow: hidden;
  }

  .store-header h1 {
    font-weight: 900;
    font-size: 3.5rem;
    background: linear-gradient(135deg, #ffffff 0%, #a5b4fc 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .store-subtitle {
    font-size: 1.15rem;
    color: #94a3b8;
    max-width: 600px;
    margin: 0 auto 3rem;
  }

  /* Product Card */
  .product-card {
    position: relative;
    background: rgba(30, 41, 59, 0.4);
    backdrop-filter: blur(25px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.5rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
  }

  .product-card::before {
    content: '';
    position: absolute;
    top: -1px; left: -1px; right: -1px; bottom: -1px;
    background: linear-gradient(135deg, rgba(99,102,241,0.5), transparent, rgba(244,63,94,0.5));
    z-index: -1;
    border-radius: 1.6rem;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .product-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 30px 60px rgba(0,0,0,0.4);
    border-color: rgba(255,255,255,0.15);
  }
  
  .product-card:hover::before {
    opacity: 1;
  }

  .product-image-wrapper {
    position: relative;
    padding: 1.2rem;
    padding-bottom: 0;
  }

  .product-image {
    width: 100%;
    height: 280px;
    object-fit: cover;
    border-radius: 1rem;
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
    box-shadow: 0 10px 20px rgba(0,0,0,0.3);
  }

  .product-card:hover .product-image {
    transform: scale(1.05) rotate(-1deg);
  }

  .tag-bestseller {
    position: absolute;
    top: 2rem;
    right: 2rem;
    background: linear-gradient(45deg, #f43f5e, #fb923c);
    color: white;
    padding: 0.4rem 1.2rem;
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    box-shadow: 0 5px 15px rgba(244, 63, 94, 0.4);
    z-index: 10;
    letter-spacing: 0.5px;
  }

  .product-info {
    padding: 1.5rem 2rem 2rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .product-title {
    font-size: 1.6rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    color: #fff;
  }

  .product-desc {
    color: #94a3b8;
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }

  .product-features {
    list-style: none;
    padding-left: 0;
    margin: 0 0 1.5rem 0;
    font-size: 0.85rem;
    color: #cbd5e1;
  }
  .product-features li {
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
  }
  .product-features li i {
    color: #10b981;
    margin-right: 0.5rem;
    font-size: 0.9rem;
  }

  .price-row {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-top: auto;
    margin-bottom: 1.5rem;
  }

  .price-wrap {
    display: flex;
    align-items: baseline;
  }

  .product-price {
    font-size: 2.2rem;
    font-weight: 900;
    color: #818cf8;
    line-height: 1;
  }

  .product-original-price {
    text-decoration: line-through;
    color: #64748b;
    font-size: 1.1rem;
    margin-left: 0.5rem;
    font-weight: 600;
  }

  .btn-buy-modern {
    background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
    color: white;
    font-weight: 700;
    font-size: 1.05rem;
    border: none;
    border-radius: 999px;
    padding: 0.85rem 2rem;
    width: 100%;
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .btn-buy-modern::before {
    content: '';
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: linear-gradient(135deg, #4f46e5 0%, #4338ca 100%);
    z-index: -1;
    transition: opacity 0.3s ease;
    opacity: 0;
  }

  .btn-buy-modern:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(99, 102, 241, 0.4);
    color: white;
  }
  .btn-buy-modern:hover::before {
    opacity: 1;
  }

  /* Modal Enhancements */
  .modal-dialog {
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) !important;
  }
  .modal.fade .modal-dialog {
    transform: scale(0.9) translateY(20px);
  }
  .modal.show .modal-dialog {
    transform: scale(1) translateY(0);
  }

  .modern-modal-content {
    background: rgba(15, 23, 42, 0.9) !important;
    backdrop-filter: blur(25px);
    border: 1px solid rgba(255, 255, 255, 0.1) !important;
    border-radius: 1.5rem !important;
    box-shadow: 0 0 50px rgba(0,0,0,0.5), inset 0 0 20px rgba(99, 102, 241, 0.05);
    overflow: hidden;
  }
  
  .modern-input-group {
    position: relative;
    margin-bottom: 1.25rem;
  }

  .modern-input-group i {
    position: absolute;
    top: 50%;
    left: 1.2rem;
    transform: translateY(-50%);
    color: #64748b;
    transition: color 0.3s;
    font-size: 1.1rem;
    z-index: 5;
  }

  .modern-input-group textarea + i {
    top: 1.5rem;
  }

  .modern-input {
    background: rgba(255, 255, 255, 0.03) !important;
    border: 1px solid rgba(255, 255, 255, 0.1) !important;
    color: white !important;
    border-radius: 1rem !important;
    padding: 0.85rem 1rem 0.85rem 3rem !important;
    transition: all 0.3s ease;
    font-size: 0.95rem;
  }
  
  .modern-input::placeholder {
    color: #475569;
  }

  .modern-input:focus {
    background: rgba(255, 255, 255, 0.08) !important;
    border-color: #6366f1 !important;
    box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.15) !important;
  }
  
  .modern-input:focus + i, .modern-input-group:focus-within i {
    color: #818cf8;
  }

  /* Success State overlay */
  .success-overlay {
    display: none;
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(15, 23, 42, 0.95);
    backdrop-filter: blur(10px);
    z-index: 100;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    animation: fadeIn 0.4s ease forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .checkmark-circle {
    width: 80px;
    height: 80px;
    background: rgba(16, 185, 129, 0.1);
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 1.5rem;
    box-shadow: 0 0 30px rgba(16, 185, 129, 0.2);
    animation: scaleIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
  }

  @keyframes scaleIn {
    from { transform: scale(0); }
    to { transform: scale(1); }
  }

  .checkmark-circle i {
    color: #10b981;
    font-size: 2.5rem;
  }
</style>

<!-- EmailJS Library -->
<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js"></script>
<script type="text/javascript">
  (function () {
    // IMPORTANT: Replace with your actual EmailJS public key
    emailjs.init("YOUR_PUBLIC_KEY");
  })();
</script>

<div class="store-page">
  <div class="container">
    <div class="store-header text-center">
      <h1><i class="fa-solid fa-store me-3 text-primary" style="font-size: 0.8em"></i>2AM Official Store</h1>
      <p class="store-subtitle">Premium, distraction-free study gear engineered to fuel your longest late-night productivity sessions.</p>
    </div>

    <div class="row g-5 justify-content-center mt-2">
      <!-- Notebook Product -->
      <div class="col-md-6 col-xl-4 col-lg-5">
        <div class="product-card">
          <span class="tag-bestseller">Best Seller</span>
          <div class="product-image-wrapper">
            <img src="https://images.unsplash.com/photo-1544816155-12df9643f363?auto=format&fit=crop&q=80&w=800" alt="2AM Notebook" class="product-image">
          </div>
          <div class="product-info">
            <h3 class="product-title">Deep Focus Notebook</h3>
            <p class="product-desc">A premium dotted journal designed to handle ink without bleeding. Minimalist layout perfectly suited for the 2AM Study method.</p>
            
            <ul class="product-features">
              <li><i class="fa-solid fa-check"></i> 120 GSM thick paper</li>
              <li><i class="fa-solid fa-check"></i> 200 dotted grid pages</li>
              <li><i class="fa-solid fa-check"></i> Lay-flat binding design</li>
            </ul>

            <div class="price-row">
              <div class="price-wrap">
                <span class="product-price">₹199</span>
                <span class="product-original-price">₹399</span>
              </div>
            </div>
            <button class="btn btn-buy-modern" onclick="openCheckoutModal('Deep Focus Notebook', 199, 'https://rzp.io/l/notebook-placeholder')">
              <i class="fa-solid fa-bag-shopping me-2"></i> Get Yours Now
            </button>
          </div>
        </div>
      </div>

      <!-- Bottle Product -->
      <div class="col-md-6 col-xl-4 col-lg-5">
        <div class="product-card">
          <div class="product-image-wrapper">
            <img src="https://images.unsplash.com/photo-1602143407151-7111542de6e8?auto=format&fit=crop&q=80&w=800" alt="2AM Water Bottle" class="product-image">
          </div>
          <div class="product-info">
            <h3 class="product-title">Stay Hydrated Flask</h3>
            <p class="product-desc">Matte black double-insulated steel bottle. Keeps your 2AM coffee steaming hot or your water ice-cold for 24 hours.</p>
            
            <ul class="product-features">
              <li><i class="fa-solid fa-check"></i> 750ml capacity</li>
              <li><i class="fa-solid fa-check"></i> 24h cold / 12h hot insulation</li>
              <li><i class="fa-solid fa-check"></i> Matte slip-resistant finish</li>
            </ul>

            <div class="price-row">
              <div class="price-wrap">
                <span class="product-price">₹299</span>
                <span class="product-original-price">₹599</span>
              </div>
            </div>
            <button class="btn btn-buy-modern" onclick="openCheckoutModal('Stay Hydrated Flask', 299, 'https://rzp.io/l/bottle-placeholder')">
              <i class="fa-solid fa-bag-shopping me-2"></i> Get Yours Now
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Checkout Modal -->
<div class="modal fade" id="checkoutModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content modern-modal-content border-0">
      
      <!-- Success State Overlay inside modal -->
      <div class="success-overlay" id="successOverlay">
        <div class="checkmark-circle">
          <i class="fa-solid fa-check"></i>
        </div>
        <h4 class="text-white fw-bold mb-2">Order Staged!</h4>
        <p class="text-muted small px-4">Redirecting you to our secure payment gateway to complete your purchase...</p>
      </div>

      <div class="modal-header border-bottom border-light border-opacity-10 py-3">
        <h5 class="modal-title fw-bold text-white"><i class="fa-solid fa-shield-halved me-2 text-primary"></i> Secure Checkout</h5>
        <button type="button" class="btn-close btn-close-white opacity-50" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      
      <div class="modal-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-4 p-3 rounded-3" style="background: rgba(99, 102, 241, 0.1); border: 1px dashed rgba(99, 102, 241, 0.3);">
          <div>
            <div class="small text-primary fw-bold text-uppercase mb-1">Selected Item</div>
            <div class="fw-bold text-white fs-5" id="modalProductName">Product Name</div>
          </div>
          <div class="text-end">
            <div class="fs-4 fw-black text-white" id="modalProductPrice">₹0</div>
          </div>
        </div>

        <form id="checkoutForm">
          <div class="modern-input-group">
            <i class="fa-solid fa-user"></i>
            <input type="text" class="form-control modern-input" id="customerName" placeholder="Full Name" required>
          </div>
          
          <div class="modern-input-group">
            <i class="fa-solid fa-phone"></i>
            <input type="tel" class="form-control modern-input" id="customerPhone" placeholder="Phone Number (+91...)" required>
          </div>
          
          <div class="modern-input-group mb-2">
            <i class="fa-solid fa-location-dot"></i>
            <textarea class="form-control modern-input" id="customerAddress" rows="3" placeholder="Complete Delivery Address (Room, Hostel, City, Pincode)" required></textarea>
          </div>
        </form>
        
        <div class="text-center mt-4">
          <p class="small mb-0" style="color: #64748b;"><i class="fa-solid fa-lock text-success me-1"></i> Payments processed securely by Razorpay</p>
        </div>
      </div>
      
      <div class="modal-footer border-top border-light border-opacity-10 p-3">
        <button type="button" class="btn text-muted fw-bold px-4" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-buy-modern w-auto px-5 m-0" id="proceedToPayBtn" onclick="submitOrder()">
          Proceed to Pay <i class="fa-solid fa-arrow-right ms-2"></i>
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  let currentProduct = '';
  let currentPaymentLink = '';
  let checkoutModal;

  document.addEventListener('DOMContentLoaded', () => {
    const modalEl = document.getElementById('checkoutModal');
    if (modalEl) {
      checkoutModal = new bootstrap.Modal(modalEl);
      // Reset overlay when modal closes
      modalEl.addEventListener('hidden.bs.modal', function () {
        document.getElementById('successOverlay').style.display = 'none';
      });
    }
  });

  function openCheckoutModal(productName, price, paymentLink) {
    currentProduct = productName;
    currentPaymentLink = paymentLink;
    
    document.getElementById('modalProductName').textContent = productName;
    document.getElementById('modalProductPrice').textContent = '₹' + price;
    
    document.getElementById('checkoutForm').reset();
    document.getElementById('successOverlay').style.display = 'none';
    
    if (checkoutModal) {
      checkoutModal.show();
    }
  }

  function submitOrder() {
    const form = document.getElementById('checkoutForm');
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const btn = document.getElementById('proceedToPayBtn');
    const originalText = btn.innerHTML;
    
    const name = document.getElementById('customerName').value;
    const phone = document.getElementById('customerPhone').value;
    const address = document.getElementById('customerAddress').value;

    // Loading State
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> Securing Order...';
    btn.disabled = true;

    // Send data using EmailJS
    emailjs.send("YOUR_SERVICE_ID", "YOUR_TEMPLATE_ID", {
      product_name: currentProduct,
      customer_name: name,
      customer_phone: phone,
      customer_address: address,
    }).then(function(response) {
      showSuccessAndRedirect();
    }, function(error) {
      console.log('EmailJS failed', error);
      // Fallback for testing without keys
      showSuccessAndRedirect();
    }).finally(() => {
      btn.innerHTML = originalText;
      btn.disabled = false;
    });
  }

  function showSuccessAndRedirect() {
    const overlay = document.getElementById('successOverlay');
    overlay.style.display = 'flex';
    
    // Smooth delay before redirecting to Razorpay
    setTimeout(() => {
      window.location.href = currentPaymentLink;
    }, 1500);
  }
</script>

<%- include('partials/footer') %>
