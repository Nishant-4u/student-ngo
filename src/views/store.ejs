<%- include('partials/header') %>

<style>
  .store-page {
    background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
    min-height: 100vh;
    padding-top: 100px;
    padding-bottom: 80px;
    color: #f8fafc;
    font-family: 'Inter', sans-serif;
  }

  .store-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .store-header .display-4 {
    font-weight: 800;
    letter-spacing: -1px;
    text-shadow: 0 0 30px rgba(99, 102, 241, 0.4);
  }

  .product-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1.5rem;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .product-card:hover {
    border-color: rgba(99, 102, 241, 0.4);
    background: rgba(255, 255, 255, 0.07);
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  }

  .product-image-container {
    height: 250px;
    overflow: hidden;
    position: relative;
  }

  .product-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .product-card:hover .product-image {
    transform: scale(1.05);
  }

  .product-info {
    padding: 2rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .product-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .product-price {
    font-size: 1.75rem;
    font-weight: 800;
    color: #818cf8;
    margin-bottom: 1.5rem;
  }

  .btn-buy-now {
    background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
    color: white;
    font-weight: 600;
    border: none;
    border-radius: 0.75rem;
    padding: 0.75rem 1.5rem;
    width: 100%;
    transition: all 0.3s ease;
    margin-top: auto;
  }

  .btn-buy-now:hover {
    background: linear-gradient(135deg, #818cf8 0%, #6366f1 100%);
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.5);
    transform: scale(1.02);
  }

  /* Modal Form Styling */
  .modal-content.dark-modal {
    background: #1e293b;
    color: #f1f5f9;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  }

  .dark-modal .modal-header {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .dark-modal .modal-footer {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .dark-input {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: white;
    border-radius: 0.5rem;
  }

  .dark-input:focus {
    background: rgba(255, 255, 255, 0.1);
    border-color: #6366f1;
    color: white;
    box-shadow: 0 0 0 0.25rem rgba(99, 102, 241, 0.25);
  }

  .modal-backdrop.show {
    opacity: 0.8;
    backdrop-filter: blur(4px);
  }
</style>

<!-- EmailJS Library -->
<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js"></script>
<script type="text/javascript">
  (function () {
    // IMPORTANT: Replace YOUR_PUBLIC_KEY with your actual EmailJS public key
    emailjs.init("YOUR_PUBLIC_KEY");
  })();
</script>

<div class="store-page">
  <div class="container">
    <div class="store-header">
      <h1 class="display-4"><i class="fa-solid fa-store me-2 text-primary"></i>2AM Official Store</h1>
      <p class="text-muted lead">Premium study gear to fuel your late-night productivity sessions.</p>
    </div>

    <div class="row g-4 justify-content-center mt-3">
      <!-- Notebook Product -->
      <div class="col-md-6 col-lg-4">
        <div class="product-card">
          <div class="product-image-container">
            <!-- Notebook Image -->
            <img src="https://images.unsplash.com/photo-1544816155-12df9643f363?auto=format&fit=crop&q=80&w=800" alt="2AM Notebook" class="product-image">
          </div>
          <div class="product-info">
            <h3 class="product-title">Focus Notebook</h3>
            <p class="text-muted small">High-quality 120 GSM dotted journal. Perfect for taking notes, planning tasks, or tracking your study streaks.</p>
            <div class="product-price">₹199</div>
            <button class="btn btn-buy-now" onclick="openCheckoutModal('Focus Notebook', 199, 'https://rzp.io/l/notebook-placeholder')">
              <i class="fa-solid fa-cart-shopping me-2"></i>Buy Now
            </button>
          </div>
        </div>
      </div>

      <!-- Bottle Product -->
      <div class="col-md-6 col-lg-4">
        <div class="product-card">
          <div class="product-image-container">
            <!-- Bottle Image -->
            <img src="https://images.unsplash.com/photo-1602143407151-7111542de6e8?auto=format&fit=crop&q=80&w=800" alt="2AM Water Bottle" class="product-image">
          </div>
          <div class="product-info">
            <h3 class="product-title">Stay Hydrated Bottle</h3>
            <p class="text-muted small">Matte black aesthetic insulated steel bottle. Keeps your water cold or coffee hot for your longest study runs.</p>
            <div class="product-price">₹299</div>
            <button class="btn btn-buy-now" onclick="openCheckoutModal('Stay Hydrated Bottle', 299, 'https://rzp.io/l/bottle-placeholder')">
              <i class="fa-solid fa-cart-shopping me-2"></i>Buy Now
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Checkout Modal -->
<div class="modal fade" id="checkoutModal" tabindex="-1" aria-labelledby="checkoutModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content dark-modal">
      <div class="modal-header border-bottom border-light border-opacity-10">
        <h5 class="modal-title fw-bold" id="checkoutModalLabel">Complete Your Order</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4">
        <div class="alert alert-info bg-primary bg-opacity-10 border-primary border-opacity-20 text-white mb-4">
          <div class="d-flex justify-content-between align-items-center">
            <span class="fw-bold" id="modalProductName">Product Name</span>
            <span class="badge bg-primary fs-6" id="modalProductPrice">₹0</span>
          </div>
        </div>

        <form id="checkoutForm">
          <div class="mb-3">
            <label for="customerName" class="form-label text-muted small fw-bold text-uppercase">Full Name</label>
            <input type="text" class="form-control dark-input" id="customerName" placeholder="Nishant Sharma" required>
          </div>
          <div class="mb-3">
            <label for="customerPhone" class="form-label text-muted small fw-bold text-uppercase">Phone Number</label>
            <input type="tel" class="form-control dark-input" id="customerPhone" placeholder="+91 9876543210" required>
          </div>
          <div class="mb-4">
            <label for="customerAddress" class="form-label text-muted small fw-bold text-uppercase">Delivery Address</label>
            <textarea class="form-control dark-input" id="customerAddress" rows="3" placeholder="Room No., Hostel/Apartment, Street Name, City, Pincode" required></textarea>
          </div>
        </form>
        <p class="small text-muted text-center mb-0"><i class="fa-solid fa-lock me-1"></i>Secure checkout processing via Razorpay</p>
      </div>
      <div class="modal-footer border-top border-light border-opacity-10">
        <button type="button" class="btn btn-outline-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-buy-now rounded-pill w-auto px-5 m-0" id="proceedToPayBtn" onclick="submitOrder()">Proceed to Pay</button>
      </div>
    </div>
  </div>
</div>

<script>
  let currentProduct = '';
  let currentPaymentLink = '';
  let checkoutModal;

  document.addEventListener('DOMContentLoaded', () => {
    // Initialize bootstrap modal
    const modalEl = document.getElementById('checkoutModal');
    if (modalEl) {
      checkoutModal = new bootstrap.Modal(modalEl);
    }
  });

  function openCheckoutModal(productName, price, paymentLink) {
    currentProduct = productName;
    currentPaymentLink = paymentLink;
    
    document.getElementById('modalProductName').textContent = productName;
    document.getElementById('modalProductPrice').textContent = '₹' + price;
    
    // Reset form
    document.getElementById('checkoutForm').reset();
    
    if (checkoutModal) {
      checkoutModal.show();
    }
  }

  function submitOrder() {
    const form = document.getElementById('checkoutForm');
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const btn = document.getElementById('proceedToPayBtn');
    const originalText = btn.innerHTML;
    
    const name = document.getElementById('customerName').value;
    const phone = document.getElementById('customerPhone').value;
    const address = document.getElementById('customerAddress').value;

    btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Processing...';
    btn.disabled = true;

    // Send data using EmailJS
    // IMPORTANT: Replace 'YOUR_SERVICE_ID' and 'YOUR_TEMPLATE_ID' with actual EmailJS IDs.
    // The template should expect variables: {{product_name}}, {{customer_name}}, {{customer_phone}}, {{customer_address}}
    emailjs.send("YOUR_SERVICE_ID", "YOUR_TEMPLATE_ID", {
      product_name: currentProduct,
      customer_name: name,
      customer_phone: phone,
      customer_address: address,
    }).then(function(response) {
      // Success, redirect to Razorpay
      console.log('Order submitted!', response.status, response.text);
      window.location.href = currentPaymentLink;
    }, function(error) {
      // In case EmailJS fails (e.g. invalid keys during testing), we can still show an alert and redirect for testing.
      console.log('EmailJS failed, probably missing keys.', error);
      alert("Note: EmailJS keys need to be setup to receive order emails. Redirecting to payment...");
      window.location.href = currentPaymentLink;
    }).finally(() => {
      btn.innerHTML = originalText;
      btn.disabled = false;
      if (checkoutModal) {
        checkoutModal.hide();
      }
    });
  }
</script>

<%- include('partials/footer') %>
