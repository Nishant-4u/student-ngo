<%- include('partials/header') %>

<style>
/* ════════════════════════════════════════════════
   2AM STUDY — STORE  (Dark Premium E-commerce)
   ════════════════════════════════════════════════ */
:root {
  --s-bg:       #080810;
  --s-card:     #0f0f1a;
  --s-card-h:   #141425;
  --s-border:   rgba(255,255,255,0.07);
  --s-accent:   #6366f1;
  --s-accent2:  #a855f7;
  --s-green:    #10b981;
  --s-gold:     #f59e0b;
  --s-red:      #ef4444;
  --s-text:     #e2e8f0;
  --s-muted:    #64748b;
}

/* ── Page Base ─────────────────────────────────── */
.store-page { background: var(--s-bg); min-height:100vh; color:var(--s-text); padding-top:80px; }

/* ── Top Banner ────────────────────────────────── */
.store-topbar {
  background: linear-gradient(90deg, #4f46e5 0%, #7c3aed 100%);
  text-align: center;
  padding: 0.55rem 1rem;
  font-size: 0.82rem;
  font-weight: 600;
  color: #fff;
  letter-spacing: 0.04em;
}
.store-topbar a { color:#fde68a; text-decoration:none; }

/* ── Hero ──────────────────────────────────────── */
.store-hero {
  background: linear-gradient(135deg, #0f0c29, #1e1b4b, #0f172a);
  padding: 60px 0 48px;
  position: relative;
  overflow: hidden;
  border-bottom: 1px solid var(--s-border);
}
.store-hero::before {
  content:'';
  position:absolute; inset:0;
  background: radial-gradient(ellipse at 15% 60%, rgba(99,102,241,.22) 0%, transparent 55%),
              radial-gradient(ellipse at 85% 30%, rgba(168,85,247,.15) 0%, transparent 50%);
}
.store-hero-inner { position:relative; z-index:1; }

.hero-tag {
  display:inline-flex; align-items:center; gap:.4rem;
  background:rgba(99,102,241,.14); border:1px solid rgba(99,102,241,.35);
  color:#a5b4fc; padding:.28rem 1rem; border-radius:999px;
  font-size:.75rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase;
  margin-bottom:1rem;
}

.store-hero h1 {
  font-size:clamp(1.9rem,5vw,3.2rem); font-weight:900; letter-spacing:-.03em;
  background:linear-gradient(135deg,#fff 0%,#c7d2fe 55%,#a78bfa 100%);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
  margin-bottom:.5rem;
}
.store-hero p { color:#94a3b8; font-size:1rem; max-width:530px; }

/* ── Search + Sort row ─────────────────────────── */
.toolbar {
  display:flex; align-items:center; gap:1rem; flex-wrap:wrap;
  padding:1.25rem 0;
  border-bottom: 1px solid var(--s-border);
  margin-bottom:1.5rem;
}
.search-wrap {
  display:flex; align-items:center;
  background:rgba(255,255,255,.05); border:1px solid var(--s-border);
  border-radius:12px; padding:.52rem 1rem; gap:.6rem; flex:1; min-width:200px;
  transition:.25s;
}
.search-wrap:focus-within {
  border-color:rgba(99,102,241,.5); background:rgba(255,255,255,.07);
  box-shadow:0 0 0 3px rgba(99,102,241,.1);
}
.search-wrap input {
  background:transparent; border:none; outline:none; color:#fff; font-size:.9rem; flex:1;
}
.search-wrap input::placeholder { color:#475569; }

.sort-select {
  background:rgba(255,255,255,.05); border:1px solid var(--s-border);
  color:#cbd5e1; border-radius:12px; padding:.52rem 1rem;
  font-size:.85rem; font-weight:600; cursor:pointer; outline:none;
  transition:.2s;
}
.sort-select:focus { border-color:rgba(99,102,241,.5); }
.sort-select option { background:#1e293b; }

.results-count { color:var(--s-muted); font-size:.82rem; white-space:nowrap; }

/* ── Layout: sidebar + grid ─────────────────────── */
.store-layout { display:grid; grid-template-columns:230px 1fr; gap:2rem; align-items:start; }

/* ── Category Sidebar ──────────────────────────── */
.cat-sidebar {
  background:var(--s-card); border:1px solid var(--s-border);
  border-radius:20px; overflow:hidden; position:sticky; top:90px;
}
.cat-sidebar-head {
  padding:1.1rem 1.25rem;
  border-bottom:1px solid var(--s-border);
  font-size:.72rem; font-weight:800; letter-spacing:.12em;
  text-transform:uppercase; color:var(--s-muted);
}
.cat-item {
  display:flex; align-items:center; gap:.75rem;
  padding:.85rem 1.25rem;
  border-bottom:1px solid var(--s-border);
  cursor:pointer; transition:.2s; text-decoration:none;
  color:var(--s-muted); font-weight:600; font-size:.9rem;
  border-left: 3px solid transparent;
}
.cat-item:last-child { border-bottom:0; }
.cat-item:hover { color:#a5b4fc; background:rgba(99,102,241,.06); border-left-color:rgba(99,102,241,.3); }
.cat-item.active { color:#a5b4fc; background:rgba(99,102,241,.1); border-left-color:var(--s-accent); }
.cat-icon { font-size:1.2rem; }
.cat-count {
  margin-left:auto; background:rgba(255,255,255,.06);
  color:var(--s-muted); font-size:.7rem; font-weight:700;
  padding:.15rem .55rem; border-radius:999px;
}

/* ── Price Filter ──────────────────────────────── */
.price-filter { padding:1.25rem; border-top:1px solid var(--s-border); }
.price-filter h6 { font-size:.72rem; font-weight:800; letter-spacing:.1em; text-transform:uppercase; color:var(--s-muted); margin-bottom:.75rem; }
.price-btn {
  display:block; width:100%; text-align:left;
  background:transparent; border:none; color:var(--s-muted);
  font-size:.85rem; font-weight:600; padding:.4rem .5rem;
  border-radius:8px; cursor:pointer; transition:.15s;
}
.price-btn:hover,.price-btn.active { color:#a5b4fc; background:rgba(99,102,241,.08); }

/* ── Product Grid ──────────────────────────────── */
.products-grid {
  display:grid; grid-template-columns:repeat(auto-fill, minmax(228px,1fr)); gap:1.25rem;
}

/* ── Product Card ──────────────────────────────── */
.p-card {
  background:var(--s-card); border:1px solid var(--s-border); border-radius:18px;
  overflow:hidden; transition:.3s cubic-bezier(.4,0,.2,1); position:relative;
  display:flex; flex-direction:column;
}
.p-card:hover {
  transform:translateY(-5px); border-color:rgba(99,102,241,.3);
  box-shadow:0 16px 40px rgba(0,0,0,.5), 0 0 0 1px rgba(99,102,241,.08);
  background:var(--s-card-h);
}

.p-img {
  aspect-ratio:1; overflow:hidden;
  background:linear-gradient(135deg,#1e1b4b,#1e293b);
  display:flex; align-items:center; justify-content:center;
  position:relative;
}
.p-emoji { font-size:5.5rem; line-height:1; transition:.4s; filter:drop-shadow(0 8px 20px rgba(0,0,0,.4)); }
.p-card:hover .p-emoji { transform:scale(1.12) rotate(-4deg); }

/* Badges */
.p-badge {
  position:absolute; top:10px; left:10px;
  padding:.22rem .7rem; border-radius:999px;
  font-size:.68rem; font-weight:800; text-transform:uppercase; letter-spacing:.05em;
}
.badge-sale   { background:rgba(239,68,68,.15);  color:#fca5a5; border:1px solid rgba(239,68,68,.3); }
.badge-new    { background:rgba(16,185,129,.15); color:#6ee7b7; border:1px solid rgba(16,185,129,.3); }
.badge-hot    { background:rgba(245,158,11,.15); color:#fcd34d; border:1px solid rgba(245,158,11,.3); }
.badge-top    { background:rgba(99,102,241,.15); color:#a5b4fc; border:1px solid rgba(99,102,241,.3); }

/* Wishlist */
.p-heart {
  position:absolute; top:10px; right:10px;
  width:32px; height:32px; border-radius:50%;
  background:rgba(0,0,0,.45); border:1px solid rgba(255,255,255,.1);
  display:flex; align-items:center; justify-content:center;
  cursor:pointer; transition:.2s; color:#475569; font-size:.82rem;
}
.p-heart:hover,.p-heart.on { background:rgba(239,68,68,.2); color:#f87171; border-color:rgba(239,68,68,.3); }

/* Info */
.p-info { padding:1.1rem; flex:1; display:flex; flex-direction:column; }
.p-cat   { font-size:.65rem; font-weight:800; text-transform:uppercase; letter-spacing:.1em; color:var(--s-accent); margin-bottom:.3rem; }
.p-name  { font-size:.95rem; font-weight:700; color:#f1f5f9; line-height:1.3; margin-bottom:.35rem; }
.p-desc  { font-size:.8rem; color:var(--s-muted); line-height:1.5; margin-bottom:.75rem; flex:1; }

/* Rating */
.p-stars { display:flex; align-items:center; gap:.3rem; margin-bottom:.75rem; font-size:.78rem; }
.stars-gold { color:#f59e0b; }
.rev-count  { color:var(--s-muted); }

/* Price row */
.p-footer { display:flex; align-items:center; justify-content:space-between; gap:.5rem; }
.p-price  { display:flex; align-items:baseline; gap:.35rem; flex-wrap:wrap; }
.price-now  { font-size:1.2rem; font-weight:800; color:#f1f5f9; }
.price-was  { font-size:.8rem; color:#475569; text-decoration:line-through; }
.price-off  {
  font-size:.65rem; font-weight:800;
  background:rgba(16,185,129,.12); color:#34d399;
  border:1px solid rgba(16,185,129,.25); padding:.1rem .4rem; border-radius:999px;
}

/* Cart button */
.btn-cart {
  display:inline-flex; align-items:center; gap:.4rem;
  background:var(--s-accent); color:#fff; border:none;
  border-radius:999px; padding:.5rem 1rem;
  font-size:.78rem; font-weight:700; cursor:pointer;
  transition:.25s; white-space:nowrap;
}
.btn-cart:hover { background:#4f46e5; transform:scale(1.05); box-shadow:0 6px 14px rgba(99,102,241,.35); }
.btn-cart.added { background:var(--s-green); }
.btn-cart.added:hover { background:#059669; }

/* ── Cart Drawer ───────────────────────────────── */
.cart-overlay {
  position:fixed; inset:0; background:rgba(0,0,0,.65); backdrop-filter:blur(8px);
  z-index:9998; opacity:0; pointer-events:none; transition:.3s;
}
.cart-overlay.open { opacity:1; pointer-events:all; }

.cart-drawer {
  position:fixed; top:0; right:-420px; width:420px; max-width:100vw; height:100%;
  background:#0d0d1a; border-left:1px solid var(--s-border);
  z-index:9999; display:flex; flex-direction:column;
  transition:.4s cubic-bezier(.16,1,.3,1); box-shadow:-20px 0 60px rgba(0,0,0,.6);
}
.cart-drawer.open { right:0; }

.cart-head {
  display:flex; align-items:center; justify-content:space-between;
  padding:1.25rem 1.5rem; border-bottom:1px solid var(--s-border);
}
.cart-head h5 { font-weight:800; color:#f1f5f9; margin:0; font-size:1.1rem; }
.cart-close {
  width:36px; height:36px; border-radius:50%; border:1px solid var(--s-border);
  background:rgba(255,255,255,.04); color:#94a3b8; cursor:pointer;
  display:flex; align-items:center; justify-content:center; transition:.2s;
}
.cart-close:hover { background:rgba(239,68,68,.1); color:#f87171; }

.cart-body { flex:1; overflow-y:auto; padding:1rem 1.5rem; }

.cart-empty {
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  height:100%; gap:1rem; color:var(--s-muted); text-align:center;
}
.cart-empty i { font-size:3.5rem; opacity:.3; }

/* Cart item */
.cart-item {
  display:flex; gap:1rem; align-items:flex-start;
  padding:1rem 0; border-bottom:1px solid var(--s-border);
}
.ci-emoji { font-size:2.8rem; line-height:1; flex-shrink:0; }
.ci-info  { flex:1; }
.ci-name  { font-size:.9rem; font-weight:700; color:#f1f5f9; margin-bottom:.2rem; }
.ci-price { font-size:.85rem; color:var(--s-accent); font-weight:700; margin-bottom:.5rem; }

/* Quantity control */
.qty-ctrl { display:flex; align-items:center; gap:.5rem; }
.qty-btn {
  width:28px; height:28px; border-radius:8px; border:1px solid var(--s-border);
  background:rgba(255,255,255,.05); color:#fff; cursor:pointer;
  display:flex; align-items:center; justify-content:center; font-size:.9rem;
  transition:.15s;
}
.qty-btn:hover { background:rgba(99,102,241,.15); border-color:rgba(99,102,241,.3); }
.qty-val { min-width:24px; text-align:center; font-weight:700; color:#f1f5f9; font-size:.9rem; }
.ci-remove {
  background:transparent; border:none; color:#475569; cursor:pointer;
  font-size:.8rem; padding:.2rem; transition:.2s;
}
.ci-remove:hover { color:#f87171; }

/* Cart footer */
.cart-foot { padding:1.25rem 1.5rem; border-top:1px solid var(--s-border); }
.cart-summary { display:flex; justify-content:space-between; align-items:baseline; margin-bottom:.4rem; }
.cart-summary .label { color:var(--s-muted); font-size:.85rem; }
.cart-summary .val   { color:#f1f5f9; font-weight:800; font-size:1.2rem; }
.cart-summary .small { font-size:.75rem; color:var(--s-green); }
.btn-checkout {
  display:flex; align-items:center; justify-content:center; gap:.6rem;
  width:100%; background:#25D366; color:#fff; border:none;
  border-radius:14px; padding:1rem; font-size:1rem; font-weight:800;
  cursor:pointer; transition:.25s; margin-top:.75rem; text-decoration:none;
}
.btn-checkout:hover { background:#1ebe5d; transform:translateY(-2px); box-shadow:0 8px 24px rgba(37,211,102,.3); color:#fff; }
.btn-clear {
  display:block; width:100%; margin-top:.6rem; background:transparent;
  border:1px solid var(--s-border); color:var(--s-muted); border-radius:10px;
  padding:.6rem; font-size:.82rem; font-weight:600; cursor:pointer; transition:.2s;
}
.btn-clear:hover { background:rgba(239,68,68,.08); border-color:rgba(239,68,68,.2); color:#f87171; }

/* Cart badge */
.cart-fab {
  position:fixed; bottom:90px; right:24px; z-index:999;
  background:var(--s-accent); color:#fff; border:none;
  width:56px; height:56px; border-radius:50%; font-size:1.3rem;
  cursor:pointer; box-shadow:0 8px 24px rgba(99,102,241,.5);
  transition:.25s; display:flex; align-items:center; justify-content:center;
}
.cart-fab:hover { transform:scale(1.1); background:#4f46e5; }
.cart-badge {
  position:absolute; top:-6px; right:-6px;
  width:22px; height:22px; background:#ef4444; color:#fff;
  border-radius:50%; font-size:.68rem; font-weight:800;
  display:flex; align-items:center; justify-content:center;
  border:2px solid var(--s-bg);
}
.cart-badge:empty, .cart-badge[data-count="0"] { display:none; }

/* ── No Results ────────────────────────────────── */
.no-results {
  grid-column:1/-1; text-align:center;
  padding:5rem 2rem; color:var(--s-muted);
}
.no-results i { font-size:3.5rem; opacity:.3; display:block; margin-bottom:1rem; }

/* ── Responsive ────────────────────────────────── */
@media (max-width:900px) {
  .store-layout { grid-template-columns:1fr; }
  .cat-sidebar { position:static; display:flex; flex-wrap:wrap; border-radius:16px; }
  .cat-sidebar-head { width:100%; }
  .cat-item { border-bottom:0; border-right:1px solid var(--s-border); flex:1; justify-content:center; min-width:120px; border-left:0; border-top:3px solid transparent; }
  .cat-item.active { border-top-color:var(--s-accent); border-left-color:transparent; }
  .cat-count { display:none; }
  .price-filter { display:none; }
}
@media (max-width:540px) {
  .products-grid { grid-template-columns:1fr 1fr; gap:.8rem; }
  .p-emoji { font-size:3.8rem; }
  .p-name { font-size:.88rem; }
  .cart-drawer { width:100%; }
}
</style>

<!-- ╔══════════════════════════════════════╗ -->
<!-- ║           CART DRAWER                ║ -->
<!-- ╚══════════════════════════════════════╝ -->
<div class="cart-overlay" id="cartOverlay" onclick="closeCart()"></div>
<div class="cart-drawer" id="cartDrawer">
  <div class="cart-head">
    <h5><i class="fa-solid fa-bag-shopping me-2" style="color:var(--s-accent)"></i> Your Cart <span id="cartCountHead" style="color:var(--s-muted);font-size:.85rem;font-weight:500;"></span></h5>
    <button class="cart-close" onclick="closeCart()"><i class="fa-solid fa-xmark"></i></button>
  </div>
  <div class="cart-body" id="cartBody"></div>
  <div class="cart-foot" id="cartFoot" style="display:none;">
    <div class="cart-summary">
      <span class="label">Subtotal</span>
      <div>
        <span class="val" id="cartTotal">₹0</span>
        <div class="small" id="cartFreeShip"></div>
      </div>
    </div>
    <a href="#" class="btn-checkout" id="waBtn" target="_blank">
      <i class="fa-brands fa-whatsapp fa-lg"></i> Order via WhatsApp
    </a>
    <button class="btn-clear" onclick="clearCart()">Clear Cart</button>
  </div>
</div>

<!-- Cart FAB -->
<button class="cart-fab" onclick="openCart()" title="View Cart">
  <i class="fa-solid fa-bag-shopping"></i>
  <span class="cart-badge" id="cartBadge">0</span>
</button>

<!-- ═══════════════════════════════════════════════════════ -->
<!--                    PAGE CONTENT                        -->
<!-- ═══════════════════════════════════════════════════════ -->
<div class="store-page">

  <!-- Top promo bar -->
  <div class="store-topbar">
    🚚 Free delivery on orders above ₹499 &nbsp;|&nbsp; 
    Order via WhatsApp: <a href="tel:+917250395555">+91 72503 95555</a> &nbsp;|&nbsp;
    <a href="mailto:support@2amstudy.online">support@2amstudy.online</a>
  </div>

  <!-- Hero -->
  <div class="store-hero">
    <div class="container store-hero-inner">
      <div class="row align-items-center g-4">
        <div class="col-lg-8">
          <span class="hero-tag"><i class="fa-solid fa-store me-1"></i> 2AM Study Store</span>
          <h1>Everything a Student Needs</h1>
          <p>Notebooks, Bottles, Bags & Study Essentials — curated for students who refuse to give up at 2 AM.</p>
        </div>
        <div class="col-lg-4 text-center d-none d-lg-flex justify-content-end gap-4 align-items-center">
          <div style="text-align:center;">
            <div style="font-size:4rem;">📚</div>
            <div style="font-size:.72rem;color:#64748b;margin-top:.3rem;font-weight:700;">200+ Items</div>
          </div>
          <div style="text-align:center;">
            <div style="font-size:4rem;">🚚</div>
            <div style="font-size:.72rem;color:#64748b;margin-top:.3rem;font-weight:700;">Pan India</div>
          </div>
          <div style="text-align:center;">
            <div style="font-size:4rem;">🔒</div>
            <div style="font-size:.72rem;color:#64748b;margin-top:.3rem;font-weight:700;">Secure Order</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Main -->
  <div class="container py-4">

    <!-- Toolbar -->
    <div class="toolbar">
      <div class="search-wrap">
        <i class="fa-solid fa-magnifying-glass" style="color:#475569;font-size:.85rem;"></i>
        <input id="searchInput" type="text" placeholder="Search notebooks, bottles, bags…" oninput="applyFilters()" autocomplete="off">
      </div>
      <select class="sort-select" id="sortSelect" onchange="applyFilters()">
        <option value="default">Sort: Featured</option>
        <option value="price-asc">Price: Low → High</option>
        <option value="price-desc">Price: High → Low</option>
        <option value="rating">Top Rated</option>
        <option value="discount">Biggest Discount</option>
      </select>
      <span class="results-count" id="resultCount"></span>
    </div>

    <div class="store-layout">

      <!-- ── Sidebar ────────────────────────────── -->
      <aside>
        <div class="cat-sidebar">
          <div class="cat-sidebar-head">Categories</div>
          <div class="cat-item active" data-cat="all" onclick="setCat('all',this)">
            <span class="cat-icon">🛍️</span> All Products <span class="cat-count" id="cnt-all">0</span>
          </div>
          <div class="cat-item" data-cat="notebooks" onclick="setCat('notebooks',this)">
            <span class="cat-icon">📓</span> Notebooks <span class="cat-count" id="cnt-notebooks">0</span>
          </div>
          <div class="cat-item" data-cat="bottles" onclick="setCat('bottles',this)">
            <span class="cat-icon">💧</span> Water Bottles <span class="cat-count" id="cnt-bottles">0</span>
          </div>
          <div class="cat-item" data-cat="bags" onclick="setCat('bags',this)">
            <span class="cat-icon">🎒</span> College Bags <span class="cat-count" id="cnt-bags">0</span>
          </div>
          <div class="cat-item" data-cat="essentials" onclick="setCat('essentials',this)">
            <span class="cat-icon">✏️</span> Study Essentials <span class="cat-count" id="cnt-essentials">0</span>
          </div>

          <!-- Price Filter -->
          <div class="price-filter">
            <h6>Filter by Price</h6>
            <button class="price-btn active" data-price="all"    onclick="setPrice('all',this)">All Prices</button>
            <button class="price-btn"       data-price="u200"   onclick="setPrice('u200',this)">Under ₹200</button>
            <button class="price-btn"       data-price="200-500" onclick="setPrice('200-500',this)">₹200 – ₹500</button>
            <button class="price-btn"       data-price="500-1000" onclick="setPrice('500-1000',this)">₹500 – ₹1,000</button>
            <button class="price-btn"       data-price="o1000"  onclick="setPrice('o1000',this)">Above ₹1,000</button>
          </div>
        </div>
      </aside>

      <!-- ── Products ─────────────────────────── -->
      <div>
        <div class="products-grid" id="productsGrid"></div>
        <div class="no-results" id="noResults" style="display:none;">
          <i class="fa-solid fa-box-open"></i>
          No products match your filter. Try adjusting your search.
        </div>
      </div>

    </div>
  </div>
</div>

<!-- ═══════════════════════════════════ SCRIPT ══════════════════════════ -->
<script>
/* ── Product Catalogue ─────────────────────────────────────────────── */
const PRODUCTS = [

