// ── State ──────────────────────────────────────────────────────────
let currentFilter = 'all';
let currentProduct = null;

// ── Render ──────────────────────────────────────────────────────────
function renderProducts(list) {
  const grid = document.getElementById('productsGrid');
  const noRes = document.getElementById('noResults');

  if (!list.length) {
    grid.innerHTML = '';
    noRes.style.display = 'block';
    return;
  }
  noRes.style.display = 'none';

  grid.innerHTML = list.map(p => {
    const isWishlisted = (JSON.parse(localStorage.getItem('2am_wishlist') || '[]')).includes(p.id);
    const stars = '★'.repeat(Math.round(p.rating)) + '☆'.repeat(5 - Math.round(p.rating));
    const badgeHtml = p.badge ? `<span class="product-badge badge-${p.badge}">${p.badgeLabel}</span>` : '';
    const origHtml  = p.original && p.original !== p.price ? `<span class="price-original">₹${p.original}</span>` : '';
    const discHtml  = p.original && p.original > p.price && p.price > 0
      ? `<span class="price-discount">${Math.round((p.original - p.price)*100/p.original)}% off</span>` : '';

    const priceHtml = p.price === 0
      ? `<span class="price-free">FREE</span>`
      : `<div class="product-price"><span class="price-current">₹${p.price}</span>${origHtml}${discHtml}</div>`;

    const btnHtml = p.link
      ? `<a href="${p.link}" class="btn-buy btn-buy-green"><i class="fa-solid fa-arrow-right fa-xs"></i> Open</a>`
      : p.price === 0
        ? `<button class="btn-buy btn-buy-green" onclick="event.stopPropagation(); downloadProduct(${p.id})"><i class="fa-solid fa-download fa-xs"></i> Get Free</button>`
        : `<button class="btn-buy" onclick="event.stopPropagation(); openOrder(${p.id})"><i class="fa-solid fa-bag-shopping fa-xs"></i> Order</button>`;

    return `
    <div class="product-card" data-id="${p.id}" data-cat="${p.cat}">
      <div class="product-image-wrap">
        <span class="product-emoji">${p.emoji}</span>
        ${badgeHtml}
        <button class="product-wishlist ${isWishlisted ? 'active' : ''}" onclick="event.stopPropagation(); toggleWishlist(${p.id}, this)" title="Add to wishlist">
          <i class="fa-${isWishlisted ? 'solid' : 'regular'} fa-heart"></i>
        </button>
      </div>
      <div class="product-info">
        <div class="product-category">${p.cat.charAt(0).toUpperCase() + p.cat.slice(1)}</div>
        <div class="product-name">${p.name}</div>
        <div class="product-desc">${p.desc}</div>
        <div class="product-rating">
          <span class="stars">${stars}</span>
          <span style="color:#f59e0b; font-weight:700;">${p.rating}</span>
          <span class="rating-count">(${p.reviews})</span>
        </div>
        <div class="product-footer">
          ${priceHtml}
          ${btnHtml}
        </div>
      </div>
    </div>`;
  }).join('');
}

// ── Filter ─────────────────────────────────────────────────────────
function setFilter(cat, btn) {
  currentFilter = cat;
  document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  filterAll();
}

function filterAll() {
  const query = (document.getElementById('globalSearch')?.value || '').toLowerCase().trim();
  let list = currentFilter === 'all' ? PRODUCTS : PRODUCTS.filter(p => p.cat === currentFilter);
  if (query) {
    list = list.filter(p =>
      p.name.toLowerCase().includes(query) ||
      p.desc.toLowerCase().includes(query) ||
      (p.tags || []).some(t => t.includes(query))
    );
  }
  renderProducts(list);
}

// ── Wishlist ───────────────────────────────────────────────────────
function toggleWishlist(id, btn) {
  let wl = JSON.parse(localStorage.getItem('2am_wishlist') || '[]');
  const idx = wl.indexOf(id);
  if (idx === -1) {
    wl.push(id);
    btn.classList.add('active');
    btn.innerHTML = '<i class="fa-solid fa-heart"></i>';
  } else {
    wl.splice(idx, 1);
    btn.classList.remove('active');
    btn.innerHTML = '<i class="fa-regular fa-heart"></i>';
  }
  localStorage.setItem('2am_wishlist', JSON.stringify(wl));
}

// ── Free Download ──────────────────────────────────────────────────
function downloadProduct(id) {
  const p = PRODUCTS.find(x => x.id === id);
  if (!p) return;
  // For now open WhatsApp to request
  const msg = encodeURIComponent(`Hi! I'd like to get the FREE download: *${p.name}* from 2AM Study Store 🎒`);
  window.open(`https://wa.me/+917250395555?text=${msg}`, '_blank');
}

// ── Order Modal ────────────────────────────────────────────────────
function openOrder(id) {
  currentProduct = PRODUCTS.find(p => p.id === id);
  if (!currentProduct) return;
  document.getElementById('modalProductName').textContent = 'Order: ' + currentProduct.name;
  document.getElementById('modalEmoji').textContent = currentProduct.emoji;
  document.getElementById('modalPreviewName').textContent = currentProduct.name;
  document.getElementById('modalPreviewPrice').textContent = currentProduct.price === 0 ? 'FREE' : '₹' + currentProduct.price;
  document.getElementById('orderName').value = '';
  document.getElementById('orderPhone').value = '';
  document.getElementById('orderAddress').value = '';
  updateWALink();
  document.getElementById('orderOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeOrderModal() {
  document.getElementById('orderOverlay').classList.remove('open');
  document.body.style.overflow = '';
}

function updateWALink() {
  if (!currentProduct) return;
  const name    = document.getElementById('orderName').value.trim() || 'Customer';
  const phone   = document.getElementById('orderPhone').value.trim();
  const address = document.getElementById('orderAddress').value.trim();
  const price   = currentProduct.price === 0 ? 'FREE' : '₹' + currentProduct.price;
  const msg = encodeURIComponent(
    `Hi 2AM Study! 👋\nI'd like to order:\n\n*Product:* ${currentProduct.name}\n*Price:* ${price}\n*Name:* ${name}\n*Phone:* ${phone}\n*Address:* ${address || 'To be confirmed'}\n\nPlease confirm my order! 🎒`
  );
  document.getElementById('waOrderBtn').href = `https://wa.me/+917250395555?text=${msg}`;
}

['orderName','orderPhone','orderAddress'].forEach(id => {
  document.getElementById(id)?.addEventListener('input', updateWALink);
});

// Close on backdrop click
document.getElementById('orderOverlay').addEventListener('click', function(e) {
  if (e.target === this) closeOrderModal();
});

// ── Init ──────────────────────────────────────────────────────────
renderProducts(PRODUCTS);
</script>

