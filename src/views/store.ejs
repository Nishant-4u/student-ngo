  { id:416, cat:'essentials', badge:'top', badgeLabel:'Best Value', brand:'2 AM Study', name:'Study Essentials Kit', specs:'Complete Stationary | 12 Items', price:899, orig:1299, rating:4.6, reviews:320, stock:11, images: ['https://images.unsplash.com/photo-1456735190827-d1262f71b8a3?auto=format&fit=crop&q=80&w=800', 'https://images.unsplash.com/photo-1488190211105-8b0e65b80b4e?auto=format&fit=crop&q=80&w=800'] }
];

let currentCategories = [];
let currentSearch = '';
let currentPriceFilters = []; // Changed to store array of strings
let currentOfferFilters = { discount: false, new: false };
let currentRatingFilters = [];
let includeOutOfStock = false;
let currentSort = 'Popularity';

const grid = document.getElementById('storeGrid');
const empty = document.getElementById('storeEmpty');
const resultsCount = document.getElementById('resultsCount');

// Debounce helper
function debounce(func, timeout = 300) {
  let timer;
  return (...args) => {
    clearTimeout(timer);
    timer = setTimeout(() => { func.apply(this, args); }, timeout);
  };
}

function renderProducts(skipAnimation = false) {
  let filtered = [...storeProducts];

  // 1. Search Filter
  if (currentSearch) {
    const term = currentSearch.toLowerCase();
    filtered = filtered.filter(p => 
      p.name.toLowerCase().includes(term) || 
      p.cat.toLowerCase().includes(term) ||
      p.brand.toLowerCase().includes(term) ||
      p.specs.toLowerCase().includes(term)
    );
  }

  // 2. Category Filter (Multi-select)
  if (currentCategories.length > 0) {
    filtered = filtered.filter(p => currentCategories.includes(p.cat));
  }

  // 3. Price Filter (Multi-select)
  if (currentPriceFilters.length > 0) {
    filtered = filtered.filter(p => {
      return currentPriceFilters.some(range => {
        if (range === '0-500') return p.price < 500;
        if (range === '500-1000') return p.price >= 500 && p.price <= 1000;
        if (range === '1000-plus') return p.price > 1000;
        return false;
      });
    });
  }

  // 4. Special Offers Filter
  if (currentOfferFilters.discount) {
    filtered = filtered.filter(p => p.orig > p.price);
  }
  if (currentOfferFilters.new) {
    filtered = filtered.filter(p => p.badge === 'new');
  }

  // 5. Ratings Filter
  if (currentRatingFilters.length > 0) {
    const minRating = Math.min(...currentRatingFilters);
    filtered = filtered.filter(p => p.rating >= minRating);
  }

  // 6. Availability Filter
  if (!includeOutOfStock) {
    filtered = filtered.filter(p => p.stock > 0);
  }

  // 6. Sort Logic (Inside renderProducts)
  switch(currentSort) {
    case 'Price -- Low to High': filtered.sort((a, b) => a.price - b.price); break;
    case 'Price -- High to Low': filtered.sort((a, b) => b.price - a.price); break;
    case 'Newest First': filtered.sort((a, b) => b.id - a.id); break;
    case 'Discount': filtered.sort((a, b) => {
      const discA = (a.orig - a.price) / a.orig;
      const discB = (b.orig - b.price) / b.orig;
      return discB - discA;
    }); break;
    // Default is Popularity (stable sort by reviews/rating)
    default: filtered.sort((a, b) => (b.rating * b.reviews) - (a.rating * a.reviews)); break;
  }

  // Update UI
  if (filtered.length === 0) {
    grid.style.display = 'none';
    empty.style.display = 'block';
    resultsCount.textContent = '0';
    return;
  }

  grid.style.display = 'grid';
  empty.style.display = 'none';
  resultsCount.textContent = filtered.length;

  grid.innerHTML = filtered.map((product, index) => {
    const discount = Math.round(((product.orig - product.price) / product.orig) * 100);
    const stockHtml = product.stock <= 10 ? `<span class="flipkart-stock-tag" style="position:relative; margin-left:10px;">Only ${product.stock} left</span>` : '';
    const img1 = product.images ? product.images[0] : 'https://images.unsplash.com/photo-1586075010923-2dd4570fb338?auto=format&fit=crop&q=80&w=800';
    const img2 = product.images && product.images[1] ? product.images[1] : img1;

    return `
    <div class="flipkart-product-card ${skipAnimation ? '' : 'product-anim-entry'}" onclick="viewProduct(${product.id})" style="animation-delay: ${index * 0.05}s">
      <div class="flipkart-product-image">
        <img src="${img1}" class="img-primary" alt="${product.name}">
        <img src="${img2}" class="img-secondary" alt="${product.name}">
        ${product.badge ? `<span class="flipkart-product-badge flipkart-badge-${product.badge}">${product.badgeLabel}</span>` : ''}
        <button class="flipkart-wishlist-btn" onclick="toggleWishlist(event, this)">
          <i class="fa-solid fa-heart"></i>
        </button>
      </div>
      <div class="flipkart-product-content">
        <span class="flipkart-product-brand">${product.brand}</span>
        <h3 class="flipkart-product-title">${product.name}</h3>
        <span class="flipkart-product-specs">${product.specs}</span>
        
        <div class="flipkart-rating-row">
          <span class="flipkart-rating-pill">${product.rating} ★</span>
          <span class="flipkart-review-count">(${product.reviews.toLocaleString()})</span>
          ${stockHtml}
        </div>
        
        <div class="flipkart-price-row">
          <span class="price-current">₹${product.price}</span>
          <span class="price-original">₹${product.orig}</span>
          <span class="price-discount">${discount}% off</span>
        </div>
      </div>
    </div>
    `;
  }).join('');
}

function viewProduct(productId) {
  window.location.href = `/store/product/${productId}`;
}

function toggleWishlist(event, btn) {
  event.stopPropagation(); // prevent opening the product page
  btn.classList.toggle('active');
  const icon = btn.querySelector('i');
  // Optional animation effect
  icon.style.transform = 'scale(1.2)';
  setTimeout(() => icon.style.transform = 'scale(1)', 150);
}

// Event Listeners
// Search handled below with clear button logic

document.querySelectorAll('.category-filter').forEach(checkbox => {
  checkbox.addEventListener('change', () => {
    currentCategories = Array.from(document.querySelectorAll('.category-filter:checked')).map(cb => cb.value);
    renderProducts();
  });
});

document.querySelectorAll('.price-filter').forEach(checkbox => {
  checkbox.addEventListener('change', () => {
    currentPriceFilters = Array.from(document.querySelectorAll('.price-filter:checked')).map(cb => cb.value);
    renderProducts();
  });
});

document.getElementById('filterDiscount')?.addEventListener('change', (e) => {
  currentOfferFilters.discount = e.target.checked;
  renderProducts();
});

document.getElementById('filterNew')?.addEventListener('change', (e) => {
  currentOfferFilters.new = e.target.checked;
  renderProducts();
});

document.querySelectorAll('.rating-filter').forEach(checkbox => {
  checkbox.addEventListener('change', () => {
    currentRatingFilters = Array.from(document.querySelectorAll('.rating-filter:checked')).map(cb => parseFloat(cb.value));
    renderProducts();
  });
});

document.getElementById('filterOutOfStock')?.addEventListener('change', (e) => {
  includeOutOfStock = e.target.checked;
  renderProducts();
});

// Sort tabs
document.querySelectorAll('.sort-tab').forEach(tab => {
  tab.addEventListener('click', function() {
    document.querySelectorAll('.sort-tab').forEach(t => t.classList.remove('active'));
    this.classList.add('active');
    currentSort = this.dataset.sort;
    renderProducts();
  });
});

// Search functionality
const searchInput = document.getElementById('storeSearchInput');
const debouncedRender = debounce(() => renderProducts(), 250);

searchInput?.addEventListener('input', (e) => {
  currentSearch = e.target.value;
  debouncedRender();
});

// Total count element
const totalCount = document.getElementById('totalCount');
if (totalCount) totalCount.textContent = storeProducts.length;

// Mobile UX logic
const mobileFilterBtn = document.getElementById('mobileFilterBtn');
const mobileSortBtn = document.getElementById('mobileSortBtn');
const sidebarOverlay = document.getElementById('sidebarOverlay');
const flipkartSidebar = document.getElementById('flipkartSidebar');
const closeFilterBtn = document.getElementById('closeFilterBtn');

const flipkartSortSidebar = document.getElementById('flipkartSortSidebar');
const closeSortBtn = document.getElementById('closeSortBtn');

function toggleFilter() {
  flipkartSidebar.classList.toggle('show');
  sidebarOverlay.classList.toggle('show');
  document.body.style.overflow = flipkartSidebar.classList.contains('show') ? 'hidden' : '';
}

function toggleSort() {
  flipkartSortSidebar.classList.toggle('show');
  sidebarOverlay.classList.toggle('show');
  document.body.style.overflow = flipkartSortSidebar.classList.contains('show') ? 'hidden' : '';
}

mobileFilterBtn?.addEventListener('click', toggleFilter);
closeFilterBtn?.addEventListener('click', toggleFilter);

mobileSortBtn?.addEventListener('click', toggleSort);
closeSortBtn?.addEventListener('click', toggleSort);

sidebarOverlay?.addEventListener('click', () => {
  flipkartSidebar.classList.remove('show');
  flipkartSortSidebar.classList.remove('show');
  sidebarOverlay.classList.remove('show');
  document.body.style.overflow = '';
});

// Mobile Sort logic
document.querySelectorAll('.mobile-sort-radio').forEach(radio => {
  radio.addEventListener('change', (e) => {
    currentSort = e.target.value;
    // update desktop tabs sync
    document.querySelectorAll('.sort-tab').forEach(t => {
      if(t.dataset.sort === currentSort) t.classList.add('active');
      else t.classList.remove('active');
    });
    toggleSort();
    renderProducts();
  });
});

// Initial render
renderProducts();
</script>

