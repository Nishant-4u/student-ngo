/* ── State ────────────────────────────────────────────────────────── */
let currentCat   = 'all';
let currentPrice = 'all';
let cart = JSON.parse(localStorage.getItem('2am_cart') || '[]');

/* ── Category Counts ──────────────────────────────────────────────── */
function updateCounts() {
  const cats = ['all','notebooks','bottles','bags','essentials'];
  cats.forEach(c => {
    const el = document.getElementById('cnt-'+c);
    if (!el) return;
    el.textContent = c === 'all' ? PRODUCTS.length : PRODUCTS.filter(p => p.cat === c).length;
  });
}

/* ── Filters ────────────────────────────────────────────────────────  */
function setCat(cat, el) {
  currentCat = cat;
  document.querySelectorAll('.cat-item').forEach(x => x.classList.remove('active'));
  el.classList.add('active');
  applyFilters();
}

function setPrice(range, el) {
  currentPrice = range;
  document.querySelectorAll('.price-btn').forEach(x => x.classList.remove('active'));
  el.classList.add('active');
  applyFilters();
}

function priceInRange(price) {
  if (currentPrice === 'all')     return true;
  if (currentPrice === 'u200')    return price < 200;
  if (currentPrice === '200-500') return price >= 200 && price <= 500;
  if (currentPrice === '500-1000')return price > 500 && price <= 1000;
  if (currentPrice === 'o1000')   return price > 1000;
  return true;
}

function applyFilters() {
  const q    = document.getElementById('searchInput').value.toLowerCase().trim();
  const sort = document.getElementById('sortSelect').value;

  let list = PRODUCTS.filter(p => {
    const catOk   = currentCat === 'all' || p.cat === currentCat;
    const priceOk = priceInRange(p.price);
    const textOk  = !q || p.name.toLowerCase().includes(q) || p.desc.toLowerCase().includes(q) || p.cat.includes(q);
    return catOk && priceOk && textOk;
  });

  if (sort === 'price-asc')  list.sort((a,b) => a.price - b.price);
  if (sort === 'price-desc') list.sort((a,b) => b.price - a.price);
  if (sort === 'rating')     list.sort((a,b) => b.rating - a.rating);
  if (sort === 'discount')   list.sort((a,b) => (b.orig - b.price) - (a.orig - a.price));

  renderProducts(list);
}

/* ── Render Products ───────────────────────────────────────────────── */
function renderProducts(list) {
  const grid   = document.getElementById('productsGrid');
  const noRes  = document.getElementById('noResults');
  const rc     = document.getElementById('resultCount');

  rc.textContent = list.length + ' product' + (list.length !== 1 ? 's' : '');

  if (!list.length) {
    grid.innerHTML = '';
    noRes.style.display = 'block';
    return;
  }
  noRes.style.display = 'none';

  const wl = JSON.parse(localStorage.getItem('2am_wl') || '[]');
  const inCart = id => cart.some(c => c.id === id);

  grid.innerHTML = list.map(p => {
    const disc    = p.orig > p.price ? Math.round((p.orig - p.price) * 100 / p.orig) : 0;
    const stars   = '★'.repeat(Math.round(p.rating)) + '☆'.repeat(5 - Math.round(p.rating));
    const badgeHtml = p.badge ? `<span class="p-badge badge-${p.badge}">${p.badgeLabel}</span>` : '';
    const heartOn   = wl.includes(p.id);
    const added     = inCart(p.id);

    return `
    <div class="p-card" data-id="${p.id}">
      <div class="p-img">
        <span class="p-emoji">${p.emoji}</span>
        ${badgeHtml}
        <button class="p-heart ${heartOn?'on':''}" onclick="toggleWL(${p.id},this)" title="Wishlist">
          <i class="fa-${heartOn?'solid':'regular'} fa-heart"></i>
        </button>
      </div>
      <div class="p-info">
        <div class="p-cat">${p.cat === 'essentials' ? 'Study Essentials' : p.cat === 'bottles' ? 'Water Bottles' : p.cat === 'bags' ? 'College Bags' : 'Notebooks'}</div>
        <div class="p-name">${p.name}</div>
        <div class="p-desc">${p.desc}</div>
        <div class="p-stars">
          <span class="stars-gold">${stars}</span>
          <span style="color:#f59e0b;font-weight:700;">${p.rating}</span>
          <span class="rev-count">(${p.reviews})</span>
        </div>
        <div class="p-footer">
          <div class="p-price">
            <span class="price-now">₹${p.price}</span>
            ${p.orig > p.price ? `<span class="price-was">₹${p.orig}</span><span class="price-off">${disc}% off</span>` : ''}
          </div>
          <button class="btn-cart ${added?'added':''}" id="btn-${p.id}" onclick="addToCart(${p.id})">
            <i class="fa-solid fa-${added?'check':'bag-shopping'} fa-xs"></i>
            ${added ? 'Added' : 'Add'}
          </button>
        </div>
      </div>
    </div>`;
  }).join('');
}

/* ── Cart Logic ────────────────────────────────────────────────────── */
function addToCart(id) {
  const p = PRODUCTS.find(x => x.id === id);
  if (!p) return;
  const existing = cart.find(c => c.id === id);
  if (existing) {
    existing.qty++;
  } else {
    cart.push({ id: p.id, name: p.name, price: p.price, emoji: p.emoji, qty: 1 });
  }
  saveCart();
  // Update button
  const btn = document.getElementById('btn-' + id);
  if (btn) {
    btn.classList.add('added');
    btn.innerHTML = '<i class="fa-solid fa-check fa-xs"></i> Added';
  }
  updateCartUI();
  openCart();
}

function changeQty(id, delta) {
  const item = cart.find(c => c.id === id);
  if (!item) return;
  item.qty += delta;
  if (item.qty <= 0) cart = cart.filter(c => c.id !== id);
  saveCart();
  updateCartUI();
  renderCart();
  // Re-render product grid to update button states
  applyFilters();
}

function removeItem(id) {
  cart = cart.filter(c => c.id !== id);
  saveCart();
  updateCartUI();
  renderCart();
  applyFilters();
}

function clearCart() {
  cart = [];
  saveCart();
  updateCartUI();
  renderCart();
  applyFilters();
}

function saveCart() { localStorage.setItem('2am_cart', JSON.stringify(cart)); }

function updateCartUI() {
  const total = cart.reduce((s, c) => s + c.qty, 0);
  const badge = document.getElementById('cartBadge');
  const head  = document.getElementById('cartCountHead');
  badge.textContent = total || '';
  if (head) head.textContent = total ? `(${total} item${total > 1 ? 's' : ''})` : '';
}

function renderCart() {
  const body = document.getElementById('cartBody');
  const foot = document.getElementById('cartFoot');

  if (!cart.length) {
    body.innerHTML = `
      <div class="cart-empty">
        <i class="fa-solid fa-bag-shopping"></i>
        <div>
          <p style="font-weight:700;color:#94a3b8;margin-bottom:.25rem;">Your cart is empty</p>
          <small style="color:#475569;">Explore our products and add items to your cart</small>
        </div>
      </div>`;
    foot.style.display = 'none';
    return;
  }

  foot.style.display = 'block';
  body.innerHTML = cart.map(c => `
    <div class="cart-item">
      <span class="ci-emoji">${c.emoji}</span>
      <div class="ci-info">
        <div class="ci-name">${c.name}</div>
        <div class="ci-price">₹${c.price} × ${c.qty} = ₹${c.price * c.qty}</div>
        <div class="qty-ctrl">
          <button class="qty-btn" onclick="changeQty(${c.id},-1)"><i class="fa-solid fa-minus fa-xs"></i></button>
          <span class="qty-val">${c.qty}</span>
          <button class="qty-btn" onclick="changeQty(${c.id},1)"><i class="fa-solid fa-plus fa-xs"></i></button>
          <button class="ci-remove" onclick="removeItem(${c.id})" title="Remove"><i class="fa-solid fa-trash-can fa-xs"></i></button>
        </div>
      </div>
    </div>`).join('');

  const subtotal = cart.reduce((s, c) => s + c.price * c.qty, 0);
  document.getElementById('cartTotal').textContent = '₹' + subtotal;
  document.getElementById('cartFreeShip').textContent = subtotal >= 499
    ? '✓ Free delivery applied!'
    : `Add ₹${499 - subtotal} more for free delivery`;
  document.getElementById('cartFreeShip').style.color = subtotal >= 499 ? '#34d399' : '#94a3b8';

  // Build WhatsApp message
  const lines = cart.map(c => `• ${c.name} × ${c.qty} = ₹${c.price * c.qty}`).join('%0A');
  const msg   = encodeURIComponent(`Hi 2AM Study! 👋 I'd like to place an order:%0A%0A${decodeURIComponent(lines)}%0A%0A*Total: ₹${subtotal}*%0A%0APlease confirm my order 🎒`);
  document.getElementById('waBtn').href = `https://wa.me/917250395555?text=${msg}`;
}

/* ── Cart Drawer Open/Close ─────────────────────────────────────────── */
function openCart() {
  renderCart();
  document.getElementById('cartDrawer').classList.add('open');
  document.getElementById('cartOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeCart() {
  document.getElementById('cartDrawer').classList.remove('open');
  document.getElementById('cartOverlay').classList.remove('open');
  document.body.style.overflow = '';
}

/* ── Wishlist ────────────────────────────────────────────────────────── */
function toggleWL(id, btn) {
  let wl = JSON.parse(localStorage.getItem('2am_wl') || '[]');
  const idx = wl.indexOf(id);
  if (idx === -1) {
    wl.push(id);
    btn.classList.add('on');
    btn.innerHTML = '<i class="fa-solid fa-heart"></i>';
  } else {
    wl.splice(idx, 1);
    btn.classList.remove('on');
    btn.innerHTML = '<i class="fa-regular fa-heart"></i>';
  }
  localStorage.setItem('2am_wl', JSON.stringify(wl));
}

/* ── Init ────────────────────────────────────────────────────────────── */
updateCounts();
applyFilters();
updateCartUI();
</script>

