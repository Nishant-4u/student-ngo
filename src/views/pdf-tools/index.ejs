<%- include('../partials/header') %>

<section class="py-5 text-white text-center" style="background: linear-gradient(135deg, #dc2626 0%, #7c3aed 100%); padding-top: 100px !important;">
  <div class="container py-5 mt-4">
    <h1 class="display-4 fw-bold mb-3"><i class="fa-solid fa-file-pdf me-3"></i>Professional PDF Hub</h1>
    <p class="lead fw-light mb-0" style="max-width: 640px; margin: 0 auto;">
      All-in-one suite of free, fast, and student-friendly PDF tools for your academic documents.
    </p>
  </div>
</section>

<main class="container py-5">
  <div class="row g-4">

    <!-- PDF Maker -->
    <div class="col-md-6 col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 h-100 p-3 text-center hover-lift">
        <div class="card-body">
          <i class="fa-solid fa-file-pdf fa-3x text-primary mb-3"></i>
          <h4 class="fw-bold">Professional PDF Maker</h4>
          <p class="text-muted small">Compress, reorder, and watermark images or text into premium PDFs.</p>
          <a href="/pdf-tools/maker" class="btn btn-outline-primary rounded-pill w-100 fw-bold">Open Pro Tool</a>
        </div>
      </div>
    </div>

    <!-- PDF Merger -->
    <div class="col-md-6 col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 h-100 p-3 text-center hover-lift">
        <div class="card-body">
          <i class="fa-solid fa-object-group fa-3x text-success mb-3"></i>
          <h4 class="fw-bold">PDF Merger</h4>
          <p class="text-muted small">Combine multiple PDF files into a single document.</p>
          <a href="/pdf-tools/merger" class="btn btn-outline-success rounded-pill w-100 fw-bold">Open Tool</a>
        </div>
      </div>
    </div>

    <!-- PDF Splitter -->
    <div class="col-md-6 col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 h-100 p-3 text-center hover-lift">
        <div class="card-body">
          <i class="fa-solid fa-scissors fa-3x text-warning mb-3"></i>
          <h4 class="fw-bold">PDF Splitter</h4>
          <p class="text-muted small">Extract specific pages or ranges from any PDF.</p>
          <a href="/pdf-tools/splitter" class="btn btn-outline-warning rounded-pill w-100 fw-bold text-dark">Open Tool</a>
        </div>
      </div>
    </div>

    <!-- PDF Editor -->
    <div class="col-md-6 col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 h-100 p-3 text-center hover-lift">
        <div class="card-body">
          <i class="fa-solid fa-pen-to-square fa-3x text-info mb-3"></i>
          <h4 class="fw-bold">PDF Editor</h4>
          <p class="text-muted small">Add text, drawings, and annotations to PDFs.</p>
          <a href="/pdf-tools/editor" class="btn btn-outline-info rounded-pill w-100 fw-bold">Open Tool</a>
        </div>
      </div>
    </div>

    <!-- PDF Compressor -->
    <div class="col-md-6 col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 h-100 p-3 text-center hover-lift">
        <div class="card-body">
          <i class="fa-solid fa-compress fa-3x text-danger mb-3"></i>
          <h4 class="fw-bold">PDF Compressor</h4>
          <p class="text-muted small">Reduce file size without losing quality, for easy sharing.</p>
          <a href="/pdf-tools/compressor" class="btn btn-outline-danger rounded-pill w-100 fw-bold">Open Tool</a>
        </div>
      </div>
    </div>

    <!-- PDF Converter -->
    <div class="col-md-6 col-lg-4">
      <div class="card border-0 shadow-sm rounded-4 h-100 p-3 text-center hover-lift">
        <div class="card-body">
          <i class="fa-solid fa-file-word fa-3x text-secondary mb-3"></i>
          <h4 class="fw-bold">To PDF Converter</h4>
          <p class="text-muted small">Convert Word docs, text files, and more into PDF format.</p>
          <a href="/pdf-tools/converter" class="btn btn-outline-secondary rounded-pill w-100 fw-bold">Open Tool</a>
        </div>
      </div>
    </div>

  </div>
</main>

<%- include('../partials/footer') %>
