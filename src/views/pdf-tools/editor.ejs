<%- include('../partials/header') %>

<!-- pdf-lib CDN -->
<script src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>

<main class="container py-5 my-0">
  <div class="row pt-5 justify-content-center">
    <div class="col-lg-8">
      <div class="bg-white p-4 p-md-5 rounded-4 shadow-lg border-0 text-center">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb justify-content-center mb-4">
            <li class="breadcrumb-item"><a href="/pdf-tools">PDF Tools</a></li>
            <li class="breadcrumb-item active" aria-current="page">Editor</li>
          </ol>
        </nav>

        <div class="alert alert-info d-flex flex-column flex-sm-row align-items-center justify-content-center gap-2 gap-sm-3 mb-4 rounded-pill border-0 shadow-sm transition-hover" style="background: linear-gradient(145deg, #e1f5fe, #b3e5fc);">
           <span class="badge bg-info rounded-pill px-3 py-2 border shadow-sm text-white">1. Upload PDF</span>
           <i class="fa-solid fa-arrow-right text-info opacity-75 d-none d-sm-block"></i><i class="fa-solid fa-arrow-down text-info opacity-75 d-block d-sm-none"></i>
           <span class="badge bg-info rounded-pill px-3 py-2 border shadow-sm text-white">2. Select Action</span>
           <i class="fa-solid fa-arrow-right text-info opacity-75 d-none d-sm-block"></i><i class="fa-solid fa-arrow-down text-info opacity-75 d-block d-sm-none"></i>
           <span class="badge bg-info rounded-pill px-3 py-2 border shadow-sm text-white">3. Download</span>
        </div>

        <h1 class="display-5 fw-bold mb-3 text-info"><i class="fa-solid fa-file-pen me-2"></i> Metadata Editor</h1>
        <p class="text-muted mb-5">Edit the hidden metadata (Title, Author, Subject) of your PDF files securely in your browser.</p>

        <div class="p-4 border border-info border-2 border-dashed rounded-4 bg-light mb-4 position-relative">
            <i class="fa-solid fa-file-pdf fa-3x text-info opacity-75 mb-3"></i>
            <h5 class="fw-bold">Upload PDF File</h5>
            <input type="file" id="editorInput" accept=".pdf" class="position-absolute top-0 start-0 w-100 h-100 opacity-0" style="cursor: pointer;" onchange="handleFile()">
            <p id="fileNameDisplay" class="text-muted fw-bold d-none"></p>
        </div>
        
        <div id="editorControls" class="d-none text-start bg-light p-4 rounded-4 mb-4 border border-info border-opacity-25">
            <div class="mb-3">
                <label class="form-label fw-bold small text-muted">Title</label>
                <input type="text" id="metaTitle" class="form-control focus-ring" placeholder="E.g., Math Assignment">
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold small text-muted">Author</label>
                <input type="text" id="metaAuthor" class="form-control focus-ring" placeholder="Your Name">
            </div>
            <div class="mb-4">
                <label class="form-label fw-bold small text-muted">Subject / Keywords</label>
                <input type="text" id="metaSubject" class="form-control focus-ring" placeholder="Algebra, Chapter 1">
            </div>

            <button class="btn btn-info text-white btn-lg w-100 fw-bold shadow-sm" onclick="saveMetadata()"><i class="fa-solid fa-floppy-disk me-2"></i> Update & Download</button>
        </div>

        <div id="loader" class="mt-4 d-none">
            <div class="progress mb-2 rounded-pill shadow-sm" style="height: 12px;">
                <div class="progress-bar progress-bar-striped progress-bar-animated bg-info" role="progressbar" style="width: 100%"></div>
            </div>
            <p class="fw-bold text-info small mb-0">Processing your document...</p>
        </div>

        <div class="d-flex flex-column flex-md-row justify-content-center gap-3 mt-5">
            <a href="/" class="btn btn-outline-secondary rounded-pill px-4 fw-bold shadow-sm transition-hover"><i class="fa-solid fa-house me-2"></i>Back to Hub</a>
            <button class="btn btn-outline-info rounded-pill px-4 fw-bold shadow-sm transition-hover" onclick="shareTool()"><i class="fa-solid fa-share-nodes me-2"></i>Share Tool</button>
        </div>

      </div>
    </div>
  </div>
</main>

<script>
let loadedPdfFile = null;
let currentPdfDoc = null;

async function handleFile() {
    const input = document.getElementById('editorInput');
    const nameDisplay = document.getElementById('fileNameDisplay');
    const controls = document.getElementById('editorControls');
    
    if (input.files.length > 0) {
        loadedPdfFile = input.files[0];
        nameDisplay.textContent = `Selected: ${loadedPdfFile.name}`;
        nameDisplay.classList.remove('d-none');
        
        const arrayBuffer = await loadedPdfFile.arrayBuffer();
        try {
            const { PDFDocument } = PDFLib;
            currentPdfDoc = await PDFDocument.load(arrayBuffer);
            
            // Populate existing metadata
            document.getElementById('metaTitle').value = currentPdfDoc.getTitle() || '';
            document.getElementById('metaAuthor').value = currentPdfDoc.getAuthor() || '';
            document.getElementById('metaSubject').value = currentPdfDoc.getSubject() || '';
            
            controls.classList.remove('d-none');
        } catch(e) {
            alert("Error reading PDF. Ensure it's a valid PDF file.");
        }
    }
}

async function saveMetadata() {
    if (!currentPdfDoc) return;
    
    document.getElementById('editorControls').classList.add('d-none');
    document.getElementById('loader').classList.remove('d-none');

    try {
        currentPdfDoc.setTitle(document.getElementById('metaTitle').value);
        currentPdfDoc.setAuthor(document.getElementById('metaAuthor').value);
        currentPdfDoc.setSubject(document.getElementById('metaSubject').value);
        
        const pdfBytes = await currentPdfDoc.save();
        download(pdfBytes, `Edited_${loadedPdfFile.name}`, "application/pdf");
        
    } catch (error) {
        alert("Failed to update PDF.");
        console.error(error);
    } finally {
        document.getElementById('loader').classList.add('d-none');
        document.getElementById('editorControls').classList.remove('d-none');
    }
}

function download(data, filename, type) {
    const blob = new Blob([data], { type: type });
    const link = document.createElement('a');
    link.href = window.URL.createObjectURL(blob);
    link.download = filename;
    link.click();
    setTimeout(() => window.URL.revokeObjectURL(link.href), 100);
}

function shareTool() {
    if (navigator.share) {
        navigator.share({ title: document.title, text: 'Check out this awesome free PDF tool on 2AM Study!', url: window.location.href }).catch(console.error);
    } else {
        const tempInput = document.createElement("input");
        tempInput.value = window.location.href;
        document.body.appendChild(tempInput);
        tempInput.select();
        document.execCommand("copy");
        document.body.removeChild(tempInput);
        alert("Link copied to clipboard!");
    }
}
</script>

<%- include('../partials/footer') %>
