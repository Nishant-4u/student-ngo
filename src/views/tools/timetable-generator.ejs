<%- include('../partials/header') %>

<main class="container py-5 my-0">
  <div class="row pt-5 justify-content-center">
    <div class="col-lg-12">
      <div class="bg-white p-4 p-md-5 rounded-4 shadow-lg border-0 mt-5">
        
        <div class="d-flex justify-content-between align-items-center mb-4 no-print">
          <a href="/tasks" class="btn btn-sm btn-outline-secondary rounded-pill px-4" style="font-size: 0.8rem;"><i class="fa-solid fa-arrow-left me-1"></i> Back to Hub</a>
          <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 border border-primary border-opacity-10">
            <i class="fa-solid fa-calendar-days me-1"></i> Schedule Builder
          </span>
        </div>

        <div class="text-center mb-5">
            <h1 class="display-5 fw-bold mb-3" style="color: #6366f1;"><i class="fa-solid fa-table-cells me-2"></i> Timetable Generator</h1>
            <p class="text-muted fs-5">Create, visualize, and print your weekly study schedule for peak productivity.</p>
        </div>

        <!-- Controls -->
        <div class="row g-3 mb-5 no-print bg-light p-4 rounded-4 border shadow-sm">
            <div class="col-md-3">
                <label class="form-label fw-bold text-muted small text-uppercase tracking-wider">Day of Week</label>
                <div class="input-group">
                  <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-calendar text-primary"></i></span>
                  <select id="daySelect" class="form-select border-start-0 ps-0 shadow-none">
                      <option value="Monday">Monday</option>
                      <option value="Tuesday">Tuesday</option>
                      <option value="Wednesday">Wednesday</option>
                      <option value="Thursday">Thursday</option>
                      <option value="Friday">Friday</option>
                      <option value="Saturday">Saturday</option>
                      <option value="Sunday">Sunday</option>
                  </select>
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold text-muted small text-uppercase tracking-wider">Time Slot</label>
                <div class="input-group">
                  <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-clock text-primary"></i></span>
                  <input type="text" id="timeInput" class="form-control border-start-0 ps-0 shadow-none" placeholder="e.g. 09-11 AM">
                </div>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold text-muted small text-uppercase tracking-wider">Subject / Activity</label>
                <div class="input-group">
                  <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-book text-primary"></i></span>
                  <input type="text" id="subjectInput" class="form-control border-start-0 ps-0 shadow-none" placeholder="e.g. Mathematics Hub">
                </div>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-primary w-100 fw-bold rounded-pill shadow px-4" style="height: 48px; background-color: #6366f1;" onclick="addSlot()">
                  <i class="fa-solid fa-plus-circle me-1"></i> Add
                </button>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-4 no-print">
            <h5 class="fw-bold text-dark mb-0"><i class="fa-solid fa-eye me-2 text-primary opacity-50"></i> Table Preview</h5>
            <div class="d-flex gap-2">
                <button class="btn btn-link text-danger btn-sm text-decoration-none fw-bold" onclick="clearTable()"><i class="fa-solid fa-trash-can me-1"></i> Reset All</button>
                <button class="btn btn-dark btn-sm rounded-pill px-4 shadow-sm" onclick="window.print()"><i class="fa-solid fa-file-pdf me-2"></i> Print / Save PDF</button>
            </div>
        </div>

        <!-- Timetable View -->
        <div class="table-responsive bg-white rounded-4 shadow-sm border overflow-hidden">
            <table class="table table-bordered text-center align-middle mb-0" style="min-width: 900px;">
                <thead class="text-white" style="background-color: #4f46e5;">
                    <tr>
                        <th class="py-4 fw-bold small text-uppercase" style="width: 12%">Time</th>
                        <th class="py-4 fw-bold small text-uppercase">Mon</th>
                        <th class="py-4 fw-bold small text-uppercase">Tue</th>
                        <th class="py-4 fw-bold small text-uppercase">Wed</th>
                        <th class="py-4 fw-bold small text-uppercase">Thu</th>
                        <th class="py-4 fw-bold small text-uppercase">Fri</th>
                        <th class="py-4 fw-bold small text-uppercase">Sat</th>
                        <th class="py-4 fw-bold small text-uppercase">Sun</th>
                    </tr>
                </thead>
                <tbody id="timetableBody">
                    <!-- Rows generated here -->
                </tbody>
            </table>
        </div>
        
        <p class="text-center mt-4 small text-muted no-print"><i class="fa-solid fa-lightbulb me-1 text-warning"></i> Click on any entry to remove it. Your table is automatically saved between visits.</p>

      </div>
    </div>
  </div>
</main>

<style>
/* Print optimizations */
@media print {
    body * { visibility: hidden; }
    .no-print { display: none !important; }
    #timetableBody, #timetableBody *, .table, .table * { visibility: visible; }
    .table { position: absolute; left: 0; top: 0; width: 100%; border: 1px solid #000; table-layout: fixed; }
    .table th { color: #000 !important; background-color: #f8f9fa !important; border: 1px solid #000 !important; }
    .table td { border: 1px solid #000 !important; color: #000 !important; padding: 12px 5px !important; }
}

.table td {
  padding: 15px 10px;
  min-height: 80px;
  font-size: 0.9rem;
}
.table thead th { border: none !important; }
.time-cell { font-weight: 700; color: #4b5563; background-color: #f9fafb !important; }
.slot-filled { 
  background-color: rgba(99, 102, 241, 0.08) !important;
  color: #4f46e5;
  font-weight: 700;
  transition: 0.2s;
  cursor: pointer;
  border: 2px solid rgba(99, 102, 241, 0.1) !important;
}
.slot-filled:hover {
  background-color: rgba(220, 38, 38, 0.1) !important;
  color: #dc3545 !important;
}
.select-day-cell { border-radius: 8px; }

/* Desktop Hover Lift */
.hover-lift { transition: transform 0.2s; }
.hover-lift:hover { transform: translateY(-4px); }
</style>

<script>
let timetable = JSON.parse(localStorage.getItem('studyTimetable')) || [];
const days = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"];

function save() {
    localStorage.setItem('studyTimetable', JSON.stringify(timetable));
    render();
}

function addSlot() {
    const day = document.getElementById('daySelect').value;
    const time = document.getElementById('timeInput').value.trim();
    const subject = document.getElementById('subjectInput').value.trim();

    if(!time || !subject) return alert("Please enter both Time Slot and Subject");

    // Check if time slot exists, if not create
    let slot = timetable.find(t => t.time === time);
    if (!slot) {
        slot = { time: time, slots: {} };
        timetable.push(slot);
        // Basic sort: this could be more complex but works for most 09-11 type strings
    }
    
    slot.slots[day] = subject;
    
    document.getElementById('subjectInput').value = '';
    save();
}

function removeSlotData(timeIndex, dayName) {
    if(confirm('Delete this entry?')) {
        delete timetable[timeIndex].slots[dayName];
        
        // If row is entirely empty now, delete row
        if (Object.keys(timetable[timeIndex].slots).length === 0) {
            timetable.splice(timeIndex, 1);
        }
        save();
    }
}

function clearTable() {
    if(confirm('Are you sure you want to reset your entire weekly schedule?')) {
        timetable = [];
        save();
    }
}

function render() {
    const tbody = document.getElementById('timetableBody');
    tbody.innerHTML = '';
    
    if (timetable.length === 0) {
        tbody.innerHTML = `<tr><td colspan="8" class="text-muted py-5 fst-italic">No schedule created yet. Add your first study session above!</td></tr>`;
        return;
    }
    
    // Naive sort by time string
    timetable.sort((a,b) => a.time.localeCompare(b.time));

    timetable.forEach((rowObj, index) => {
        const tr = document.createElement('tr');
        
        // Time Cell
        let html = `<td class="time-cell">${rowObj.time}</td>`;
        
        // Day Cells
        days.forEach(d => {
            const subject = rowObj.slots[d] || '';
            const isFilled = !!subject;
            html += `<td class="${isFilled ? 'slot-filled' : ''}" 
                        onclick="${isFilled ? `removeSlotData(${index}, '${d}')` : ''}"
                        title="${isFilled ? 'Click to delete' : ''}">
                      ${subject}
                     </td>`;
        });
        
        tr.innerHTML = html;
        tbody.appendChild(tr);
    });
}

// Enter support for adding subject
document.getElementById('subjectInput').addEventListener('keypress', e => {
    if(e.key === 'Enter') addSlot();
});

window.onload = render;
</script>

<%- include('../partials/footer') %>
